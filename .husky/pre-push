#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Colors
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Skip checks for main branch and non-feature branches
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  exit 0
fi

# Only check feat/ and fix/ branches (pipeline-tracked branches)
case "$BRANCH" in
  feat/*|fix/*)
    ;;
  *)
    exit 0
    ;;
esac

echo "${BLUE}🔍 Pipeline check: verifying PR for branch ${BRANCH}...${NC}"

# Check if gh CLI is available
if ! command -v gh >/dev/null 2>&1; then
  echo "${YELLOW}⚠️  gh CLI not installed - skipping PR verification${NC}"
  exit 0
fi

# Check if there's an open PR for this branch
PR_URL=$(gh pr view "$BRANCH" --json url --jq '.url' 2>/dev/null || echo "")

if [ -z "$PR_URL" ]; then
  echo "${YELLOW}⚠️  WARNING: No open PR found for branch '${BRANCH}'${NC}"
  echo "${YELLOW}   After pushing, create a PR with:${NC}"
  echo "${YELLOW}   gh pr create --title \"...\" --body \"...\"${NC}"
  echo "${YELLOW}   Then update the card's pipelineStatus.prCreated in Planning Game${NC}"
  echo ""
  # Warning only, does not block push
else
  echo "${GREEN}✅ PR found: ${PR_URL}${NC}"
fi

exit 0
