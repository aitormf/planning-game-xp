#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Colors
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# Card ID pattern: 3 uppercase letters + hyphen + type + hyphen + 4 digits
# Examples: PLN-TSK-0042, C4D-BUG-0015, PMC-TSK-0043
CARD_PATTERN='[A-Z][A-Z0-9]{2}-(TSK|BUG|PCS)-[0-9]{4}'

# Get the merge commit message (last commit after merge)
MERGE_MSG=$(git log -1 --format="%s" HEAD)

# Extract card IDs from the merge commit message or branch name
CARD_IDS=$(echo "$MERGE_MSG" | grep -oE "$CARD_PATTERN" | sort -u)

if [ -z "$CARD_IDS" ]; then
  # Try to extract from the branch name mentioned in merge commit
  BRANCH_NAME=$(echo "$MERGE_MSG" | grep -oE '(feat|fix)/[^ ]+' | head -1)
  if [ -n "$BRANCH_NAME" ]; then
    CARD_IDS=$(echo "$BRANCH_NAME" | grep -oE "$CARD_PATTERN" | sort -u)
  fi
fi

if [ -n "$CARD_IDS" ]; then
  echo ""
  echo "${BLUE}📋 Pipeline reminder after merge:${NC}"
  echo "$CARD_IDS" | while read -r CARD_ID; do
    echo "${YELLOW}   → Update pipelineStatus.merged for ${CARD_ID} in Planning Game${NC}"
    echo "${YELLOW}     Use: update_card with pipelineStatus: { merged: { date: \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\", mergedBy: \"...\" } }${NC}"
  done
  echo ""
fi

exit 0
