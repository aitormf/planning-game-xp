#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

BLUE='\033[0;34m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
DIM='\033[2m'
NC='\033[0m'

COMMIT_MSG=$(git log -1 --pretty=%s HEAD)

case "$COMMIT_MSG" in
  "chore: bump client version"*)
    echo ""
    echo "${GREEN}📦 Version bump committed. Ready to deploy:${NC}"
    echo "${DIM}   npm run deploy:all${NC}"
    echo ""
    exit 0
    ;;
  "Merge "*|"chore: pre-build"*)
    exit 0
    ;;
esac

echo ""
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "${BLUE}  📋 Post-commit checklist${NC}"
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo "${YELLOW}  1.${NC} Run tests if not already done:     ${DIM}npm test${NC}"
echo "${YELLOW}  2.${NC} Build all instances:                ${DIM}npm run build:all${NC}"
echo "${YELLOW}  3.${NC} Deploy all instances:               ${DIM}npm run deploy:all${NC}"
echo ""
echo "${DIM}  build:all includes: version bump + changelog + build${NC}"
echo "${DIM}  deploy:all includes: version check + hosting + functions + RTDB${NC}"
echo ""

exit 0
