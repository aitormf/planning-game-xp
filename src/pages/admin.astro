---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Console">
  <div id="adminContainer" style="display: none; padding: 2rem; max-width: 1400px; margin: 0 auto;">
    <h1 class="admin-title">Admin Console</h1>
    <p class="admin-subtitle">Herramientas de administración y generación de informes</p>

    <!-- Tabs -->
    <div class="admin-tabs">
      <button id="firebaseTab" data-section="firebase" class="admin-tablink active">🔥 Firebase</button>
      <button id="reportsTab" data-section="reports" class="admin-tablink">📊 Informes</button>
      <button id="isoTab" data-section="iso" class="admin-tablink">📋 Informes ISO</button>
      <button id="configTab" data-section="config" class="admin-tablink">⚙️ Configuración</button>
      <button id="trashTab" data-section="trash" class="admin-tablink">🗑️ Papelera</button>
    </div>

    <!-- Firebase Section -->
    <div id="firebaseTabContent" class="admin-tabcontent active">
      <div class="admin-section">
        <h2>Escribir JSON a ruta</h2>
        <div class="form-group">
          <label for="firebasePath">Ruta en Firebase:</label>
          <input type="text" id="firebasePath" class="form-input mono" placeholder="/views" value="/views">
        </div>

        <div class="form-group">
          <label for="jsonInput">JSON a escribir:</label>
          <textarea id="jsonInput" class="form-textarea mono" rows="15" placeholder='{"task-list": {...}, "bug-list": {...}}'></textarea>
        </div>

        <div class="form-group">
          <label>
            <input type="checkbox" id="mergeMode"> Merge (no sobrescribir, solo añadir/actualizar)
          </label>
        </div>

        <div class="button-group">
          <button id="validateJsonBtn" class="btn btn-secondary">Validar JSON</button>
          <button id="loadFromFileBtn" class="btn btn-secondary">Cargar desde archivo</button>
          <input type="file" id="jsonFileInput" accept=".json" style="display: none;">
          <button id="writeToFirebaseBtn" class="btn btn-primary">Escribir a Firebase</button>
        </div>

        <div id="statusMessage" class="status-message" style="display: none;"></div>
      </div>

      <div class="admin-section">
        <h2>Resincronizar Vistas de Proyecto</h2>
        <p class="section-description">Regenera las vistas optimizadas (/views) desde los datos de cards. Útil si las tablas muestran datos desactualizados.</p>
        <div class="form-group">
          <label for="syncProjectId">ID del Proyecto:</label>
          <input type="text" id="syncProjectId" class="form-input mono" placeholder="Intranet-Extended">
        </div>
        <div class="button-group">
          <button id="syncViewsBtn" class="btn btn-primary">Resincronizar Vistas</button>
        </div>
        <div id="syncStatusMessage" class="status-message" style="display: none;"></div>
      </div>

      <div class="admin-section">
        <h2>Leer ruta</h2>
        <div class="form-group">
          <label for="readPath">Ruta a leer:</label>
          <input type="text" id="readPath" class="form-input mono" placeholder="/views/task-list/PlanningGame">
        </div>
        <button id="readFromFirebaseBtn" class="btn btn-secondary">Leer de Firebase</button>
        <pre id="readOutput" class="code-output"></pre>
      </div>
    </div>

    <!-- Reports Section -->
    <div id="reportsTabContent" class="admin-tabcontent">
      <div class="admin-section">
        <h2>Filtros del Informe</h2>
        <div class="report-filters">
          <div class="filter-row">
            <div class="filter-group">
              <label for="reportStartDate">Fecha inicio:</label>
              <input type="date" id="reportStartDate" class="filter-input">
            </div>
            <div class="filter-group">
              <label for="reportEndDate">Fecha fin:</label>
              <input type="date" id="reportEndDate" class="filter-input">
            </div>
            <div class="filter-group year-filter-group">
              <label>Año completo:</label>
              <div class="year-filter-controls">
                <input type="checkbox" id="fullYearCheckbox">
                <select id="yearSelect" class="filter-input year-select" disabled>
                  <!-- Populated by JavaScript -->
                </select>
              </div>
            </div>
          </div>
          <div class="filter-row">
            <div class="filter-group project-select-group">
              <label for="reportProjects">Proyecto:</label>
              <select id="reportProjects" class="filter-input project-select">
                <option value="all" selected>Todos los proyectos</option>
              </select>
            </div>
          </div>
          <div class="button-group">
            <button id="generateReportBtn" class="btn btn-primary">📊 Generar Informe</button>
            <button id="exportPdfBtn" class="btn btn-secondary" disabled>📄 Exportar PDF</button>
          </div>
        </div>
      </div>

      <div id="reportLoading" class="report-loading" style="display: none;">
        <div class="spinner"></div>
        <p>Generando informe...</p>
      </div>

      <div id="reportResults" style="display: none;">
        <!-- Summary Cards -->
        <div class="admin-section">
          <h2>Resumen General</h2>
          <div id="reportSummaryCards" class="summary-cards"></div>
        </div>

        <!-- Project Stats Table -->
        <div class="admin-section">
          <h2>Estadísticas por Proyecto</h2>
          <div id="projectStatsTable" class="stats-table-container"></div>
        </div>

        <!-- Developer Stats grouped by developer groups -->
        <div class="admin-section">
          <h2>Horas por Developer</h2>
          <div id="developerStatsContainer"></div>
        </div>
      </div>
    </div>

    <!-- ISO Reports Section -->
    <div id="isoTabContent" class="admin-tabcontent">
      <div class="admin-section">
        <h2>Informe ISO - Detalle por Developer</h2>
        <div class="report-filters">
          <div class="filter-row">
            <div class="filter-group">
              <label for="isoStartDate">Fecha inicio:</label>
              <input type="date" id="isoStartDate" class="filter-input">
            </div>
            <div class="filter-group">
              <label for="isoEndDate">Fecha fin:</label>
              <input type="date" id="isoEndDate" class="filter-input">
            </div>
            <div class="filter-group year-filter-group">
              <label>Año completo:</label>
              <div class="year-filter-controls">
                <input type="checkbox" id="isoFullYearCheckbox">
                <select id="isoYearSelect" class="filter-input year-select" disabled>
                </select>
              </div>
            </div>
          </div>
          <div class="button-group">
            <button id="generateISOBtn" class="btn btn-primary">📋 Generar Informe ISO</button>
            <button id="exportISOPdfBtn" class="btn btn-secondary" disabled>📄 Exportar PDF</button>
          </div>
        </div>
      </div>

      <div id="isoLoading" class="report-loading" style="display: none;">
        <div class="spinner"></div>
        <p>Generando informe ISO...</p>
      </div>

      <div id="isoResults" style="display: none;"></div>
    </div>

    <!-- Config Section -->
    <div id="configTabContent" class="admin-tabcontent">
      <div class="admin-section">
        <h2>Grupos de Developers</h2>
        <p class="section-description">Clasifica developers en grupos para informes mensuales de horas. Arrastra developers entre grupos y guarda la configuración.</p>

        <div id="configStatusMessage" class="status-message" style="display: none;"></div>

        <div id="groupsNotInitialized" style="display: none;">
          <p style="margin-bottom: 1rem; color: var(--text-muted, #666);">No se encontró configuración de grupos. Pulsa el botón para crear la configuración inicial.</p>
          <button id="initGroupsBtn" class="btn btn-primary">Inicializar grupos con datos por defecto</button>
        </div>

        <div id="groupsEditor" style="display: none;">
          <div class="groups-container">
            <div class="group-column" data-group="internal">
              <h3 class="group-title group-title--internal">Internos</h3>
              <ul id="groupList-internal" class="group-list"></ul>
              <div class="group-add">
                <select id="groupAdd-internal" class="filter-input group-select">
                  <option value="">Añadir developer...</option>
                </select>
              </div>
            </div>

            <div class="group-column" data-group="external">
              <h3 class="group-title group-title--external">Externos</h3>
              <ul id="groupList-external" class="group-list"></ul>
              <div class="group-add">
                <select id="groupAdd-external" class="filter-input group-select">
                  <option value="">Añadir developer...</option>
                </select>
              </div>
            </div>

            <div class="group-column" data-group="manager">
              <h3 class="group-title group-title--manager">Manager</h3>
              <ul id="groupList-manager" class="group-list"></ul>
              <div class="group-add">
                <select id="groupAdd-manager" class="filter-input group-select">
                  <option value="">Añadir developer...</option>
                </select>
              </div>
            </div>
          </div>

          <div class="button-group" style="margin-top: 1.5rem;">
            <button id="saveGroupsBtn" class="btn btn-primary">💾 Guardar Configuración</button>
          </div>
        </div>
      </div>

      <div class="admin-section" style="margin-top: 2rem;">
        <h2>Theme Configuration</h2>
        <p class="section-description">Personaliza colores de marca, colores de estado, branding y features de esta instancia.</p>
        <theme-editor id="themeEditor"></theme-editor>
      </div>
    </div>

    <!-- Trash Section -->
    <div id="trashTabContent" class="admin-tabcontent">
      <div class="admin-section">
        <h2>Papelera</h2>
        <p class="section-description">Cards eliminadas de todos los proyectos. Solo visible para SuperAdmin.</p>
        <div id="trashLoading" class="report-loading" style="display: none;">
          <div class="spinner"></div>
          <p>Cargando papelera...</p>
        </div>
        <div id="trashResults"></div>
      </div>
    </div>
  </div>

  <div id="accessDenied" class="access-denied">
    <h1>Acceso denegado</h1>
    <p>Esta página requiere permisos de SuperAdmin.</p>
    <a href="/" class="link-primary">Volver al inicio</a>
  </div>

  <div id="loadingAuth" style="padding: 2rem; text-align: center;">
    <p>Verificando permisos...</p>
  </div>
</Layout>

<style is:global>
  /* Title and subtitle */
  .admin-title {
    margin-bottom: 0.5rem;
    color: var(--text-primary, #333);
  }

  .admin-subtitle {
    color: var(--text-muted, #666);
    margin-bottom: 1.5rem;
  }

  .section-description {
    color: var(--text-muted, #666);
    margin-bottom: 1rem;
  }

  /* Code output */
  .code-output {
    background: var(--bg-tertiary, #f5f5f5);
    color: var(--text-primary, #333);
    padding: 1rem;
    margin-top: 1rem;
    overflow: auto;
    max-height: 400px;
    display: none;
    border-radius: 4px;
    border: 1px solid var(--border-subtle, #eee);
  }

  /* Access denied */
  .access-denied {
    display: none;
    padding: 2rem;
    text-align: center;
  }

  .access-denied h1 {
    color: var(--text-primary, #333);
  }

  .access-denied p {
    color: var(--text-secondary, #555);
  }

  .link-primary {
    color: var(--brand-primary, #007bff);
  }

  .link-primary:hover {
    color: var(--brand-secondary, #0056b3);
  }

  /* Tabs Styles */
  .admin-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 0;
    border-bottom: 2px solid var(--border-default, #ddd);
  }

  .admin-tablink {
    padding: 0.75rem 1.5rem;
    border: none;
    background: var(--tab-bg, var(--bg-tertiary, #f5f5f5));
    cursor: pointer;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted, #666);
    border-radius: 8px 8px 0 0;
    margin-right: 4px;
    transition: all 0.2s;
  }

  .admin-tablink:hover {
    background: var(--hover-overlay, rgba(0,0,0,0.05));
    color: var(--text-primary, #333);
  }

  .admin-tablink.active {
    background: var(--tab-bg-active, var(--bg-primary, #fff));
    color: var(--brand-primary, #007bff);
    border: 2px solid var(--border-default, #ddd);
    border-bottom: 2px solid var(--tab-bg-active, var(--bg-primary, #fff));
    margin-bottom: -2px;
  }

  .admin-tabcontent {
    display: none;
    padding-top: 1.5rem;
  }

  .admin-tabcontent.active {
    display: block;
  }

  /* Section Styles */
  .admin-section {
    background: var(--card-bg, var(--bg-secondary, #fff));
    border: 1px solid var(--card-border-color, var(--border-default, #ddd));
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .admin-section h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.25rem;
    border-bottom: 1px solid var(--border-subtle, #eee);
    padding-bottom: 0.5rem;
    color: var(--text-primary, #333);
  }

  /* Form Styles */
  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: var(--text-primary, #333);
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--input-border, var(--border-default, #ddd));
    border-radius: 6px;
    font-size: 0.95rem;
    background: var(--input-bg, var(--bg-primary, #fff));
    color: var(--text-primary, #333);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--brand-primary, #007bff);
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.15);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .mono {
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;
    font-size: 0.9rem;
  }

  .button-group {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--brand-primary, #007bff);
    color: white;
  }

  .btn-primary:hover:not(:disabled) {
    background: var(--brand-secondary, #0056b3);
  }

  .btn-secondary {
    background: var(--color-gray-500, #6c757d);
    color: white;
  }

  .btn-secondary:hover:not(:disabled) {
    background: var(--color-gray-600, #545b62);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .status-message {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    border: 1px solid transparent;
  }

  .status-message.success {
    background: var(--status-success-bg, #d4edda);
    color: var(--status-success-text, #155724);
    border-color: var(--status-success-border, #c3e6cb);
  }

  .status-message.error {
    background: var(--status-error-bg, #f8d7da);
    color: var(--status-error-text, #721c24);
    border-color: var(--status-error-border, #f5c6cb);
  }

  .status-message.info {
    background: var(--status-info-bg, #cce5ff);
    color: var(--status-info-text, #004085);
    border-color: var(--status-info-border, #b8daff);
  }

  /* Report Filters Styles */
  .report-filters {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .filter-row {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 180px;
  }

  .filter-group label {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-secondary, #555);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .filter-input {
    padding: 0.75rem;
    border: 1px solid var(--input-border, var(--border-default, #ddd));
    border-radius: 6px;
    font-size: 0.95rem;
    background: var(--input-bg, var(--bg-primary, #fff));
    color: var(--text-primary, #333);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .filter-input:focus {
    outline: none;
    border-color: var(--brand-primary, #007bff);
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.15);
  }

  .project-select-group {
    flex: 0 1 auto;
    min-width: 250px;
    max-width: 350px;
  }

  .project-select {
    font-size: 1.1rem;
    padding: 0.75rem 1rem;
    cursor: pointer;
  }

  .project-select:hover {
    border-color: var(--brand-primary, #007bff);
  }

  .checkbox-group {
    flex: 0 0 auto;
    flex-direction: row;
    align-items: center;
    padding-bottom: 0.5rem;
  }

  .checkbox-group label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.95rem;
    text-transform: none;
    letter-spacing: normal;
  }

  .checkbox-group input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--brand-primary, #007bff);
  }

  /* Year filter group */
  .year-filter-group {
    flex: 0 0 auto;
    min-width: auto;
  }

  .year-filter-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .year-filter-controls input[type="checkbox"] {
    width: 20px;
    height: 20px;
    cursor: pointer;
    accent-color: var(--brand-primary, #007bff);
  }

  .year-select {
    width: 100px;
    font-size: 1rem;
    padding: 0.5rem 0.75rem;
    text-align: center;
    font-weight: 600;
  }

  .year-select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Report Loading */
  .report-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    color: var(--text-muted, #666);
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--border-subtle, #f3f3f3);
    border-top: 4px solid var(--brand-primary, #007bff);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1rem;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Summary Cards */
  .summary-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .summary-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 1.25rem;
    border-radius: 8px;
    text-align: center;
  }

  .summary-card.tasks {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  }

  .summary-card.bugs {
    background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
  }

  .summary-card.time {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  }

  .summary-card.projects {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .summary-card .value {
    font-size: 2.5rem;
    font-weight: bold;
    display: block;
  }

  .summary-card .label {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-top: 0.25rem;
  }

  /* Stats Table */
  .stats-table-container {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-subtle, #eee);
  }

  .stats-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .stats-table th,
  .stats-table td {
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--border-subtle, #eee);
  }

  .stats-table th:first-child,
  .stats-table td:first-child {
    text-align: left;
    font-weight: 600;
  }

  .stats-table th {
    background: var(--bg-tertiary, #f8f9fa);
    font-weight: 700;
    color: var(--text-primary, #333);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
  }

  .stats-table tbody tr {
    transition: background-color 0.15s;
  }

  .stats-table tbody tr:hover {
    background: var(--hover-overlay, rgba(0,0,0,0.03));
  }

  .stats-table tbody tr:last-child td {
    border-bottom: none;
  }

  .stats-table .number {
    text-align: center;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }

  .stats-table .highlight-cell {
    color: var(--brand-primary, #007bff);
    font-weight: 700;
  }

  /* Developer Stats Grid */
  .developer-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .developer-card {
    background: var(--card-bg, #fff);
    border: none;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px var(--shadow-color, rgba(0,0,0,0.08));
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .developer-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px var(--shadow-color, rgba(0,0,0,0.15));
  }

  .developer-card .dev-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border-subtle, #eee);
  }

  .developer-card .dev-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.3rem;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  }

  .developer-card .dev-name {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text-primary, #333);
  }

  .developer-card .dev-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .developer-card .stat-item {
    display: flex;
    flex-direction: column;
    background: var(--bg-tertiary, #f8f9fa);
    padding: 0.875rem;
    border-radius: 10px;
    text-align: center;
  }

  .developer-card .stat-value {
    font-size: 1.75rem;
