---
import Layout from '../layouts/Layout.astro';

// Server-side protection: Only super admin can access this page
const superAdminEmail = import.meta.env.PUBLIC_SUPER_ADMIN_EMAIL || '';

// Check if we're on the server (during SSR)
if (Astro.request) {
  // This will be enforced client-side after authentication
  // For now, we render the page and check on client
}
---

<Layout title="Development Analytics">
  <div class="dev-dashboard-header">
    <div>
      <h1>Development Analytics</h1>
      <p>Consolidated view of developer throughput, blocking work, and bug load across your projects.</p>
    </div>
    <div class="dev-header-actions">
      <span id="devProjectCount">0 projects</span>
    </div>
  </div>

  <section class="dev-controls">
    <div class="control-group">
      <label for="devScopeSelect">Vista</label>
      <select id="devScopeSelect" disabled>
        <option value="all">Todos mis proyectos</option>
      </select>
    </div>
    <div class="control-group">
      <label for="devYearSelect">Año</label>
      <select id="devYearSelect" disabled>
        <option value="all">Todos</option>
      </select>
    </div>
    <div class="control-group">
      <label>&nbsp;</label>
      <button id="devReloadButton" class="ghost" disabled>Actualizar datos</button>
    </div>
  </section>

  <section id="devLoadingState" class="dev-loading">Inicializando módulo de analíticas...</section>

  <section id="devContentSection" class="dev-content hidden">
    <div class="dev-tabs">
      <button class="dev-tab active" data-tab="summary">Resumen global</button>
      <button class="dev-tab" data-tab="projects">Por proyecto</button>
    </div>

    <div id="devTabSummary" class="dev-tab-content active">
      <div id="devSummaryCards" class="summary-cards"></div>
      <div id="devDeveloperTableContainer" class="developer-table-container"></div>
    </div>

    <div id="devTabProjects" class="dev-tab-content">
      <div id="devProjectBreakdown" class="project-breakdown"></div>
    </div>
  </section>
</Layout>

<script type="module">
  import { database, ref, get, auth, superAdminEmail as envSuperAdminEmail } from '/firebase-config.js';
  import { encodeEmailForFirebase } from '/js/utils/email-sanitizer.js';
  import { normalizeDeveloperEntry, getDeveloperKey } from '/js/utils/developer-normalizer.js';
const normalizeEmail = (email) => (email || '').toString().trim().toLowerCase();
  const legacyEncodeEmail = (email) => normalizeEmail(email).replace(/[@.#$\[\]\/]/g, '_');

  class DevelopmentAnalytics {
    constructor() {
      this.projects = [];
      this.datasets = [];
      this.metrics = null;
      this.selectedScope = 'all';
      this.selectedYear = new Date().getFullYear().toString();
      this.developerMap = new Map(); // Map of developer ID/email to name
      this.sprintYearMap = new Map(); // Map of sprint ID to year

      this.elements = {
        loading: document.getElementById('devLoadingState'),
        contentSection: document.getElementById('devContentSection'),
        summaryCards: document.getElementById('devSummaryCards'),
        tableContainer: document.getElementById('devDeveloperTableContainer'),
        projectBreakdown: document.getElementById('devProjectBreakdown'),
        scopeSelect: document.getElementById('devScopeSelect'),
        yearSelect: document.getElementById('devYearSelect'),
        reloadButton: document.getElementById('devReloadButton'),
        projectCount: document.getElementById('devProjectCount'),
        tabSummary: document.getElementById('devTabSummary'),
        tabProjects: document.getElementById('devTabProjects')
      };

      this.activeTab = 'summary';

      this.init();
    }

    async init() {
      try {
        this.setLoading('Autenticando usuario...');
        const currentUser = await this.waitForAuth();
        if (!currentUser) {
          this.setError('Inicia sesión para ver las métricas de desarrollo.');
          return;
        }

        this.setLoading('Cargando proyectos disponibles...');
        this.projects = await this.loadAccessibleProjects(currentUser);
        if (!this.projects.length) {
          this.setError('No tienes proyectos asignados. Solicita acceso a un administrador.');
          return;
        }
        this.populateProjectSelect();
        this.populateYearSelect();
        await Promise.all([
          this.loadDeveloperMappings(),
          this.loadSprintMappings()
        ]);
        this.elements.projectCount.textContent = `${this.projects.length} proyecto${this.projects.length === 1 ? '' : 's'}`;

        await this.loadMetrics();
        this.bindEvents();
        // render() is now called inside loadMetrics()
      } catch (error) {
this.setError('No se pudo cargar la vista de desarrollo.');
      }
    }

    async waitForAuth() {
      if (auth.currentUser) {
        return auth.currentUser;
      }

      return new Promise((resolve) => {
        const unsubscribe = auth.onAuthStateChanged((user) => {
          unsubscribe();
          resolve(user);
        });
        setTimeout(() => {
          unsubscribe();
          resolve(null);
        }, 10000);
      });
    }

    async loadAccessibleProjects(user) {
      try {
        const projectsRef = ref(database, '/projects');
        const projectsSnap = await get(projectsRef);
        if (!projectsSnap.exists()) {
          return [];
        }

        const allProjects = Object.entries(projectsSnap.val() || {}).map(([id, project]) => ({
          id,
          name: project.name || id
        }));

        // SuperAdmin always sees all projects
        const isSuperAdmin = envSuperAdminEmail && user.email.toLowerCase() === envSuperAdminEmail.toLowerCase();
        if (isSuperAdmin) {
          return allProjects;
        }

        const userKey = encodeEmailForFirebase(user.email);
        const userProjectsRef = ref(database, `/data/projectsByUser/${userKey}`);
        const userProjectsSnap = await get(userProjectsRef);
        const userProjectData = userProjectsSnap.val();

        if (userProjectData === 'All') {
          return allProjects;
        }

        if (typeof userProjectData === 'string') {
          const allowed = userProjectData.split(',').map((p) => p.trim()).filter(Boolean);
          return allProjects.filter((project) => allowed.includes(project.id) || allowed.includes(project.name));
        }

        return [];
      } catch (error) {
return [];
      }
    }

    bindEvents() {
      if (this.elements.scopeSelect) {
        this.elements.scopeSelect.addEventListener('change', (event) => {
          this.selectedScope = event.target.value || 'all';
          this.render();
        });
      }

      if (this.elements.yearSelect) {
        this.elements.yearSelect.addEventListener('change', (event) => {
          this.selectedYear = event.target.value || 'all';
          this.loadMetrics(true);
        });
      }

      if (this.elements.reloadButton) {
        this.elements.reloadButton.addEventListener('click', () => {
          this.loadMetrics(true);
        });
      }

      // Tab switching
      document.querySelectorAll('.dev-tab').forEach(tab => {
        tab.addEventListener('click', (event) => {
          const tabName = event.target.dataset.tab;
          this.switchTab(tabName);
        });
      });
    }

    switchTab(tabName) {
      this.activeTab = tabName;

      // Update tab buttons
      document.querySelectorAll('.dev-tab').forEach(tab => {
        tab.classList.toggle('active', tab.dataset.tab === tabName);
      });

      // Update tab content
      if (this.elements.tabSummary) {
        this.elements.tabSummary.classList.toggle('active', tabName === 'summary');
      }
      if (this.elements.tabProjects) {
        this.elements.tabProjects.classList.toggle('active', tabName === 'projects');
      }
    }

    populateProjectSelect() {
      const select = this.elements.scopeSelect;
      if (!select) return;

      select.innerHTML = '';
      const optionAll = document.createElement('option');
      optionAll.value = 'all';
      optionAll.textContent = 'Todos mis proyectos';
      select.appendChild(optionAll);

      this.projects.forEach((project) => {
        const option = document.createElement('option');
        option.value = project.id;
        option.textContent = project.name || project.id;
        select.appendChild(option);
      });

      select.disabled = false;
      this.elements.reloadButton.disabled = false;
    }

    populateYearSelect() {
      const select = this.elements.yearSelect;
      if (!select) return;

      select.innerHTML = '';

      // Add "All years" option
      const optionAll = document.createElement('option');
      optionAll.value = 'all';
      optionAll.textContent = 'Todos los años';
      select.appendChild(optionAll);

      // Add years from current year back to 2020
      const currentYear = new Date().getFullYear();
      for (let year = currentYear; year >= 2020; year--) {
        const option = document.createElement('option');
        option.value = year.toString();
        option.textContent = year.toString();
        select.appendChild(option);
      }

      // Set the value directly to ensure it's selected
      select.value = this.selectedYear;
      select.disabled = false;
    }

    async loadDeveloperMappings() {
      // Load developer info from global entities and projects
      try {
        // First, load from global developers (/data/developers) - source of truth
        const entitiesSnap = await get(ref(database, '/data/developers'));
        if (entitiesSnap.exists()) {
          const entities = entitiesSnap.val() || {};
          Object.entries(entities).forEach(([id, dev]) => {
            if (!dev) return;
            const name = dev.name || '';
            const email = (dev.email || '').toLowerCase();

            // Map dev_XXX ID to name
            if (id && name) {
              this.developerMap.set(id.toLowerCase(), name);
            }
            // Map email to name
            if (email && name) {
              this.developerMap.set(email, name);
            }
          });
        }

        // Then, load from each project's developers list
        for (const project of this.projects) {
          const projectSnap = await get(ref(database, `/projects/${project.id}`));
          if (projectSnap.exists()) {
            const projectData = projectSnap.val() || {};
            const developers = projectData.developers || [];

            // Process each developer entry
            (Array.isArray(developers) ? developers : Object.values(developers)).forEach(dev => {
              if (!dev) return;

              const id = dev.id || dev.name || '';
              const name = dev.name || '';
              const email = (dev.email || '').toLowerCase();

              // Map ID to name (don't overwrite if already exists from entities)
              if (id && name && !this.developerMap.has(id.toLowerCase())) {
                this.developerMap.set(id.toLowerCase(), name);
              }
              // Map email to name
              if (email && name && !this.developerMap.has(email)) {
                this.developerMap.set(email, name);
              }
            });
          }
        }
      } catch (error) {
        // Silently ignore errors loading developer mappings
      }
    }

    async loadSprintMappings() {
      // Load sprint data to get year field for each sprint
      try {
        for (const project of this.projects) {
          const sprintsSnap = await get(ref(database, `/cards/${project.id}/SPRINTS_${project.id}`));
          if (sprintsSnap.exists()) {
            const sprints = sprintsSnap.val() || {};
            Object.entries(sprints).forEach(([sprintId, sprint]) => {
              if (!sprint) return;

              // Use sprint's year field directly
              let sprintYear = sprint.year ? parseInt(sprint.year, 10) : null;

              // Fallback to startDate if no year field
              if (!sprintYear && sprint.startDate) {
                sprintYear = new Date(sprint.startDate).getFullYear();
              }

              if (sprintYear) {
                // Map by multiple keys for flexible lookup
                const keysToMap = [
                  sprintId,
                  sprint.cardId,
                  sprint.title,
                  sprint.name,
                  // Also map lowercase versions
                  sprintId?.toLowerCase?.(),
                  sprint.cardId?.toLowerCase?.(),
                  sprint.title?.toLowerCase?.(),
                  sprint.name?.toLowerCase?.()
                ].filter(Boolean);

                keysToMap.forEach(key => {
                  this.sprintYearMap.set(key, sprintYear);
                });
              }
            });
          }
        }
      } catch (error) {
        // Silently ignore errors loading sprint mappings
      }
    }

    async loadMetrics(force = false) {
      try {
        if (!force && this.datasets.length) {
          this.metrics = this.buildMetrics(this.datasets);
          this.setReady();
          this.render();
          return;
        }

        this.setLoading('Calculando métricas de tareas y bugs...');
        this.datasets = await Promise.all(this.projects.map((project) => this.fetchProjectDataset(project)));
        this.metrics = this.buildMetrics(this.datasets);
        this.setReady();
        this.render();
      } catch (error) {
this.setError('Error calculando métricas de desarrollo.');
      }
    }

    async fetchProjectDataset(project) {
      try {
        const [tasksSnap, bugsSnap] = await Promise.all([
          get(ref(database, `/cards/${project.id}/TASKS_${project.id}`)),
          get(ref(database, `/cards/${project.id}/BUGS_${project.id}`))
        ]);

        let tasks = tasksSnap.exists() ? Object.values(tasksSnap.val() || {}) : [];
        let bugs = bugsSnap.exists() ? Object.values(bugsSnap.val() || {}) : [];

        // Filter by year if a specific year is selected
        if (this.selectedYear && this.selectedYear !== 'all') {
          tasks = tasks.filter(task => this.isFromYear(task, this.selectedYear));
          bugs = bugs.filter(bug => this.isFromYear(bug, this.selectedYear));
        }

        return {
          project,
          tasks,
          bugs
        };
      } catch (error) {
return {
          project,
          tasks: [],
          bugs: []
        };
      }
    }

    isFromYear(card, year) {
      const yearInt = parseInt(year, 10);
      const currentYear = new Date().getFullYear();

      // Primary: use task's year field directly
      if (card.year !== undefined && card.year !== null && card.year !== '') {
        return parseInt(card.year, 10) === yearInt;
      }

      // Secondary: use sprint's year field
      if (card.sprint) {
        let sprintYear = this.sprintYearMap.get(card.sprint);
        if (!sprintYear && typeof card.sprint === 'string') {
          sprintYear = this.sprintYearMap.get(card.sprint.toLowerCase());
        }
        if (sprintYear) {
          return sprintYear === yearInt;
        }
      }

      // No year field and no sprint: show in current year
      return yearInt === currentYear;
    }

    buildMetrics(datasets) {
      const globalMap = new Map();
      const projectsMap = new Map();

      datasets.forEach(({ project, tasks, bugs }) => {
        const projectMap = new Map();

        tasks.forEach((task) => {
          const normalized = this.normalizeDeveloper(task.developer);
          if (!normalized) return;

          const projectStats = this.getOrCreateStats(projectMap, normalized, project);
          const globalStats = this.getOrCreateStats(globalMap, normalized, project);

          this.processTask(projectStats, task);
          this.processTask(globalStats, task);
        });

        bugs.forEach((bug) => {
          const normalized = this.normalizeDeveloper(bug.developer || bug.assignee);
          if (!normalized) return;

          const projectStats = this.getOrCreateStats(projectMap, normalized, project);
          const globalStats = this.getOrCreateStats(globalMap, normalized, project);

          this.processBug(projectStats, bug);
          this.processBug(globalStats, bug);
        });

        projectsMap.set(project.id, this.generateMetricsPayload(projectMap, project));
      });

      return {
        global: this.generateMetricsPayload(globalMap),
        projects: projectsMap
      };
    }

    normalizeDeveloper(rawDeveloper) {
      const normalized = normalizeDeveloperEntry(rawDeveloper || '');
      const needsFallbackUnassigned = !normalized.isUnassigned && !normalized.name && !normalized.email;
      const isUnassigned = normalized.isUnassigned || needsFallbackUnassigned;
      const developerKey = isUnassigned
        ? 'developer:unassigned'
        : (getDeveloperKey(rawDeveloper || normalized.name) || `developer:${(normalized.name || '').toLowerCase()}`);

      // Try to resolve name from developerMap using various keys
      let resolvedName = null;
      if (!isUnassigned) {
        const rawLower = (rawDeveloper || '').toString().toLowerCase();
        const emailLower = (normalized.email || '').toLowerCase();

        // Try raw value (could be ID like "dev_abc")
        if (this.developerMap.has(rawLower)) {
          resolvedName = this.developerMap.get(rawLower);
        }
        // Try email
        else if (emailLower && this.developerMap.has(emailLower)) {
          resolvedName = this.developerMap.get(emailLower);
        }
        // Try normalized name
        else if (normalized.name && this.developerMap.has(normalized.name.toLowerCase())) {
          resolvedName = this.developerMap.get(normalized.name.toLowerCase());
        }
      }

      const developerName = isUnassigned
        ? 'Sin asignar'
        : (resolvedName || normalized.name || this.formatNameFromEmail(normalized.email) || 'Sin asignar');

      const developerEmail = normalized.isUnassigned ? '' : (normalized.email || normalized.sourceEmail || '');

      return {
        key: developerKey,
        name: developerName,
        email: developerEmail
      };
    }

    getOrCreateStats(map, developerInfo, project) {
      if (!map.has(developerInfo.key)) {
        map.set(developerInfo.key, {
          developerKey: developerInfo.key,
          developer: developerInfo.name,
          email: developerInfo.email,
          projectNames: new Set(),
          totalTasks: 0,
          completedTasks: 0,
          inProgressTasks: 0,
          blockedTasks: 0,
          devPointsDone: 0,
          totalDevPoints: 0,
          bugsTotal: 0,
          bugsResolved: 0,
          bugsOpen: 0
        });
      }

      const stats = map.get(developerInfo.key);
      if (project) {
        stats.projectNames.add(project.name || project.id);
      }
      return stats;
    }

    processTask(stats, task) {
      stats.totalTasks += 1;
      const status = (task.status || '').toLowerCase();
      const devPoints = Number(task.devPoints) || 0;

      if (status.includes('in progress')) {
        stats.inProgressTasks += 1;
      }

      if (this.isTaskBlocked(task)) {
        stats.blockedTasks += 1;
      }

      const isDone = status.includes('done') || status.includes('completed') || status.includes('ready for qa');
      if (isDone) {
        stats.completedTasks += 1;
        stats.devPointsDone += devPoints;
      }

      stats.totalDevPoints += devPoints;
    }

    processBug(stats, bug) {
      stats.bugsTotal += 1;
      const status = (bug.status || '').toLowerCase();
      const resolved = status.includes('done') || status.includes('fixed') || status.includes('closed') || status.includes('resolved');
      if (resolved) {
        stats.bugsResolved += 1;
      } else {
        stats.bugsOpen += 1;
      }
    }

    generateMetricsPayload(map, project = null) {
      const developers = Array.from(map.values()).map((stats) => ({
        ...stats,
        projectList: Array.from(stats.projectNames)
      })).sort((a, b) => b.completedTasks - a.completedTasks || b.totalTasks - a.totalTasks);

      const totals = developers.reduce((acc, row) => {
        acc.totalTasks += row.totalTasks;
        acc.completedTasks += row.completedTasks;
        acc.inProgressTasks += row.inProgressTasks;
        acc.blockedTasks += row.blockedTasks;
        acc.devPointsDone += row.devPointsDone;
        acc.totalDevPoints += row.totalDevPoints;
        acc.bugsTotal += row.bugsTotal;
        acc.bugsResolved += row.bugsResolved;
        acc.bugsOpen += row.bugsOpen;
        return acc;
      }, {
        totalTasks: 0,
        completedTasks: 0,
        inProgressTasks: 0,
        blockedTasks: 0,
        devPointsDone: 0,
        totalDevPoints: 0,
        bugsTotal: 0,
        bugsResolved: 0,
        bugsOpen: 0
      });

      return {
        projectId: project?.id || null,
        projectName: project?.name || null,
        developers,
        totals
      };
    }

    render() {
      if (!this.metrics) {
        this.setError('No hay métricas disponibles.');
        return;
      }

      const scopeData = this.selectedScope === 'all'
        ? this.metrics.global
        : this.metrics.projects.get(this.selectedScope);

      if (!scopeData) {
        this.setError('No existen datos para el proyecto seleccionado.');
        return;
      }

      this.renderSummary(scopeData);
      this.renderDeveloperTable(scopeData);
      this.renderProjectBreakdown();
    }

    renderSummary(scopeData) {
      const totals = scopeData.totals || {};
      const cards = [
        {
          label: 'Tareas totales',
          value: totals.totalTasks,
          detail: `${this.formatNumber(totals.completedTasks)} completadas`
        },
        {
          label: 'En progreso',
          value: totals.inProgressTasks,
          detail: `${this.formatNumber(totals.blockedTasks)} bloqueadas`
        },
        {
          label: 'Dev points',
          value: totals.devPointsDone,
          detail: `${this.formatNumber(totals.totalDevPoints)} estimados`
        },
        {
          label: 'Bugs',
          value: totals.bugsOpen,
          detail: `${this.formatNumber(totals.bugsResolved)} resueltos`
        }
      ];

      this.elements.summaryCards.innerHTML = cards.map((card) => `
        <article class="summary-card">
          <p class="card-label">${card.label}</p>
          <p class="card-value">${this.formatNumber(card.value)}</p>
          <p class="card-detail">${card.detail}</p>
        </article>
      `).join('');
    }

    renderDeveloperTable(scopeData) {
      const rows = scopeData.developers || [];
      if (!rows.length) {
        this.elements.tableContainer.innerHTML = '<div class="dev-empty">No hay developers con métricas registradas.</div>';
        return;
      }

      const tableRows = rows.map((row) => {
        const projectsLabel = row.projectList.length <= 2
          ? row.projectList.join(', ')
          : `${row.projectList.length} proyectos`;
        return `
          <tr>
            <td>${row.developer}</td>
            <td>${projectsLabel || '—'}</td>
            <td>${this.formatNumber(row.totalTasks)}</td>
            <td>${this.formatNumber(row.completedTasks)}</td>
            <td>${this.formatNumber(row.inProgressTasks)}</td>
            <td>${this.formatNumber(row.blockedTasks)}</td>
            <td>${this.formatNumber(row.devPointsDone)}</td>
            <td>${this.formatNumber(row.bugsOpen)} / ${this.formatNumber(row.bugsTotal)}</td>
          </tr>
        `;
      }).join('');

      const scopeLabel = this.selectedScope === 'all' ? 'Todos mis proyectos' : scopeData.projectName;
      const highlightRow = rows[0];

      this.elements.tableContainer.innerHTML = `
        <div class="developer-table-header">
          <div>
            <p class="eyebrow">Resumen · ${scopeLabel}</p>
            <h2>Performance de developers</h2>
            <p class="subtitle">Tareas, bloqueos y carga de bugs por persona.</p>
          </div>
          ${highlightRow ? `
            <div class="dev-highlight-card">
              <p class="highlight-label">Top performer</p>
              <p class="highlight-name">${highlightRow.developer}</p>
              <p class="highlight-metrics">${this.formatNumber(highlightRow.completedTasks)} tareas done · ${this.formatNumber(highlightRow.bugsOpen)} bugs abiertos</p>
            </div>` : ''}
        </div>
        <div class="developer-table-wrapper">
          <table class="developer-summary-table">
            <thead>
              <tr>
                <th>Developer</th>
                <th>Proyectos</th>
                <th>Asignadas</th>
                <th>Completadas</th>
                <th>En progreso</th>
                <th>Bloqueadas</th>
                <th>Dev points (Done)</th>
                <th>Bugs (Abiertos/Totales)</th>
              </tr>
            </thead>
            <tbody>
              ${tableRows}
            </tbody>
          </table>
        </div>
      `;
    }

    renderProjectBreakdown() {
      if (!this.metrics || !this.metrics.projects || !this.metrics.projects.size) {
        this.elements.projectBreakdown.innerHTML = '<div class="dev-empty">No hay datos de proyectos disponibles.</div>';
        return;
      }

      const cards = Array.from(this.metrics.projects.values()).map((projectMetric) => {
        const totals = projectMetric.totals || {};
        const topDevelopers = (projectMetric.developers || []).slice(0, 3);
        const topList = topDevelopers.length
          ? topDevelopers.map((dev) => `
            <li>
              <span class="dev-name">${dev.developer}</span>
              <span class="dev-metric"><strong>${this.formatNumber(dev.completedTasks)}</strong> done</span>
              <span class="dev-metric"><strong>${this.formatNumber(dev.bugsOpen)}</strong> bugs abiertos</span>
            </li>
          `).join('')
          : '<li class="dev-empty-item">Sin developers asignados</li>';

        const completionRate = totals.totalTasks ? (totals.completedTasks / Math.max(totals.totalTasks, 1)) * 100 : 0;
        const bugRatio = totals.bugsTotal ? (totals.bugsOpen / Math.max(totals.bugsTotal, 1)) * 100 : 0;
        const stats = [
          { label: 'Completadas', value: totals.completedTasks },
          { label: 'En progreso', value: totals.inProgressTasks },
          { label: 'Bloqueadas', value: totals.blockedTasks },
          { label: 'Dev points (done)', value: totals.devPointsDone }
        ];

        return `
          <article class="project-card">
            <header>
              <div>
                <h3>${projectMetric.projectName || projectMetric.projectId}</h3>
                <p>${this.formatNumber(totals.totalTasks)} tareas · ${this.formatNumber(totals.bugsOpen)} bugs abiertos</p>
              </div>
              <span class="project-chip">${projectMetric.projectName?.slice(0, 3).toUpperCase() || 'PRJ'}</span>
            </header>
            <div class="project-stat-grid">
              ${stats.map((stat) => `
                <div class="project-stat">
                  <span class="stat-label">${stat.label}</span>
                  <strong class="stat-value">${this.formatNumber(stat.value)}</strong>
                </div>
              `).join('')}
            </div>
            <div class="project-progress">
              <div class="progress-block">
                <div class="progress-label">Tareas completadas</div>
                <div class="progress-track">
                  <div class="progress-fill completed" style="width:${completionRate}%"></div>
                </div>
                <div class="progress-values">${this.formatNumber(totals.completedTasks)} / ${this.formatNumber(totals.totalTasks)}</div>
              </div>
              <div class="progress-block">
                <div class="progress-label">Bugs abiertos</div>
                <div class="progress-track">
                  <div class="progress-fill bugs" style="width:${bugRatio}%"></div>
                </div>
                <div class="progress-values">${this.formatNumber(totals.bugsOpen)} / ${this.formatNumber(totals.bugsTotal)}</div>
              </div>
            </div>
            <div class="top-devs">
              <p>Top developers</p>
              <ul>${topList}</ul>
            </div>
          </article>
        `;
      }).join('');

      this.elements.projectBreakdown.innerHTML = `
        <h2>Detalle por proyecto</h2>
        <div class="project-card-grid">
          ${cards}
        </div>
      `;
    }

    setLoading(message) {
      this.elements.loading.textContent = message;
      this.elements.loading.classList.remove('hidden');
      this.elements.contentSection.classList.add('hidden');
    }

    setReady() {
      this.elements.loading.classList.add('hidden');
      this.elements.contentSection.classList.remove('hidden');
    }

    setError(message) {
      this.elements.loading.textContent = message;
      this.elements.loading.classList.remove('hidden');
      this.elements.contentSection.classList.add('hidden');
    }

    formatNumber(value) {
      if (value === null || value === undefined) {
        return '0';
      }
      return Number(value).toLocaleString('es-ES');
    }

    formatNameFromEmail(email) {
      if (!email || typeof email !== 'string') {
        return email || '';
      }
      const localPart = email.split('@')[0] || email;
      let cleaned = localPart.replace(/#ext#/gi, '');
      cleaned = cleaned.replace(/[._-]+/g, ' ');
      cleaned = cleaned.replace(/\s+/g, ' ').trim();
      if (!cleaned) {
        return email;
      }
      return cleaned.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
    }

    isTaskBlocked(task) {
      if (!task) return false;
      const status = (task.status || '').toLowerCase();
      return status.includes('block') || Boolean(task.blockedByBusiness) || Boolean(task.blockedByDevelopment);
    }
  }

  // Security check: redirect if not super admin
  async function checkSuperAdminAccess() {
    try {
      const currentUserEmail = document.body.dataset.userEmail;
      const normalizedUserEmail = normalizeEmail(currentUserEmail);

      if (!normalizedUserEmail) {
window.location.href = '/';
        return false;
      }

      let hasAccess = false;

      // First check: Environment variable (fastest)
      const normalizedSuperAdmin = normalizeEmail(envSuperAdminEmail);
      if (normalizedSuperAdmin && normalizedUserEmail === normalizedSuperAdmin) {
        hasAccess = true;
}

      // NOTE: /data/superAdminEmails is DEPRECATED - SuperAdmin is only from .env
if (!hasAccess) {
window.location.href = '/dashboard/';
        return false;
      }

      return true;
    } catch (error) {
window.location.href = '/dashboard/';
      return false;
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    // Wait for user authentication using auth.currentUser or onAuthStateChanged
    const waitForUser = () => new Promise((resolve) => {
      if (auth.currentUser) {
        document.body.dataset.userEmail = auth.currentUser.email;
        resolve(auth.currentUser);
      } else {
        const unsubscribe = auth.onAuthStateChanged((user) => {
          unsubscribe();
          if (user) {
            document.body.dataset.userEmail = user.email;
          }
          resolve(user);
        });
        // Timeout after 10 seconds
        setTimeout(() => {
          unsubscribe();
          resolve(null);
        }, 10000);
      }
    });

    const user = await waitForUser();
    if (!user) {
      window.location.href = '/';
      return;
    }

    const isAllowed = await checkSuperAdminAccess();

    // Only initialize if access is allowed
    if (isAllowed) {
      new DevelopmentAnalytics();
    }
  });
</script>

