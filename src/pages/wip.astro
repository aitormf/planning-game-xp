---
import Layout from '../layouts/Layout.astro';
import BacklogStyles from '../components/BacklogStyles.astro';
---

<Layout title="Work In Progress">
  <BacklogStyles />
  <section class="wip-container">
    <h1>Work In Progress</h1>
    <p class="wip-subtitle">Un developer solo puede tener 1 tarea In Progress en todos los proyectos. Duración en jornadas laborables (excluye fines de semana y festivos).</p>
    <div class="wip-tabs">
      <button class="tab-button active" data-tab="wip">WIP actual</button>
      <button class="tab-button" data-tab="backlog">Backlog por developer</button>
    </div>
    <div id="tab-wip" class="tab-panel">
      <div id="wipContent" class="wip-list">Cargando...</div>
    </div>
    <div id="tab-backlog" class="tab-panel hidden">
      <div class="backlog-header">
        <button id="refreshBacklogBtn" class="refresh-backlog-btn" title="Actualizar lista de backlogs">🔄 Actualizar</button>
      </div>
      <div id="backlogContent" class="backlog-list">Cargando...</div>
    </div>
  </section>
</Layout>

<script type="module">
  import { database, ref, onValue, get, set } from '/firebase-config.js';
  import { isCurrentUserSuperAdmin, normalizeEmail as normalizeEmailSafe } from '/js/utils/super-admin-check.js';
  import { getWorkdaysDuration } from '/js/utils/workday-utils.js';
  import { entityDirectoryService } from '/js/services/entity-directory-service.js';
  import { developerBacklogService } from '/js/services/developer-backlog-service.js';
  import { FirebaseService } from '/js/services/firebase-service.js';
  import { CardRealtimeService } from '/js/services/card-realtime-service.js';
  import { URLStateManager } from '/js/utils/url-utils.js';
  import '/js/core/app-initializer.js';
  import 'https://cdn.jsdelivr.net/npm/@manufosela/loading-layer@2.0.1/+esm';

  // DOM elements
  const wipContent = document.getElementById('wipContent');
  const backlogContent = document.getElementById('backlogContent');
  const tabButtons = Array.from(document.querySelectorAll('.tab-button'));
  const tabWip = document.getElementById('tab-wip');
  const tabBacklog = document.getElementById('tab-backlog');
  let loadingLayer = null;

  // State
  let developerDirectory = new Map(); // devId (dev_XXX) -> { id, email, name, active }
  let wipEntries = new Map();         // devId -> { taskId, taskTitle, projectId, startedAt, developer, developerName }
  let backlogEntries = new Map();     // devId -> { order: [], items: {} }
  let currentUserEmail = '';
  let currentUserId = '';
  let isSuperAdmin = false;
  let scanning = false;
  let activeTab = 'wip';
  let activeBacklogDev = null;
  let hasTriedToSelectCurrentUser = false; // Track if we've tried to auto-select current user
  let draggedItem = null;
  const openState = new Map();
  const userEmail = document.body.dataset.userEmail || '';
  let modalDevContext = '';
  const statusCache = new Map();

  // Developers to exclude from WIP and Backlog views (tests, placeholders, bots)
  const excludedDevNames = [
    'tests',
    'no developer assigned',
    'becaria',
    'test',
    'bot'
  ];
  let isRemovingFromBacklog = false; // Flag to prevent render during remove operation

  const normalizeSortKey = (value) => (value || '').toString().trim().toLowerCase();

  function sortDevelopersForBacklog(entries) {
    return entries.sort((a, b) => {
      if (a.id === currentUserId) return -1;
      if (b.id === currentUserId) return 1;
      const labelA = normalizeSortKey(a.info?.name || a.info?.email || a.id);
      const labelB = normalizeSortKey(b.info?.name || b.info?.email || b.id);
      return labelA.localeCompare(labelB);
    });
  }

  // Helpers
  function setStatus(message, type = 'info') {
    if (!message) return;
    // Use toast notifications instead of inline status
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message, type: type === 'ok' ? 'success' : type } }
    }));
  }

  function updateTabs(tab, updateUrl = true) {
    if (tab) activeTab = tab;
    tabButtons.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.tab === activeTab);
    });
    if (activeTab === 'backlog') {
      tabBacklog.classList.remove('hidden');
      tabWip.classList.add('hidden');
      // No auto-sync - user can click "Sincronizar Backlogs" button manually
    } else {
      tabBacklog.classList.add('hidden');
      tabWip.classList.remove('hidden');
    }

    // Update URL with tab state (use pushState for navigation history)
    if (updateUrl) {
      URLStateManager.updateState({ tab: activeTab });
    }
  }

  // Restore tab from URL on page load
  function restoreTabFromUrl() {
    const urlState = URLStateManager.getState();
    if (urlState.tab && (urlState.tab === 'wip' || urlState.tab === 'backlog')) {
      updateTabs(urlState.tab, false); // Don't update URL again
    }
  }

  // Listen for browser back/forward navigation
  URLStateManager.onPopState((state) => {
    if (state.tab && (state.tab === 'wip' || state.tab === 'backlog')) {
      updateTabs(state.tab, false);
    }
  });

  function formatTime(iso) {
    if (!iso) return '-';
    return new Date(iso).toLocaleString([], { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' });
  }

  function formatNameFromEmail(email) {
    if (!email || typeof email !== 'string') return '';
    const localPart = email.split('@')[0] || email;
    return localPart.replace(/[._-]+/g, ' ').replace(/\s+/g, ' ').trim()
      .split(' ').filter(Boolean)
      .map(part => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ');
  }

  function isExcludedDeveloper(devId, devName) {
    if (!devId && !devName) return true;
    const idLower = (devId || '').toLowerCase().trim();
    const nameLower = (devName || '').toLowerCase().trim();
    return excludedDevNames.some(excluded =>
      idLower.includes(excluded) || nameLower.includes(excluded)
    );
  }

  function canEditRow(devId) {
    if (!currentUserEmail) return false;
    if (isSuperAdmin) return true;
    if (!devId) return false;
    // Comparar por ID o por email
    if (currentUserId && devId === currentUserId) return true;
    const devInfo = developerDirectory.get(devId);
    return devInfo && normalizeEmailSafe(devInfo.email) === currentUserEmail;
  }

  const canEditBacklog = (devId) => canEditRow(devId);

  // Render
  function renderWip() {
    const rows = [];
    const processedIds = new Set();

    // Primero, iterar sobre todos los developers del directorio
    for (const [devId, devInfo] of developerDirectory.entries()) {
      if (!devInfo.active) continue; // Solo mostrar activos
      if (isExcludedDeveloper(devId, devInfo.name)) continue; // Excluir tests/bots
      processedIds.add(devId);
      const wipEntry = wipEntries.get(devId);
      const isActive = wipEntry && wipEntry.taskId && wipEntry.taskId !== 'idle';

      rows.push({
        key: devId,
        developerName: wipEntry?.developerName || devInfo.name || formatNameFromEmail(devInfo.email) || devId,
        developerEmail: devInfo.email || '',
        projectId: isActive ? wipEntry.projectId : '-',
        taskId: isActive ? wipEntry.taskId : '',
        taskLabel: isActive ? (wipEntry.taskTitle || wipEntry.taskId) : 'Sin tarea',
        startedAt: isActive ? wipEntry.startedAt : null,
        duration: isActive ? getWorkdaysDuration(wipEntry.startedAt) : '-',
        statusLabel: isActive ? 'En progreso' : 'Disponible',
        isActive
      });
    }

    // Luego, añadir developers que están en /wip pero no en el directorio
    for (const [devId, wipEntry] of wipEntries.entries()) {
      if (processedIds.has(devId)) continue;
      const devName = wipEntry.developerName || formatNameFromEmail(wipEntry.developer) || devId;
      if (isExcludedDeveloper(devId, devName)) continue; // Excluir tests/bots
      const isActive = wipEntry && wipEntry.taskId && wipEntry.taskId !== 'idle';
      if (!isActive) continue; // Solo mostrar si tienen tarea activa

      rows.push({
        key: devId,
        developerName: wipEntry.developerName || formatNameFromEmail(wipEntry.developer) || devId,
        developerEmail: wipEntry.developer || '',
        projectId: wipEntry.projectId || '-',
        taskId: wipEntry.taskId || '',
        taskLabel: wipEntry.taskTitle || wipEntry.taskId || 'Tarea',
        startedAt: wipEntry.startedAt || null,
        duration: getWorkdaysDuration(wipEntry.startedAt),
        statusLabel: 'En progreso',
        isActive: true
      });
    }

    // Ordenar por nombre
    rows.sort((a, b) => (a.developerName || '').localeCompare(b.developerName || ''));

    const activeCount = rows.filter(r => r.isActive).length;

    const table = `
      <div class="wip-card">
        <div class="summary-chips">
          <span class="summary-chip">Total: ${rows.length}</span>
          <span class="summary-chip chip-active">En progreso: ${activeCount}</span>
          <span class="summary-chip chip-idle">Disponibles: ${rows.length - activeCount}</span>
        </div>
        <table class="wip-table" role="table">
          <thead>
            <tr>
              <th scope="col">Developer</th>
              <th scope="col">Estado</th>
              <th scope="col">Proyecto</th>
              <th scope="col">Tarea</th>
              <th scope="col">Inicio</th>
              <th scope="col" title="Jornadas laborables (excluye fines de semana y festivos)">Jornadas</th>
              <th scope="col" class="actions-col">Acciones</th>
            </tr>
          </thead>
          <tbody>
            ${rows.map(row => `
              <tr class="${row.isActive ? 'row-active' : 'row-idle'}">
                <td class="dev">${row.developerName}</td>
                <td><span class="pill ${row.isActive ? 'pill-active' : 'pill-idle'}">${row.statusLabel}</span></td>
                <td><span class="pill">${row.projectId}</span></td>
                <td class="task">${row.taskLabel}</td>
                <td>${row.startedAt ? formatTime(row.startedAt) : '-'}</td>
                <td class="duration">${row.duration}</td>
                <td class="actions">
                  ${row.isActive && canEditRow(row.key) ? `
                    <button class="btn ghost" data-action="tovalidate" data-key="${row.key}" data-task="${row.taskId}" data-project="${row.projectId}">To Validate</button>
                    <button class="btn ghost danger" data-action="unassign" data-key="${row.key}" data-task="${row.taskId}" data-project="${row.projectId}">Desasignar</button>
                  ` : '<span class="muted">-</span>'}
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;

    const scanSection = `
      <div class="wip-card wip-scan">
        <div class="wip-card__header">
          <div>
            <div class="eyebrow">Sincronizar WIP</div>
            <p style="margin:0;color:var(--text-muted, #6b7280)">Escanea todas las tareas In Progress de todos los proyectos y actualiza /wip.</p>
          </div>
          <button id="scanBtn" class="btn" ${scanning ? 'disabled' : ''}>${scanning ? 'Escaneando...' : 'Escanear tareas'}</button>
        </div>
      </div>
    `;

    wipContent.innerHTML = table + scanSection;
    bindActions();
  }

  function renderBacklog() {
    const processed = new Set();

    const makeList = (devId, devInfo) => {
      const entry = backlogEntries.get(devId) || { order: [], items: {} };
      const order = Array.isArray(entry.order) ? entry.order : [];
      const items = entry.items || {};
      const orderedItems = [];
      const seen = new Set();

      for (const key of order) {
        if (items[key]) {
          orderedItems.push({ key, ...items[key] });
          seen.add(key);
        }
      }

      for (const [key, value] of Object.entries(items)) {
        if (!seen.has(key)) {
          orderedItems.push({ key, ...value });
        }
      }

      const activeWip = wipEntries.get(devId);
      const seenCardIds = new Set();
      const filteredItems = orderedItems.filter(item => {
        if (!item) return false;
        if (activeWip && activeWip.taskId && (item.cardId === activeWip.taskId || item.cardKey?.endsWith(`|${activeWip.taskId}`))) {
          return false;
        }
        const status = (item.status || '').toLowerCase();
        if (status === 'in progress') return false;
        // Dedupe by cardId to avoid showing duplicates with different cardKeys
        const cardId = item.cardId || item.cardKey;
        if (seenCardIds.has(cardId)) return false;
        seenCardIds.add(cardId);
        return true;
      });

      const list = filteredItems.length ? filteredItems.map((item, idx) => {
        const cardType = item.cardType || '';
        const section = cardType.includes('proposal') ? 'proposals' : (cardType.includes('bug') ? 'bugs' : 'tasks');
        const cardLink = '#';
        return `
          <div class="backlog-row" draggable="${canEditBacklog(devId)}" data-dev="${devId}" data-key="${item.cardKey}">
            <div class="drag-cell" title="Arrastrar para reordenar">☰</div>
            <div class="cell cell-title">${item.title || item.cardId || item.cardKey}</div>
            <div class="cell">${item.projectId || '-'}</div>
            <div class="cell">${(item.cardType || '').replace('-card', '') || '-'}</div>
            <div class="cell"><span class="pill pill-${(item.status || 'pending').toLowerCase().replace(/\s+/g, '-')}" title="Estado">${item.status || 'Pending'}</span></div>
            <div class="cell cell-action">
              <button class="btn-icon btn-view" data-project="${item.projectId || ''}" data-cardid="${item.cardId || ''}" data-cardtype="${item.cardType || ''}" data-section="${section}" data-key="${item.cardKey}" data-firebasekey="${item.firebaseKey || item.firebaseId || ''}" data-dev="${devId}" title="Editar tarea">✏️</button>
              ${canEditBacklog(devId) ? `<button class="btn-icon btn-remove" data-remove="${item.cardKey}" data-dev="${devId}" data-cardid="${item.cardId || ''}" data-title="${(item.title || '').replace(/"/g, '&quot;')}" title="Desasignar developer">✕</button>` : ''}
            </div>
          </div>
        `;
      }).join('') : '<div class="backlog-empty">Sin elementos en backlog</div>';

      const wipLabel = activeWip?.taskTitle ? `WIP: ${activeWip.taskTitle}` : 'Sin WIP';
      const wipBadge = activeWip?.taskTitle ? `<span class="pill pill-active">${wipLabel}</span>` : `<span class="pill pill-idle">${wipLabel}</span>`;

      return {
        devId,
        header: `
          <div class="backlog-card__header">
            <div class="summary-left">
              <div class="summary-name">${devInfo.name || formatNameFromEmail(devInfo.email) || devId}</div>
              <div class="summary-email">${devInfo.email || ''}</div>
            </div>
            <div class="summary-right">
              ${wipBadge}
              <span class="pill pill-light">Pendientes: ${filteredItems.length}</span>
            </div>
          </div>`,
        table: `
          <div class="backlog-table-wrapper">
            <div class="backlog-table-head">
              <div class="head-cell" style="width:32px;"></div>
              <div class="head-cell">Título</div>
              <div class="head-cell">Proyecto</div>
              <div class="head-cell">Tipo</div>
              <div class="head-cell">Estado</div>
              <div class="head-cell" style="width:110px;">Acción</div>
            </div>
            <div class="backlog-rows" data-dev="${devId}">
              ${list}
            </div>
          </div>
        `
      };
    };

    const invalidDevNames = ['', 'null', 'undefined', 'no developer', 'unassigned', 'no developer assigned', 'sin asignar', 'none'];

    // Build list ONLY from developers that have actual tasks (backlog items or active WIP)
    const devsWithTasks = new Set();

    // Add developers with backlog items
    for (const [devId, backlog] of backlogEntries.entries()) {
      if (backlog && backlog.items && Object.keys(backlog.items).length > 0) {
        devsWithTasks.add(devId);
      }
    }

    // Add developers with active WIP
    for (const [devId, wipEntry] of wipEntries.entries()) {
      if (wipEntry && wipEntry.taskId && wipEntry.taskId !== 'idle' && wipEntry.taskId.trim() !== '') {
        devsWithTasks.add(devId);
      }
    }

    // Now build the list only with developers that have tasks
    const devEntries = sortDevelopersForBacklog(
      Array.from(devsWithTasks)
        .filter(devId => {
          if (!devId || !devId.trim()) return false;
          const devIdLower = devId.toLowerCase().trim();
          if (invalidDevNames.includes(devIdLower)) return false;
          // Also check developer name from directory
          const dirInfo = developerDirectory.get(devId);
          const devName = dirInfo?.name || '';
          if (dirInfo) {
            const nameLower = (dirInfo.name || '').toLowerCase().trim();
            if (invalidDevNames.includes(nameLower)) return false;
          }
          // Exclude test developers/bots
          if (isExcludedDeveloper(devId, devName)) return false;
          return true;
        })
        .map(devId => {
          // Get info from directory if available, otherwise create basic info
          const dirInfo = developerDirectory.get(devId);
          const backlogEntry = backlogEntries.get(devId);
          const info = dirInfo || {
            id: devId,
            email: backlogEntry?.email || devId,
            name: formatNameFromEmail(backlogEntry?.email || devId),
            active: true
          };
          return { id: devId, info };
        })
    );

    const backlogLists = [];

    devEntries.forEach(({ id, info }) => {
      backlogLists.push({ id, info, content: makeList(id, info) });
    });

    if (backlogLists.length === 0) {
      backlogContent.innerHTML = '<div class="backlog-empty">Sin developers con backlog.</div>';
      return;
    }

    // Seleccionar dev activo (primero el usuario actual)
    const currentUserInList = backlogLists.find(d => d.id === currentUserId);
    const activeDevStillValid = activeBacklogDev && backlogLists.find(d => d.id === activeBacklogDev);

    // Si no hay dev activo válido, seleccionar uno
    if (!activeDevStillValid) {
      activeBacklogDev = currentUserInList ? currentUserInList.id : backlogLists[0].id;
      if (currentUserInList) hasTriedToSelectCurrentUser = true;
    }
    // Si el usuario actual está en la lista y aún no lo hemos seleccionado automáticamente
    else if (currentUserInList && !hasTriedToSelectCurrentUser) {
      activeBacklogDev = currentUserId;
      hasTriedToSelectCurrentUser = true;
    }

    const tabs = backlogLists.map(({ id, info }) => `
      <button class="dev-tab ${id === activeBacklogDev ? 'active' : ''}" data-dev="${id}">
        ${info.name || formatNameFromEmail(info.email) || id}
      </button>
    `).join('');

    const activeContent = backlogLists.find(d => d.id === activeBacklogDev);
    const body = activeContent ? `${activeContent.content.header}${activeContent.content.table}` : '';

    const syncBacklogBtn = isSuperAdmin ? `
      <div class="backlog-sync-section" style="margin-bottom:1rem;padding:0.75rem;background:var(--bg-tertiary, #f3f4f6);border-radius:8px;display:flex;align-items:center;justify-content:space-between;">
        <span style="color:var(--text-muted, #6b7280);font-size:0.875rem;">Sincronizar backlogs desde tareas "To Do" asignadas</span>
        <button id="syncBacklogBtn" class="btn" ${scanning ? 'disabled' : ''}>${scanning ? 'Sincronizando...' : 'Sincronizar Backlogs'}</button>
      </div>
    ` : '';

    backlogContent.innerHTML = `
      ${syncBacklogBtn}
      <div class="dev-tabs-row" style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
        <div class="dev-tabs" style="flex:1;">${tabs}</div>
      </div>
      <div class="backlog-card" data-dev="${activeBacklogDev}">
        ${body}
      </div>
    `;

    backlogContent.querySelectorAll('.dev-tab').forEach(btn => {
      btn.onclick = () => {
        activeBacklogDev = btn.dataset.dev;
        renderBacklog();
      };
    });

    bindBacklogActions();
  }

  function render() {
    renderWip();
    renderBacklog();
    updateTabs();
  }

  function bindActions() {
    wipContent.querySelectorAll('button[data-action]').forEach(btn => {
      btn.onclick = async () => {
        const { action, key, task, project } = btn.dataset;
        if (!canEditRow(key)) return;

        setStatus('Procesando...', 'info');
        try {
          await handleAction(action, key, task, project);
          setStatus('Actualizado correctamente.', 'success');
        } catch (error) {
          setStatus('Error: ' + error.message, 'error');
        }
      };
    });

    const scanBtn = document.getElementById('scanBtn');
    if (scanBtn) {
      scanBtn.onclick = () => scanAllTasks();
    }
  }

  function bindBacklogActions() {
    backlogContent.querySelectorAll('button[data-remove]').forEach(btn => {
      btn.onclick = async () => {
        const devId = btn.dataset.dev;
        const cardKey = btn.dataset.remove;
        const cardId = btn.dataset.cardid || '';
        if (!canEditBacklog(devId)) return;

        // Block renders during the operation to prevent race conditions
        isRemovingFromBacklog = true;

        try {
          // Parse cardKey: format is "projectId|cardType|firebaseKey"
          const parts = cardKey.split('|');
          if (parts.length >= 3) {
            const [projectId, cardType, firebaseKey] = parts;
            const section = cardType.includes('proposal') ? 'PROPOSALS' : (cardType.includes('bug') ? 'BUGS' : 'TASKS');
            const cardPath = `/cards/${projectId}/${section}_${projectId}/${firebaseKey}`;
            const cardSnap = await get(ref(database, cardPath));
            if (cardSnap.exists()) {
              const card = cardSnap.val();
              const devInfo = developerDirectory.get(devId) || entityDirectoryService.getDeveloper(devId);
              const devName = devInfo?.name || devInfo?.email || devId;
              card.developer = '';
              card.developerName = '';
              await set(ref(database, cardPath), card);
              const itemLabel = cardType.includes('bug') ? 'bug' : 'tarea';
              setStatus(`Desasignado ${devName} de ${itemLabel} ${card.cardId || cardId}`, 'success');
            } else {
              setStatus(`Elemento eliminado del backlog (ya no existe en el proyecto)`, 'info');
            }
          }
          await developerBacklogService.removeItem(devId, cardKey);
        } catch (error) {
          setStatus('Error: ' + error.message, 'error');
        } finally {
          isRemovingFromBacklog = false;
          render();
        }
      };
    });

    backlogContent.querySelectorAll('.backlog-items, .backlog-rows').forEach(list => {
      const devId = list.dataset.dev;
      if (!canEditBacklog(devId)) return;
      list.querySelectorAll('.backlog-item, .backlog-row').forEach(item => {
        item.addEventListener('dragstart', handleBacklogDragStart);
        item.addEventListener('dragend', handleBacklogDragEnd);
      });
      list.addEventListener('dragover', handleBacklogDragOver);
      list.addEventListener('drop', handleBacklogDrop);
      list.addEventListener('dragenter', (e) => e.preventDefault());
    });

    backlogContent.querySelectorAll('.backlog-card').forEach(details => {
      details.addEventListener('toggle', () => {
        openState.set(details.dataset.dev, details.open);
      });
    });

    backlogContent.querySelectorAll('.btn-view').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const { project, cardid, cardtype, section, key, firebasekey, dev } = btn.dataset;
        modalDevContext = dev || '';
        if (!project || !cardid || !cardtype) {
          setStatus('Card sin datos para abrir.', 'error');
          return;
        }

        try {
          setStatus('Cargando tarjeta...', 'info');
          // Asegurar que los custom elements estén registrados antes de crear la tarjeta
          const cardImport = cardtype.includes('proposal')
            ? import('/js/wc/ProposalCard.js')
            : (cardtype.includes('bug')
              ? import('/js/wc/BugCard.js')
              : import('/js/wc/TaskCard.js'));
          await Promise.all([
            import('/js/wc/ColorTabs.js'),
            import('/js/wc/card-history-viewer.js'),
            import('/js/wc/FirebaseStorageUploader.js'),
            cardImport
          ]);

          // Use firebaseKey directly if available, fallback to extracting from cardKey
          let fbKey = firebasekey;
          if (!fbKey) {
            const keyParts = (key || '').split('|');
            fbKey = keyParts.length >= 3 ? keyParts[2] : cardid;
          }
          let cardData = await loadCardData(section, project, fbKey);
          // If not found by firebaseKey, try by display cardId as fallback
          if (!cardData && fbKey !== cardid && cardid) {
            cardData = await loadCardData(section, project, cardid);
          }
          if (!cardData) {
            // Remove stale entry from backlog and re-render
            if (dev && key) {
              await developerBacklogService.removeItem(dev, key);
              // Update local state
              const devBacklog = backlogEntries.get(dev);
              if (devBacklog) {
                delete devBacklog.items[key];
                devBacklog.order = (devBacklog.order || []).filter(k => k !== key);
              }
              renderBacklog();
              setStatus(`Tarjeta ${cardid || fbKey} eliminada del backlog (ya no existe en el proyecto).`, 'info');
            } else {
              setStatus(`No se encontró la tarjeta ${cardid || fbKey}.`, 'error');
            }
            return;
          }

          const tagName = cardtype.includes('proposal') ? 'proposal-card' : (cardtype.includes('bug') ? 'bug-card' : 'task-card');
          const cardElement = document.createElement(tagName);

          const statusList = await loadStatusList(cardtype);
          const developersList = entityDirectoryService.getActiveDevelopers().map(dev => ({
            id: dev.id,
            email: dev.email,
            name: dev.name || formatNameFromEmail(dev.email)
          }));

          // Load sprints for the specific project (needed when opening from backlog)
          const projectSprintList = await FirebaseService.getSprintList(project);

          // Clean UI state fields that shouldn't be in Firebase data
          const { expanded: _, isEditable: __, isSaving: ___, ...cleanCardData } = cardData;

          Object.assign(cardElement, cleanCardData, {
            projectId: project,
            cardType: cardtype,
            cardKey: key,
            userEmail,
            expanded: true,
            statusList,
            developerList: developersList,
            developers: developersList,
            globalSprintList: projectSprintList,
            _skipClone: true
          });

          const { showExpandedCardInModal } = await import('/js/utils/common-functions.js');
          showExpandedCardInModal(cardElement);
          setStatus('', 'info');
        } catch (error) {
          setStatus('Error abriendo tarjeta: ' + error.message, 'error');
        }
      });
    });

    // Bind sync backlog button
    const syncBacklogBtn = document.getElementById('syncBacklogBtn');
    if (syncBacklogBtn) {
      syncBacklogBtn.onclick = () => syncBacklogs();
    }
  }

