  // Sync backlogs from existing "To Do" tasks
  async function syncBacklogs() {
    if (scanning) return;
    scanning = true;
    showLoading('Sincronizando backlogs...');
    render();

    try {
      await entityDirectoryService.waitForInit();

      const projectsSnap = await get(ref(database, '/projects'));
      if (!projectsSnap.exists()) {
        setStatus('No hay proyectos.', 'error');
        scanning = false;
        render();
        return;
      }

      const projects = Object.keys(projectsSnap.val() || {});
      const backlogsByDev = new Map(); // devId -> { order: [], items: {} }
      let taskCount = 0;

      for (const projectId of projects) {
        // Scan tasks
        const tasksPath = `/cards/${projectId}/TASKS_${projectId}`;
        const tasksSnap = await get(ref(database, tasksPath));

        if (tasksSnap.exists()) {
          const tasks = tasksSnap.val() || {};

          for (const [taskKey, task] of Object.entries(tasks)) {
            const status = (task.status || '').toLowerCase();
            // Only "To Do" tasks go to backlog (In Progress go to WIP)
            if (!['to do', 'todo', 'pending'].includes(status)) continue;

            const developerRaw = task.developer || '';
            if (!developerRaw) continue;

            let devId = entityDirectoryService.resolveDeveloperId(developerRaw);

            if (!devId && developerRaw.startsWith('dev_')) {
              devId = developerRaw; // Trust dev_XXX format
            }
            if (!devId) {
              devId = await entityDirectoryService.findOrCreateDeveloper(
                developerRaw.includes('@') ? developerRaw : '',
                developerRaw.includes('@') ? null : developerRaw
              );
            }
            if (!devId) continue;

            const cardKey = `${projectId}|task-card|${taskKey}`;

            if (!backlogsByDev.has(devId)) {
              backlogsByDev.set(devId, { order: [], items: {}, email: entityDirectoryService.getDeveloper(devId)?.email || '' });
            }

            const devBacklog = backlogsByDev.get(devId);
            if (!devBacklog.items[cardKey]) {
              devBacklog.order.push(cardKey);
              devBacklog.items[cardKey] = {
                cardKey,
                cardId: task.cardId || taskKey,
                firebaseKey: taskKey,
                projectId,
                cardType: 'task-card',
                title: task.title || task.cardId || taskKey,
                status: task.status,
                addedBy: 'sync',
                addedAt: new Date().toISOString()
              };
              taskCount++;
            }
          }
        }

        // Scan proposals
        const proposalsPath = `/cards/${projectId}/PROPOSALS_${projectId}`;
        const proposalsSnap = await get(ref(database, proposalsPath));

        if (proposalsSnap.exists()) {
          const proposals = proposalsSnap.val() || {};
          for (const [propKey, prop] of Object.entries(proposals)) {
            const status = (prop.status || '').toLowerCase();
            if (!['to do', 'todo', 'pending', ''].includes(status)) continue;

            const developerRaw = prop.developer || '';
            if (!developerRaw) continue;

            let devId = entityDirectoryService.resolveDeveloperId(developerRaw);
            if (!devId && developerRaw.startsWith('dev_')) {
              devId = developerRaw;
            }
            if (!devId) continue;

            const cardKey = `${projectId}|proposal-card|${prop.cardId || propKey}`;

            if (!backlogsByDev.has(devId)) {
              backlogsByDev.set(devId, { order: [], items: {}, email: entityDirectoryService.getDeveloper(devId)?.email || '' });
            }

            const devBacklog = backlogsByDev.get(devId);
            if (!devBacklog.items[cardKey]) {
              devBacklog.order.push(cardKey);
              devBacklog.items[cardKey] = {
                cardKey,
                cardId: prop.cardId || propKey,
                projectId,
                cardType: 'proposal-card',
                title: prop.title || prop.cardId || propKey,
                status: prop.status || 'To Do',
                addedBy: 'sync',
                addedAt: new Date().toISOString()
              };
              taskCount++;
            }
          }
        }

        // Scan bugs (assigned, not finalized)
        const bugsPath = `/cards/${projectId}/BUGS_${projectId}`;
        const bugsSnap = await get(ref(database, bugsPath));

        if (bugsSnap.exists()) {
          const bugs = bugsSnap.val() || {};
          // Bug statuses that are considered "finalized" (should NOT appear in backlog)
          const finalizedBugStatuses = ['fixed', 'verified', 'closed', 'won\'t fix', 'wontfix', 'duplicate', 'invalid'];

          for (const [bugKey, bug] of Object.entries(bugs)) {
            const status = (bug.status || '').toLowerCase();
            // Skip finalized bugs
            if (finalizedBugStatuses.includes(status)) continue;

            const developerRaw = bug.developer || '';
            if (!developerRaw) continue;

            let devId = entityDirectoryService.resolveDeveloperId(developerRaw);
            if (!devId && developerRaw.startsWith('dev_')) {
              devId = developerRaw;
            }
            if (!devId) continue;

            const cardKey = `${projectId}|bug-card|${bugKey}`;

            if (!backlogsByDev.has(devId)) {
              backlogsByDev.set(devId, { order: [], items: {}, email: entityDirectoryService.getDeveloper(devId)?.email || '' });
            }

            const devBacklog = backlogsByDev.get(devId);
            if (!devBacklog.items[cardKey]) {
              devBacklog.order.push(cardKey);
              devBacklog.items[cardKey] = {
                cardKey,
                cardId: bug.cardId || bugKey,
                firebaseKey: bugKey,
                projectId,
                cardType: 'bug-card',
                title: bug.title || bug.cardId || bugKey,
                status: bug.status || 'Assigned',
                addedBy: 'sync',
                addedAt: new Date().toISOString()
              };
              taskCount++;
            }
          }
        }
      }

      // Merge with existing backlogs (don't overwrite, just add missing)
      const existingBacklogsSnap = await get(ref(database, '/developerBacklogs'));
      const existingBacklogs = existingBacklogsSnap.exists() ? existingBacklogsSnap.val() || {} : {};

      for (const [devId, newBacklog] of backlogsByDev.entries()) {
        const existing = existingBacklogs[devId] || { order: [], items: {} };
        const mergedItems = { ...existing.items };
        const mergedOrder = [...(existing.order || [])];

        for (const [cardKey, item] of Object.entries(newBacklog.items)) {
          if (!mergedItems[cardKey]) {
            mergedItems[cardKey] = item;
            if (!mergedOrder.includes(cardKey)) {
              mergedOrder.push(cardKey);
            }
          }
        }

        await set(ref(database, `/developerBacklogs/${devId}`), {
          order: mergedOrder,
          items: mergedItems,
          email: newBacklog.email || existing.email || ''
        });
      }

      setStatus(`Sincronización completada. ${taskCount} tareas añadidas a backlogs de ${backlogsByDev.size} developers.`, 'success');
    } catch (error) {
      console.error('[syncBacklogs] Error:', error);
      setStatus('Error sincronizando: ' + error.message, 'error');
    }

    hideLoading();
    scanning = false;
    render();
  }

  // Firebase listeners
  function listenDevelopers() {
    const syncDirectory = () => {
      developerDirectory.clear();
      const list = entityDirectoryService.getAllDevelopers();
      list.forEach((info) => {
        if (!info || !info.id) {
          console.warn('[WIP] Developer without id ignored:', info);
          return;
        }
        // Always use info.id as the unique identifier - never fallback to email
        developerDirectory.set(info.id, {
          id: info.id,
          email: (info.email || '').toLowerCase().trim(),
          name: info.name || formatNameFromEmail(info.email) || info.id,
          active: info.active !== false
        });
      });
      render();
    };

    syncDirectory();
    entityDirectoryService.addChangeListener((type) => {
      if (type === 'projects' || type === 'developers') {
        syncDirectory();
      }
    });
  }

  function listenWip() {
    const wipRef = ref(database, '/wip');
    onValue(wipRef, (snapshot) => {
      wipEntries.clear();
      if (snapshot.exists()) {
        const data = snapshot.val() || {};
        for (const [devId, entry] of Object.entries(data)) {
          if (entry) {
            wipEntries.set(devId, entry);
          }
        }
      }
      render();
    });
  }

  function listenBacklogs() {
    const backlogRef = ref(database, '/developerBacklogs');
    onValue(backlogRef, (snapshot) => {
      backlogEntries.clear();
      if (snapshot.exists()) {
        const raw = snapshot.val() || {};
        for (const [devId, data] of Object.entries(raw)) {
          backlogEntries.set(devId, {
            order: Array.isArray(data.order) ? data.order : [],
            items: data.items || {},
            email: data.email || ''
          });
        }
      }
      // Don't render if we're in the middle of removing an item
      if (!isRemovingFromBacklog) {
        render();
      }
    });
  }

  function setupCardEventHandlers() {
    // Enable request-card-action (needed for _updateExistingTaskStatus in TaskCard)
    FirebaseService.init();

    // Handle request-project-tasks (needed for _validateDeveloperInProgressLimit in TaskCard)
    document.addEventListener('request-project-tasks', async (e) => {
      const { projectId, callback, fullData = false } = e.detail;
      try {
        const path = FirebaseService.getPathBySectionAndProjectId('tasks', projectId);
        const tasks = await FirebaseService.getCards(path);

        let taskList;
        if (fullData) {
          taskList = Object.entries(tasks || {}).map(([id, task]) => ({
            id,
            firebaseId: id,
            ...task
          }));
        } else {
          taskList = Object.entries(tasks || {}).map(([id, task]) => ({
            id,
            cardId: task.cardId,
            title: task.title || 'Sin título'
          }));
        }

        // Also check global /wip for cross-project In Progress tasks
        if (fullData) {
          const wipSnap = await get(ref(database, '/wip'));
          if (wipSnap.exists()) {
            const wipData = wipSnap.val() || {};
            for (const [devId, wipEntry] of Object.entries(wipData)) {
              if (!wipEntry || !wipEntry.taskId || wipEntry.projectId === projectId) continue;
              const alreadyIncluded = taskList.some(t =>
                t.firebaseId === wipEntry.taskId || t.cardId === wipEntry.cardId
              );
              if (!alreadyIncluded) {
                // Fetch full card data from the other project
                const wipTaskPath = FirebaseService.getPathBySectionAndProjectId('tasks', wipEntry.projectId);
                const wipTasksData = await FirebaseService.getCards(wipTaskPath);
                if (wipTasksData && wipTasksData[wipEntry.taskId]) {
                  taskList.push({
                    ...wipTasksData[wipEntry.taskId],
                    id: wipEntry.taskId,
                    firebaseId: wipEntry.taskId,
                    group: 'tasks',
                    cardType: 'task-card'
                  });
                }
              }
            }
          }
        }

        if (callback) callback(taskList);
      } catch (error) {
        if (callback) callback([]);
      }
    });

    // Handle save-card event (needed for BaseCard._handleSave to persist to Firebase)
    document.addEventListener('save-card', async (e) => {
      const { cardData } = e.detail;
      if (!cardData) return;

      if (!cardData.projectId) {
        cardData.projectId = cardData.projectId || '';
      }

      try {
        await FirebaseService.saveCard(cardData);
      } catch (error) {
        console.error('[WIP] Error saving card:', error);
        document.dispatchEvent(new CustomEvent('card-save-error', {
          detail: { error: error.message, cardData }
        }));
      }
    });
  }

  function setupPermissionHandlers() {
    document.addEventListener('request-task-permissions', (e) => {
      const { callback } = e.detail;
      const devMatch = modalDevContext && modalDevContext === currentUserId;
      const isAdmin = isSuperAdmin || devMatch;
      const permissions = {
        canEdit: isAdmin,
        canSave: isAdmin,
        canDelete: isSuperAdmin,
        userRole: { isResponsable: isAdmin },
        viewMode: 'management'
      };
      if (callback) callback(permissions);
    });

    document.addEventListener('request-ownership-permissions', (e) => {
      const { createdBy, callback } = e.detail;
      const current = normalizeEmailSafe(userEmail);
      const isOwner = createdBy && current && normalizeEmailSafe(createdBy) === current;
      const devMatch = modalDevContext && modalDevContext === currentUserId;
      const isAdmin = isSuperAdmin || devMatch;
      const canEdit = isAdmin || isOwner;
      const permissions = {
        canEdit,
        canSave: canEdit,
        canDelete: isSuperAdmin,
        canConvertToTask: canEdit,
        userRole: { isResponsable: isAdmin },
        viewMode: 'management',
        isOwner,
        isAdmin
      };
      if (callback) callback(permissions);
    });
  }

  // Init
  async function init() {
    // Inicializar el servicio de directorio
    await entityDirectoryService.init();
    if (!window.cardRealtimeService) {
      window.cardRealtimeService = new CardRealtimeService(FirebaseService);
    }

    const email = document.body.dataset.userEmail || '';
    if (email) {
      currentUserEmail = normalizeEmailSafe(email);
      currentUserId = entityDirectoryService.resolveDeveloperId(currentUserEmail) || '';
      isSuperAdmin = await isCurrentUserSuperAdmin(currentUserEmail);
      setupCardEventHandlers();
      setupPermissionHandlers();
      tabButtons.forEach(btn => btn.addEventListener('click', () => updateTabs(btn.dataset.tab, true)));
      document.getElementById('refreshBacklogBtn')?.addEventListener('click', () => syncBacklogs());
      listenDevelopers();
      listenWip();
      listenBacklogs();
      restoreTabFromUrl(); // Restore tab from URL on page load
      render();
    } else {
      document.addEventListener('user-authenticated', async (event) => {
        const email = event?.detail?.user?.email || document.body.dataset.userEmail || '';
        currentUserEmail = normalizeEmailSafe(email);
        currentUserId = entityDirectoryService.resolveDeveloperId(currentUserEmail) || '';
        isSuperAdmin = await isCurrentUserSuperAdmin(currentUserEmail);
        setupCardEventHandlers();
        setupPermissionHandlers();
        tabButtons.forEach(btn => btn.addEventListener('click', () => updateTabs(btn.dataset.tab, true)));
        document.getElementById('refreshBacklogBtn')?.addEventListener('click', () => syncBacklogs());
        listenDevelopers();
        listenWip();
        listenBacklogs();
        restoreTabFromUrl(); // Restore tab from URL on page load
        render();
      }, { once: true });
    }
  }

  init();
</script>

