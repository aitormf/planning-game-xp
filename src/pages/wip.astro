  async function loadCardData(section, projectId, cardId) {
    const path = FirebaseService.getPathBySectionAndProjectId(section, projectId);
    const cards = await FirebaseService.getCards(path);
    if (!cards) return null;

    if (cards[cardId]) {
      return { ...cards[cardId], firebaseId: cardId, cardId: cards[cardId].cardId || cardId };
    }

    for (const [firebaseId, card] of Object.entries(cards)) {
      if (!card) continue;
      if (card.cardId === cardId || card.id === cardId) {
        return { ...card, firebaseId, cardId: card.cardId || firebaseId };
      }
    }

    return null;
  }

  async function loadStatusList(cardType) {
    const cached = statusCache.get(cardType);
    if (cached) return cached;

    const raw = await FirebaseService.getStatusList(cardType);
    const list = Array.isArray(raw) ? raw : Object.keys(raw || {});
    if (!list.length) {
      throw new Error(`Sin status list para ${cardType}`);
    }
    statusCache.set(cardType, list);
    return list;
  }

  function handleBacklogDragStart(e) {
    const item = e.currentTarget.closest('.backlog-item, .backlog-row') || e.currentTarget;
    draggedItem = item;
    item.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
  }

  function handleBacklogDragEnd() {
    if (draggedItem) {
      draggedItem.classList.remove('dragging');
      draggedItem = null;
    }
  }

  function handleBacklogDragOver(e) {
    e.preventDefault();
    const list = e.currentTarget.closest('.backlog-items, .backlog-rows');
    if (!list || !draggedItem) return;
    if (list.dataset.dev !== draggedItem.dataset.dev) return;

    const target = e.target.closest('.backlog-item, .backlog-row');
    if (!target || target === draggedItem) return;

    const bounding = target.getBoundingClientRect();
    const offset = e.clientY - bounding.top;
    const shouldInsertAfter = offset > bounding.height / 2;
    if (shouldInsertAfter) {
      target.insertAdjacentElement('afterend', draggedItem);
    } else {
      target.insertAdjacentElement('beforebegin', draggedItem);
    }
  }

  async function handleBacklogDrop(e) {
    e.preventDefault();
    const list = e.currentTarget;
    const devId = list.dataset.dev;
    if (!draggedItem || list.dataset.dev !== draggedItem.dataset.dev) {
      handleBacklogDragEnd();
      return;
    }

    openState.set(devId, true);
    const container = list.closest('details');
    if (container) container.setAttribute('open', '');

    const newOrder = Array.from(list.querySelectorAll('.backlog-item, .backlog-row')).map(item => item.dataset.key);
    try {
      await developerBacklogService.reorder(devId, newOrder);
      setStatus('Backlog reordenado.', 'success');
    } catch (error) {
      setStatus('Error al reordenar: ' + error.message, 'error');
    }

    handleBacklogDragEnd();
  }

  async function handleAction(action, devKey, taskId, projectId) {
    const taskPath = `/cards/${projectId}/TASKS_${projectId}/${taskId}`;
    const snap = await get(ref(database, taskPath));
    if (!snap.exists()) throw new Error('Tarea no encontrada');

    const task = snap.val();
    task.firebaseId = taskId; // taskId is the Firebase key
    task.id = taskId;
    task.projectId = projectId;
    task.group = 'tasks';
    task.cardType = 'task-card';

    if (action === 'tovalidate') {
      const missingFields = [];
      if (!task.title || task.title.trim() === '') missingFields.push('Título');
      if (!task.developer) missingFields.push('Developer');
      if (!task.startDate) missingFields.push('Fecha inicio');

      if (missingFields.length > 0) {
        throw new Error(`Faltan campos obligatorios: ${missingFields.join(', ')}`);
      }

      task.status = 'To Validate';
    } else if (action === 'unassign') {
      task.status = 'To Do';
      task.developer = '';
      task.developerName = '';
    }

    const { FirebaseService } = await import('/js/services/firebase-service.js');
    await FirebaseService.saveCard(task, { silent: true });
  }

  // Scan all tasks across all projects
  async function scanAllTasks() {
    if (scanning) return;
    scanning = true;
    render();
    setStatus('Escaneando tareas...', 'info');

    try {
      // Asegurar que el directorio esté inicializado
      await entityDirectoryService.waitForInit();

      const projectsSnap = await get(ref(database, '/projects'));
      if (!projectsSnap.exists()) {
        setStatus('No hay proyectos.', 'error');
        scanning = false;
        render();
        return;
      }

      const projects = Object.keys(projectsSnap.val() || {});
      const foundWip = new Map(); // devId -> entry

      for (const projectId of projects) {
        const tasksPath = `/cards/${projectId}/TASKS_${projectId}`;
        const tasksSnap = await get(ref(database, tasksPath));
        if (!tasksSnap.exists()) {
          continue;
        }

        const tasks = tasksSnap.val() || {};
        const statusCounts = {};
        for (const t of Object.values(tasks)) {
          const s = t.status || '(vacío)';
          statusCounts[s] = (statusCounts[s] || 0) + 1;
        }

        for (const [taskKey, task] of Object.entries(tasks)) {
          const status = (task.status || '').toLowerCase();
          if (status === 'in progress') {
          }
          if (status !== 'in progress') continue;

          const developerRaw = task.developer || '';
          if (!developerRaw) {
            continue;
          }

          // Resolver developer a ID (puede venir como email, nombre o ya como ID)
          let devId = entityDirectoryService.resolveDeveloperId(developerRaw);

          // Si no existe, crear una entrada nueva
          if (!devId) {
            devId = await entityDirectoryService.findOrCreateDeveloper(
              developerRaw.includes('@') ? developerRaw : '',
              developerRaw.includes('@') ? null : developerRaw
            );
          }

          if (!devId) {
            continue;
          }


          const startedAt = task.currentWip?.startedAt ||
            (task.startDate ? new Date(task.startDate).toISOString() : new Date().toISOString());

          const developerName = entityDirectoryService.getDeveloperDisplayName(devId);

          foundWip.set(devId, {
            taskId: taskKey,
            taskTitle: task.title || task.cardId || taskKey,
            projectId,
            startedAt,
            developer: devId,
            developerName
          });
        }
      }

      for (const [k, v] of foundWip.entries()) {
      }

      // Update /wip in Firebase
      const currentWipSnap = await get(ref(database, '/wip'));
      const currentWip = currentWipSnap.exists() ? currentWipSnap.val() || {} : {};

      // Remove entries that no longer have active tasks
      for (const devId of Object.keys(currentWip)) {
        if (!foundWip.has(devId)) {
          await set(ref(database, `/wip/${devId}`), null);
        }
      }

      // Add/update entries for developers with active tasks
      for (const [devId, entry] of foundWip.entries()) {
        await set(ref(database, `/wip/${devId}`), entry);
      }

      setStatus(`Escaneo completado. ${foundWip.size} tareas en progreso.`, 'success');
    } catch (error) {
      setStatus('Error escaneando: ' + error.message, 'error');
    }

    scanning = false;
    render();
  }

