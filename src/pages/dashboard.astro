---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Project Analytics Dashboard">
  <div class="dashboard-header">
    <h1>Project Analytics Dashboard</h1>
    <div class="project-selector-container">
      <multi-project-selector id="projectSelector" max-projects="3"></multi-project-selector>
    </div>
  </div>

  <div class="dashboard-content">
    <div class="tabs">
      <button class="tab-button active" data-tab="gantt">
        <span class="tab-icon">📊</span>
        Gantt Charts
      </button>
      <button class="tab-button" data-tab="sprint">
        <span class="tab-icon">📈</span>
        Sprint Analytics
      </button>
      <button class="tab-button" data-tab="developer">
        <span class="tab-icon">🧑‍💻</span>
        Developer Metrics
      </button>
    </div>

    <div class="year-selector-controls">
      <label for="dashboard-year-selector">Año:</label>
      <select id="dashboard-year-selector" disabled>
        <option value="">Selecciona proyecto</option>
      </select>
    </div>

    <div class="tab-content active" id="gantt-tab">
      <div class="chart-container">
        <div id="gantt-charts-container">
          <div class="no-projects-message">
            Select up to 3 projects to compare their Gantt charts
          </div>
        </div>
      </div>
    </div>

    <div class="tab-content" id="sprint-tab">
      <div class="chart-container">
        <div id="sprint-charts-container">
          <div class="no-projects-message">
            Select up to 3 projects to compare their sprint analytics
          </div>
        </div>
      </div>
    </div>

    <div class="tab-content" id="developer-tab">
      <div class="chart-container">
        <div id="developer-metrics-container">
          <div class="no-projects-message">
            Select up to 3 projects to view developer metrics
          </div>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script type="module">
  import '/js/wc/GanttChart.js';
  import '/js/wc/SprintPointsChart.js';
  import { database, ref, onValue, get, superAdminEmail } from '/firebase-config.js';
  import { getLists } from '/js/utils/common-functions.js';
import { normalizeDeveloperEntry, getDeveloperKey } from '/js/utils/developer-normalizer.js';

  class MultiProjectSelector extends HTMLElement {
    constructor() {
      super();
      this.selectedProjects = [];
      this.maxProjects = parseInt(this.getAttribute('max-projects')) || 3;
      this.allProjects = [];
    }

    connectedCallback() {
      this.waitForAuthAndLoad();
    }

    async waitForAuthAndLoad() {
      try {
        const { auth } = await import('/firebase-config.js');
        
        // Si ya hay un usuario autenticado, cargar inmediatamente
        if (auth.currentUser) {
this.loadProjects();
          return;
        }

        // Si no hay usuario, esperar por el estado de autenticación
this.innerHTML = '<p style="text-align: center; padding: 2rem;">Loading projects...</p>';
        
        const unsubscribe = auth.onAuthStateChanged((user) => {
if (user) {
            this.loadProjects();
            unsubscribe(); // Solo cargar una vez
          } else {
            this.innerHTML = '<p class="error">Please sign in to view projects</p>';
            unsubscribe();
          }
        });
        
        // Timeout de seguridad después de 10 segundos
        setTimeout(() => {
          if (!auth.currentUser) {
this.innerHTML = '<p class="error">Authentication timeout. Please refresh the page.</p>';
            unsubscribe();
          }
        }, 10000);

      } catch (error) {
this.innerHTML = '<p class="error">Error initializing dashboard</p>';
      }
    }

    async loadProjects() {
      try {
        // Wait for authentication
        const { auth } = await import('/firebase-config.js');
        const currentUser = auth.currentUser;
if (!currentUser) {
          this.innerHTML = '<p class="error">Please sign in to view projects</p>';
          return;
        }
        
        // Import email sanitizer
        const { encodeEmailForFirebase } = await import('/js/utils/email-sanitizer.js');
        const userKey = encodeEmailForFirebase(currentUser.email);
        
        // Check user's project access
        const userProjectsRef = ref(database, `/data/projectsByUser/${userKey}`);
        const userProjectsSnapshot = await get(userProjectsRef);
        const userProjectsData = userProjectsSnapshot.val();
// Get all projects from Firebase
        const projectsRef = ref(database, 'projects');
        const allProjectsSnapshot = await get(projectsRef);
        
        
        if (allProjectsSnapshot.exists()) {
          const allProjectsRaw = allProjectsSnapshot.val();
const allProjects = Object.entries(allProjectsRaw).map(([id, project]) => ({
            id,
            name: project.name || id,
            ...project
          }));
// Filter projects based on user access
          const isSuperAdmin = superAdminEmail && currentUser.email.toLowerCase() === superAdminEmail.toLowerCase();
          if (isSuperAdmin || userProjectsData === 'All') {
            // SuperAdmin or user with "All" access sees all projects
            this.allProjects = allProjects;
} else if (userProjectsData) {
            // User has access to specific projects
            const allowedProjects = userProjectsData.split(',').map(p => p.trim());
this.allProjects = allProjects.filter(project =>
              allowedProjects.includes(project.id) || allowedProjects.includes(project.name)
            );
} else {
            // User has no project access
            this.allProjects = [];
}
this.render();
        } else {
this.allProjects = [];
          this.render();
        }
      } catch (error) {
this.innerHTML = '<p class="error">Error loading projects</p>';
      }
    }

    render() {
      this.innerHTML = `
        <style>
          .project-selector {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
          }
          
          .project-selector > label {
            display: block;
            margin-bottom: 1.5rem;
            font-weight: 500;
            font-size: 1.1rem;
            color: white;
          }
          
          .project-checkboxes {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            width: 100%;
          }
          
          .project-checkbox-item {
            flex: 0 0 auto;
            width: 180px;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            padding: 0.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
          }
          
          .project-checkbox-item:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.4);
          }
          
          .project-checkbox-item.selected {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.6);
            box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.3);
          }
          
          .project-checkbox-item.disabled {
            opacity: 0.5;
            cursor: not-allowed;
          }
          
          .project-checkbox {
            transform: scale(1.0);
            flex-shrink: 0;
            margin: 0;
          }
          
          .project-label {
            cursor: pointer;
            font-size: 0.9rem;
            color: white;
            line-height: 1.2;
            display: flex;
            align-items: center;
            margin: 0;
          }
          
          .project-name {
            font-weight: 500;
          }
          
          .selected-count {
            text-align: center;
            font-size: 0.9rem;
            opacity: 0.9;
            font-weight: 500;
            color: white;
          }
          
          .no-access-message {
            text-align: center;
            padding: 2rem;
            color: white;
          }
          
          .no-access-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.8;
          }
          
          .no-access-title {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: #ffeb3b;
          }
          
          .no-access-text {
            font-size: 1rem;
            line-height: 1.5;
            opacity: 0.9;
          }
          
          .no-access-text strong {
            color: #ffeb3b;
            font-weight: 600;
          }
        </style>
        <div class="project-selector">
          ${this.allProjects.length > 0 ? `
            <label>Select Projects (max ${this.maxProjects}):</label>
            <div class="project-checkboxes">
              ${this.allProjects.map(project => {
                const isSelected = this.selectedProjects.find(selected => selected.id === project.id);
                const isDisabled = !isSelected && this.selectedProjects.length >= this.maxProjects;
                return `
                  <div class="project-checkbox-item ${isSelected ? 'selected' : ''} ${isDisabled ? 'disabled' : ''}">
                    <input 
                      type="checkbox" 
                      id="project-${project.id}" 
                      value="${project.id}"
                      ${isSelected ? 'checked' : ''}
                      ${isDisabled ? 'disabled' : ''}
                      class="project-checkbox"
                    >
                    <label for="project-${project.id}" class="project-label">
                      <span class="project-name">${project.name}</span>
                    </label>
                  </div>
                `;
              }).join('')}
            </div>
            <div class="selected-count">
              ${this.selectedProjects.length} of ${this.maxProjects} projects selected
            </div>
          ` : `
            <div class="no-access-message">
              <div class="no-access-icon">🔒</div>
              <div class="no-access-title">Sin acceso a proyectos</div>
              <div class="no-access-text">
                No tienes proyectos asignados para visualizar gráficas.<br>
                <strong>Solicita al administrador que te asigne proyectos</strong> para poder acceder al dashboard.
              </div>
            </div>
          `}
        </div>
      `;

      this.setupEventListeners();
    }

    setupEventListeners() {
      const checkboxes = this.querySelectorAll('.project-checkbox');

      checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', (e) => {
          const projectId = e.target.value;
          const project = this.allProjects.find(p => p.id === projectId);
          
          if (e.target.checked) {
            // Add project if not already selected and under limit
            if (project && !this.selectedProjects.find(p => p.id === projectId) && this.selectedProjects.length < this.maxProjects) {
              this.selectedProjects.push(project);
              this.render();
              this.dispatchProjectChange();
            }
          } else {
            // Remove project
            this.selectedProjects = this.selectedProjects.filter(p => p.id !== projectId);
            this.render();
            this.dispatchProjectChange();
          }
        });
      });
    }

    dispatchProjectChange() {
      this.dispatchEvent(new CustomEvent('projects-changed', {
        detail: { projects: this.selectedProjects },
        bubbles: true
      }));
    }
  }

  // Register the custom element
  customElements.define('multi-project-selector', MultiProjectSelector);

  class DashboardController {
    constructor() {
      this.selectedProjects = [];
      this.activeTab = 'gantt';
      this.selectedYear = new Date().getFullYear();
      this.availableYears = [];
      this.developerMetricsView = 'summary';
      this.developerSprintMetrics = null;
      this.developerSprintFilter = { developer: 'all', sprint: 'all' };
      this._chartJsModule = null;
      this._developerSprintChart = null;
      this._developerSprintChartMeta = null;
      this.developerSprintChartMode = 'completed';
      this.init();
    }

    init() {
      this.setupTabSwitching();
      this.setupProjectSelector();
      this.setupYearSelector();
    }

    setupYearSelector() {
      const selector = document.getElementById('dashboard-year-selector');
      selector.addEventListener('change', (e) => {
        this.selectedYear = parseInt(e.target.value, 10);
        this.updateChartsForActiveTab();
      });
    }

    updateYearSelector(years) {
      const selector = document.getElementById('dashboard-year-selector');
      const currentValue = this.selectedYear;

      // Sort years descending (most recent first)
      const sortedYears = [...years].sort((a, b) => b - a);

      selector.innerHTML = sortedYears.map(year =>
        `<option value="${year}" ${year === currentValue ? 'selected' : ''}>${year}</option>`
      ).join('');

      // Enable the selector
      selector.disabled = false;

      // If current selected year is not in available years, select the most recent
      if (!sortedYears.includes(currentValue) && sortedYears.length > 0) {
        this.selectedYear = sortedYears[0];
        selector.value = this.selectedYear;
      }
    }

    setupTabSwitching() {
      const tabButtons = document.querySelectorAll('.tab-button');
      const tabContents = document.querySelectorAll('.tab-content');

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const tabName = button.dataset.tab;
          
          // Update active states
          tabButtons.forEach(btn => btn.classList.remove('active'));
          tabContents.forEach(content => content.classList.remove('active'));
          
          button.classList.add('active');
          document.getElementById(`${tabName}-tab`).classList.add('active');
          
          this.activeTab = tabName;
          this.updateChartsForActiveTab();
        });
      });
    }

    setupProjectSelector() {
      const selector = document.getElementById('projectSelector');
      selector.addEventListener('projects-changed', async (e) => {
        this.selectedProjects = e.detail.projects;
        await this.loadAvailableYears();
        this.updateChartsForActiveTab();
      });
    }

    async loadAvailableYears() {
      const yearSelector = document.getElementById('dashboard-year-selector');

      if (this.selectedProjects.length === 0) {
        yearSelector.innerHTML = '<option value="">Selecciona proyecto</option>';
        yearSelector.disabled = true;
        return;
      }

      const { database, ref, get } = await import('/firebase-config.js');
      const allYears = new Set();

      // Load years from epics, sprints, and tasks
      for (const project of this.selectedProjects) {
        try {
          // From epics
          const epicsRef = ref(database, `/cards/${project.id}/EPICS_${project.id}`);
          const epicsSnapshot = await get(epicsRef);
          if (epicsSnapshot.exists()) {
            Object.values(epicsSnapshot.val()).forEach(epic => {
              if (epic.deletedAt) return;
              const startDate = epic.startDate || epic.estimatedStartDate;
              const endDate = epic.endDate || epic.estimatedEndDate;
              if (startDate) {
                const year = new Date(startDate).getFullYear();
                if (!isNaN(year)) allYears.add(year);
              }
              if (endDate) {
                const year = new Date(endDate).getFullYear();
                if (!isNaN(year)) allYears.add(year);
              }
            });
          }

          // From sprints
          const sprintsRef = ref(database, `/cards/${project.id}/SPRINTS_${project.id}`);
          const sprintsSnapshot = await get(sprintsRef);
          if (sprintsSnapshot.exists()) {
            Object.values(sprintsSnapshot.val()).forEach(sprint => {
              const startDate = sprint.startDate;
              const endDate = sprint.endDate || sprint.estimatedEndDate;
              if (startDate) {
                const year = new Date(startDate).getFullYear();
                if (!isNaN(year)) allYears.add(year);
              }
              if (endDate) {
                const year = new Date(endDate).getFullYear();
                if (!isNaN(year)) allYears.add(year);
              }
            });
          }
        } catch (error) {
          console.warn('Error loading years for project:', project.id, error);
        }
      }

      // Always include current year
      allYears.add(new Date().getFullYear());

      this.updateYearSelector(Array.from(allYears));
    }

    updateChartsForActiveTab() {
      if (this.activeTab === 'gantt') {
        this.updateGanttCharts();
      } else if (this.activeTab === 'sprint') {
        this.updateSprintCharts();
      } else if (this.activeTab === 'developer') {
        this.updateDeveloperMetrics();
      }
    }

    async updateGanttCharts() {
      const container = document.getElementById('gantt-charts-container');
      if (this.selectedProjects.length === 0) {
        container.innerHTML = '<div class="no-projects-message">Select up to 3 projects to compare their Gantt charts</div>';
        return;
      }

      container.innerHTML = '<div class="no-projects-message">Cargando datos del Gantt...</div>';

      const { database, ref, get } = await import('/firebase-config.js');
      const projectEpicsMap = new Map();

      for (const project of this.selectedProjects) {
        try {
          const epicsRef = ref(database, `/cards/${project.id}/EPICS_${project.id}`);
          const epicsSnapshot = await get(epicsRef);

          if (epicsSnapshot.exists()) {
            projectEpicsMap.set(project.id, epicsSnapshot.val());
          } else {
            projectEpicsMap.set(project.id, {});
          }
        } catch (error) {
          projectEpicsMap.set(project.id, null); // Mark as error
        }
      }

      // Render charts
      container.innerHTML = '';

      for (const [index, project] of this.selectedProjects.entries()) {
        const epics = projectEpicsMap.get(project.id);

        if (epics === null) {
          // Error loading this project
          const chartWrapper = document.createElement('div');
          chartWrapper.className = 'chart-wrapper';
          chartWrapper.innerHTML = `
            <h3 class="chart-title" style="color: var(--project-color-${index + 1})">${project.name}</h3>
            <div class="error-message">Error loading Gantt data for this project</div>
          `;
          container.appendChild(chartWrapper);
          continue;
        }

        const chartWrapper = document.createElement('div');
        chartWrapper.className = 'chart-wrapper';
        chartWrapper.innerHTML = `
          <h3 class="chart-title" style="color: var(--project-color-${index + 1})">${project.name} (${this.selectedYear})</h3>
          <gantt-chart
            class="project-gantt"
            data-project-index="${index}"
            year="${this.selectedYear}">
          </gantt-chart>
        `;
        container.appendChild(chartWrapper);

        const ganttChart = chartWrapper.querySelector('gantt-chart');
        ganttChart.year = this.selectedYear;

        if (Object.keys(epics).length > 0) {
          const taskData = await this.prepareGanttData(epics, project.id, this.selectedYear);

          setTimeout(() => {
            ganttChart.setTaskData(taskData);
          }, 100);
        } else {
          setTimeout(() => {
            ganttChart.setTaskData([]);
          }, 100);
        }
      }
    }

    async prepareGanttData(epics, projectId, selectedYear = null) {
      const tasks = [];
      const todayStr = new Date().toISOString().split('T')[0];
      const currentYear = new Date().getFullYear();

      // Get project tasks to relate them with epics
      let projectTasks = {};
      try {
        const { database, ref, get } = await import('/firebase-config.js');
        const tasksRef = ref(database, `/cards/${projectId}/TASKS_${projectId}`);
        const tasksSnapshot = await get(tasksRef);
        if (tasksSnapshot.exists()) {
          projectTasks = tasksSnapshot.val();
        }
      } catch (error) {
      }

      Object.entries(epics).forEach(([id, epic]) => {
        if (epic.deletedAt) return;

        const startDate = epic.startDate || epic.estimatedStartDate;
        const endDate = epic.endDate || epic.estimatedEndDate || epic.desiredEndDate;

        // Filter by year if specified
        if (selectedYear) {
          const epicStartYear = startDate ? new Date(startDate).getFullYear() : null;
          const epicEndYear = endDate ? new Date(endDate).getFullYear() : null;

          // Check if epic has activity in the selected year:
          const startsInYear = epicStartYear === selectedYear;
          const endsInYear = epicEndYear === selectedYear;
          const spansYear = epicStartYear && epicEndYear && epicStartYear < selectedYear && epicEndYear > selectedYear;
          const isOngoingInYear = epicStartYear && !epicEndYear && epicStartYear <= selectedYear && selectedYear <= currentYear;

          // Check if epic has no dates but has tasks with activity in the selected year
          const hasTasksInYear = !epicStartYear && !epicEndYear && Object.values(projectTasks).some(task => {
            if (task.deletedAt) return false;
            const taskEpicId = task.epic || task.epicId;
            if (taskEpicId !== epic.cardId && taskEpicId !== id) return false;
            const taskYear = task.year || (task.startDate ? new Date(task.startDate).getFullYear() : null);
            return taskYear === selectedYear;
          });

          // Also check epic.year field directly
          const epicYearMatches = epic.year === selectedYear;

          if (!startsInYear && !endsInYear && !spansYear && !isOngoingInYear && !hasTasksInYear && !epicYearMatches) {
            return; // Skip this epic, not in selected year
          }
        }

        // Add epic as main task (same structure as gantt-renderer)
        const epicTask = {
          sprint: epic.sprintId || '',
          name: epic.title || 'Untitled Epic',
          plannedStart: startDate,
          plannedEnd: endDate,
          realStart: epic.startDate,
          realEnd: epic.endDate,
          dev: epic.assignedTo || 'Unassigned',
          subtasks: []
        };

        // Find tasks related to this epic
        Object.entries(projectTasks).forEach(([taskId, task]) => {
          if (task.deletedAt) return;

          // Check if task belongs to this epic (by epic ID)
          const taskEpicId = task.epic || task.epicId;
          if (taskEpicId === epic.cardId || taskEpicId === id) {
            // If has start date but no end date, use today as end ONLY for Gantt
            let plannedStart = task.startDate;
            let plannedEnd = task.endDate || task.desiredDate;
            if (plannedStart && !plannedEnd) {
              plannedEnd = todayStr;
            }
            const subtask = {
              name: task.title || 'Untitled Task',
              plannedStart,
              plannedEnd,
              realStart: task.startDate,
              realEnd: task.endDate,
              dev: task.developer || 'Unassigned'
            };

            // Only add if has start date
            if (subtask.plannedStart) {
              epicTask.subtasks.push(subtask);
            }
          }
        });

        // If epic has no start date, infer from earliest subtask
        if (!epicTask.plannedStart && epicTask.subtasks.length > 0) {
          const subtaskStarts = epicTask.subtasks
            .map(s => s.plannedStart)
            .filter(Boolean)
            .sort();
          if (subtaskStarts.length > 0) {
            epicTask.plannedStart = subtaskStarts[0];
          }
        }

        // If epic has no end date, infer from latest subtask
        if (!epicTask.plannedEnd && epicTask.subtasks.length > 0) {
          const subtaskEnds = epicTask.subtasks
            .map(s => s.plannedEnd)
            .filter(Boolean)
            .sort()
            .reverse();
          if (subtaskEnds.length > 0) {
            epicTask.plannedEnd = subtaskEnds[0];
          }
        }

        // Fallback: epic has year matching but no dates at all — use year boundaries
        if (!epicTask.plannedStart && selectedYear && epic.year === selectedYear) {
          epicTask.plannedStart = `${selectedYear}-01-01`;
        }

        // Only add epic if we have valid dates (start is required, end is optional for ongoing epics)
        if (epicTask.plannedStart) {
          // For ongoing epics without end date, use end of selected year for visualization
          if (!epicTask.plannedEnd && selectedYear) {
            epicTask.plannedEnd = `${selectedYear}-12-31`;
          } else if (!epicTask.plannedEnd) {
            epicTask.plannedEnd = todayStr;
          }
          tasks.push(epicTask);
        }
      });

      return tasks;
    }

    async updateSprintCharts() {
      const container = document.getElementById('sprint-charts-container');
if (this.selectedProjects.length === 0) {
        container.innerHTML = '<div class="no-projects-message">Select up to 3 projects to compare their sprint analytics</div>';
        return;
      }

      container.innerHTML = '';
      
      for (const [index, project] of this.selectedProjects.entries()) {
try {
          // Load sprint data like app-controller does
          const { database, ref, get } = await import('/firebase-config.js');
          const sprintsRef = ref(database, `/cards/${project.id}/SPRINTS_${project.id}`);
          const sprintsSnapshot = await get(sprintsRef);
          
          if (sprintsSnapshot.exists()) {
            const sprintData = sprintsSnapshot.val();
            const selectedYear = this.selectedYear;

            // Transform to expected format and filter by year
            const allSprints = Object.entries(sprintData).map(([id, sprint]) => ({
              title: sprint.title,
              businessPoints: Number(sprint.businessPoints) || 0,
              devPoints: Number(sprint.devPoints) || 0,
              startDate: sprint.startDate,
              endDate: sprint.endDate || sprint.estimatedEndDate
            }));

            // Filter sprints that have activity in the selected year
            const sprints = allSprints.filter(sprint => {
              const startDate = sprint.startDate ? new Date(sprint.startDate) : null;
              const endDate = sprint.endDate ? new Date(sprint.endDate) : null;

              if (!startDate && !endDate) return false;

              const startYear = startDate ? startDate.getFullYear() : null;
              const endYear = endDate ? endDate.getFullYear() : null;

              // Sprint is in year if it starts, ends, or spans the year
              const startsInYear = startYear === selectedYear;
              const endsInYear = endYear === selectedYear;
              const spansYear = startYear && endYear && startYear < selectedYear && endYear > selectedYear;

              return startsInYear || endsInYear || spansYear;
            });

            // Get bugs data to calculate bugs by sprint
            const bugsRef = ref(database, `/cards/${project.id}/BUGS_${project.id}`);
            const bugsSnapshot = await get(bugsRef);
            const bugs = bugsSnapshot.exists() ? Object.values(bugsSnapshot.val()) : [];

            // Calculate bugs resolved by sprint
            const bugsBySprint = sprints.map((sprint, idx) => {
              if (!sprint.startDate || !sprint.endDate) return 0;

              const start = new Date(sprint.startDate);
              const end = new Date(sprint.endDate);

              const bugsInSprint = bugs.filter(bug => {
                const bugEnd = bug.endDate || bug.desiredDate || bug.estimatedEndDate;
                if (!bugEnd) return false;

                const bugEndDate = new Date(bugEnd);
                return bugEndDate >= start && bugEndDate <= end;
              });

              return bugsInSprint.length;
            });

            const chartWrapper = document.createElement('div');
            chartWrapper.className = 'chart-wrapper';
            chartWrapper.innerHTML = `
              <h3 class="chart-title" style="color: var(--project-color-${index + 1})">${project.name} (${selectedYear})</h3>
              <sprint-points-chart
                class="project-sprint-chart"
                data-project-index="${index}">
              </sprint-points-chart>
            `;
            container.appendChild(chartWrapper);

            // Set the properties after the element is in the DOM
            const sprintChart = chartWrapper.querySelector('sprint-points-chart');
            if (sprintChart) {
              if (sprints.length === 0) {
                chartWrapper.querySelector('sprint-points-chart').remove();
                chartWrapper.insertAdjacentHTML('beforeend', `<div class="no-data-message">No hay sprints con actividad en ${selectedYear}</div>`);
              } else {
                sprintChart.sprints = sprints;
                sprintChart.bugsBySprint = bugsBySprint;
              }
            }
          } else {
const chartWrapper = document.createElement('div');
            chartWrapper.className = 'chart-wrapper';
            chartWrapper.innerHTML = `
              <h3 class="chart-title" style="color: var(--project-color-${index + 1})">${project.name}</h3>
              <div class="no-data-message">No sprint data available for this project</div>
            `;
            container.appendChild(chartWrapper);
          }
          
        } catch (error) {
const chartWrapper = document.createElement('div');
          chartWrapper.className = 'chart-wrapper';
          chartWrapper.innerHTML = `
            <h3 class="chart-title" style="color: var(--project-color-${index + 1})">${project.name}</h3>
            <div class="error-message">Error loading sprint data for this project</div>
          `;
          container.appendChild(chartWrapper);
        }
      }
    }

    async updateDeveloperMetrics() {
      const container = document.getElementById('developer-metrics-container');
      if (!container) {
        return;
      }

      if (this.selectedProjects.length === 0) {
        container.innerHTML = '<div class="no-projects-message">Select up to 3 projects to view developer metrics</div>';
        return;
      }

      container.innerHTML = '<div class="no-projects-message">Calculating developer metrics...</div>';

      try {
        const { database, ref, get } = await import('/firebase-config.js');
        const selectedYear = this.selectedYear;

        // Load developers data for name resolution
        let developersMap = new Map();
        try {
          const developersRef = ref(database, '/data/developers');
          const developersSnapshot = await get(developersRef);
          if (developersSnapshot.exists()) {
            const developersData = developersSnapshot.val();
            Object.entries(developersData).forEach(([key, dev]) => {
              // Map by ID (dev_XXX)
              if (dev.id) {
                developersMap.set(dev.id, dev.name || dev.id);
              }
              // Also map by the key itself
              developersMap.set(key, dev.name || key);
            });
          }
        } catch (devError) {
          console.warn('Could not load developers data:', devError);
        }

        this._developersMap = developersMap;

        const projectData = await Promise.all(this.selectedProjects.map(async (project) => {
          const tasksRef = ref(database, `/cards/${project.id}/TASKS_${project.id}`);
          const tasksSnapshot = await get(tasksRef);
          const tasksData = tasksSnapshot.exists() ? tasksSnapshot.val() : {};
          const allTasks = Object.entries(tasksData).map(([id, task]) => ({
            projectId: project.id,
            projectName: project.name || project.id,
            id,
            cardId: task.cardId || id,
            title: task.title || 'Sin título',
            status: task.status || '',
            developer: task.developer || '',
            businessPoints: Number(task.businessPoints) || 0,
            devPoints: Number(task.devPoints) || 0,
            startDate: task.startDate || '',
            endDate: task.endDate || '',
            sprintId: task.sprint || '',
            blockedByBusiness: Boolean(task.blockedByBusiness),
            blockedByDevelopment: Boolean(task.blockedByDevelopment)
          }));

          // Filter tasks by year
          const tasks = allTasks.filter(task => {
            const startDate = task.startDate ? new Date(task.startDate) : null;
            const endDate = task.endDate ? new Date(task.endDate) : null;

            // If no dates, include the task (could be in backlog)
            if (!startDate && !endDate) return true;

            const startYear = startDate ? startDate.getFullYear() : null;
            const endYear = endDate ? endDate.getFullYear() : null;

            // Task is in year if it starts, ends, or spans the year
            const startsInYear = startYear === selectedYear;
            const endsInYear = endYear === selectedYear;
            const spansYear = startYear && endYear && startYear < selectedYear && endYear > selectedYear;
            const ongoingInYear = startYear && !endYear && startYear <= selectedYear;

            return startsInYear || endsInYear || spansYear || ongoingInYear;
          });

          let sprints = {};
          try {
            const sprintsRef = ref(database, `/cards/${project.id}/SPRINTS_${project.id}`);
            const sprintsSnapshot = await get(sprintsRef);
            if (sprintsSnapshot.exists()) {
              sprints = sprintsSnapshot.val();
            }
          } catch (sprintError) {
          }

          return { project, tasks, sprints };
        }));

        const summaryMetrics = this._buildDeveloperSummaryMetrics(projectData);
        const sprintMetrics = this._buildDeveloperSprintMetrics(projectData);

        this.developerSprintMetrics = sprintMetrics;
        if (!this.developerSprintFilter) {
          this.developerSprintFilter = { developer: 'all', sprint: 'all' };
        }

        const availableDevelopers = new Set((sprintMetrics?.developers || []).map(option => option.value));
        if (this.developerSprintFilter.developer !== 'all' && !availableDevelopers.has(this.developerSprintFilter.developer)) {
          this.developerSprintFilter.developer = 'all';
        }

        const availableSprints = new Set((sprintMetrics?.sprints || []).map(option => option.value));
        if (this.developerSprintFilter.sprint !== 'all' && !availableSprints.has(this.developerSprintFilter.sprint)) {
          this.developerSprintFilter.sprint = 'all';
        }

        container.innerHTML = this._renderDeveloperMetrics(summaryMetrics, sprintMetrics);
        this._attachDeveloperMetricsEvents();
        this._applyDeveloperMetricsView();
        if (this.developerMetricsView === 'sprint') {
          this._refreshDeveloperSprintChart();
        } else {
          // Preload chart data so switching to the sprint view feels instant
          this._refreshDeveloperSprintChart();
        }
      } catch (error) {
container.innerHTML = '<div class="error-message">Error calculating developer metrics</div>';
      }
    }

    _buildDeveloperSummaryMetrics(projectData) {
      const metricsByDeveloper = new Map();
      const developersMap = this._developersMap || new Map();

      projectData.forEach(({ project, tasks }) => {
        tasks.forEach(task => {
          const rawDeveloper = (task.developer || '').trim();

          // Check if it's unassigned - include many variations
          const unassignedValues = ['', '""', "''", 'unassigned', 'sin asignar', 'no developer assigned', 'not assigned', 'null', 'undefined', 'n/a', 'na', 'none', '-', 'pending', 'tbd'];
          const isUnassigned = !rawDeveloper || unassignedValues.includes(rawDeveloper.toLowerCase()) || unassignedValues.includes(rawDeveloper);

          let developerKey, developerName, developerEmail;

          if (isUnassigned) {
            developerKey = 'developer:unassigned';
            developerName = 'Sin asignar';
            developerEmail = '';
          } else {
            // Try to resolve from developers map (for dev_XXX IDs)
            const resolvedName = developersMap.get(rawDeveloper);

            if (resolvedName && resolvedName !== rawDeveloper) {
              // Found in map - use resolved name
              developerKey = rawDeveloper; // Use the ID as key
              developerName = resolvedName;
              developerEmail = '';
            } else {
              // Not in map - use normalizer
              const normalizedDeveloper = normalizeDeveloperEntry(rawDeveloper);
              developerKey = getDeveloperKey(rawDeveloper) || `developer:${rawDeveloper.toLowerCase()}`;
              developerName = normalizedDeveloper.name || this._formatNameFromEmail(normalizedDeveloper.email) || rawDeveloper;
              developerEmail = normalizedDeveloper.email || normalizedDeveloper.sourceEmail || '';
            }
          }

          if (!metricsByDeveloper.has(developerKey)) {
            metricsByDeveloper.set(developerKey, {
              developerKey,
              developer: developerName,
              email: developerEmail,
              projects: new Set(),
              totalAssigned: 0,
              completed: 0,
              inProgress: 0,
              blocked: 0,
              completedBusinessPoints: 0,
              completedDevPoints: 0,
              totalBusinessPoints: 0,
              totalDevPoints: 0,
              totalCycleDays: 0,
              cycleSamples: 0
            });
          }

          const stats = metricsByDeveloper.get(developerKey);
          stats.projects.add(project.name || project.id);
          stats.totalAssigned += 1;

          const status = (task.status || '').toLowerCase();
          const businessPoints = Number(task.businessPoints) || 0;
          const devPoints = Number(task.devPoints) || 0;

          stats.totalBusinessPoints += businessPoints;
          stats.totalDevPoints += devPoints;

          if (status === 'in progress') {
            stats.inProgress += 1;
          }

          if (status === 'done') {
            stats.completed += 1;
            stats.completedBusinessPoints += businessPoints;
            stats.completedDevPoints += devPoints;

            const start = this._parseDateValue(task.startDate);
            const end = this._parseDateValue(task.endDate);
            if (start && end && end >= start) {
              const diffMs = end.getTime() - start.getTime();
              const diffDays = diffMs / (1000 * 60 * 60 * 24);
              stats.totalCycleDays += diffDays;
              stats.cycleSamples += 1;
            }
          }

          if (this._isTaskBlocked(task)) {
            stats.blocked += 1;
          }
        });
      });

      const rows = Array.from(metricsByDeveloper.values()).map(stats => {
        const avgCycle = stats.cycleSamples > 0 ? (stats.totalCycleDays / stats.cycleSamples) : null;
        return {
          developerKey: stats.developerKey,
          developer: stats.developer,
          email: stats.email,
          projects: Array.from(stats.projects),
          totalAssigned: stats.totalAssigned,
          completed: stats.completed,
          inProgress: stats.inProgress,
          blocked: stats.blocked,
          completedDevPoints: stats.completedDevPoints,
          completedBusinessPoints: stats.completedBusinessPoints,
          totalDevPoints: stats.totalDevPoints,
          avgCycle,
          cycleSamples: stats.cycleSamples
        };
      }).sort((a, b) => {
        if (b.completed !== a.completed) {
          return b.completed - a.completed;
        }
        return b.totalAssigned - a.totalAssigned;
      });

      const totals = rows.reduce((acc, row) => {
        acc.totalAssigned += row.totalAssigned;
        acc.completed += row.completed;
        acc.inProgress += row.inProgress;
        acc.blocked += row.blocked;
        acc.completedDevPoints += row.completedDevPoints;
        acc.completedBusinessPoints += row.completedBusinessPoints;
        if (row.avgCycle !== null && row.cycleSamples > 0) {
          acc.totalCycleDays += row.avgCycle * row.cycleSamples;
          acc.cycleSamples += row.cycleSamples;
        }
        return acc;
      }, {
        totalAssigned: 0,
        completed: 0,
        inProgress: 0,
        blocked: 0,
        completedDevPoints: 0,
        completedBusinessPoints: 0,
        totalCycleDays: 0,
        cycleSamples: 0
      });

      totals.avgCycle = totals.cycleSamples > 0
        ? totals.totalCycleDays / totals.cycleSamples
        : null;

      return { rows, totals };
    }

    _buildDeveloperSprintMetrics(projectData) {
      const metricsByKey = new Map();
      const developerMap = new Map();
      const sprintOptionMap = new Map();
      const developersMap = this._developersMap || new Map();

      projectData.forEach(({ project, tasks, sprints }) => {
        const sprintLookup = new Map(Object.entries(sprints || {}).map(([id, sprint]) => [id, sprint]));

        tasks.forEach(task => {
          const rawDeveloper = (task.developer || '').trim();

          // Check if it's unassigned - include many variations
          const unassignedValues = ['', '""', "''", 'unassigned', 'sin asignar', 'no developer assigned', 'not assigned', 'null', 'undefined', 'n/a', 'na', 'none', '-', 'pending', 'tbd'];
          const isUnassigned = !rawDeveloper || unassignedValues.includes(rawDeveloper.toLowerCase()) || unassignedValues.includes(rawDeveloper);

          let developerKey, developerName, developerEmail;

          if (isUnassigned) {
            developerKey = 'developer:unassigned';
            developerName = 'Sin asignar';
            developerEmail = '';
          } else {
            // Try to resolve from developers map (for dev_XXX IDs)
            const resolvedName = developersMap.get(rawDeveloper);

            if (resolvedName && resolvedName !== rawDeveloper) {
              // Found in map - use resolved name
              developerKey = rawDeveloper;
              developerName = resolvedName;
              developerEmail = '';
            } else {
              // Not in map - use normalizer
              const normalizedDeveloper = normalizeDeveloperEntry(rawDeveloper);
              developerKey = getDeveloperKey(rawDeveloper) || `developer:${rawDeveloper.toLowerCase()}`;
              developerName = normalizedDeveloper.name || this._formatNameFromEmail(normalizedDeveloper.email) || rawDeveloper;
              developerEmail = normalizedDeveloper.email || normalizedDeveloper.sourceEmail || '';
            }
          }

          developerMap.set(developerKey, { value: developerKey, label: developerName });

          const sprintId = (task.sprintId || task.sprint || '').trim();
          const sprintData = sprintLookup.get(sprintId) || null;
          const sprintTitle = sprintData?.title || (sprintId ? sprintId : 'Sin sprint');
          const sprintStart = sprintData?.startDate || sprintData?.estimatedStartDate || '';
          const sprintEnd = sprintData?.endDate || sprintData?.estimatedEndDate || '';
          const sprintKey = `${project.id}__${sprintId || '__none'}`;

          if (!sprintOptionMap.has(sprintKey)) {
            sprintOptionMap.set(sprintKey, {
              value: sprintKey,
              label: `${project.name || project.id} — ${sprintTitle}`,
              projectId: project.id,
              sprintId: sprintId || '',
              projectName: project.name || project.id,
              sprintTitle,
              startDate: sprintStart,
              endDate: sprintEnd
            });
          }

          const key = `${developerKey}__${sprintKey}`;
          if (!metricsByKey.has(key)) {
            metricsByKey.set(key, {
              developerKey,
              developerName,
              developerEmail,
              projectId: project.id,
              projectName: project.name || project.id,
              sprintKey,
              sprintId: sprintId || '',
              sprintTitle,
              sprintStart,
              sprintEnd,
              totalAssigned: 0,
              completed: 0,
              inProgress: 0,
              blocked: 0,
              completedBusinessPoints: 0,
              completedDevPoints: 0,
              totalBusinessPoints: 0,
              totalDevPoints: 0,
              totalCycleDays: 0,
              cycleSamples: 0
            });
          }

          const stats = metricsByKey.get(key);
          stats.totalAssigned += 1;

          const status = (task.status || '').toLowerCase();
          const businessPoints = Number(task.businessPoints) || 0;
          const devPoints = Number(task.devPoints) || 0;

          stats.totalBusinessPoints += businessPoints;
          stats.totalDevPoints += devPoints;

          if (status === 'in progress') {
            stats.inProgress += 1;
          }

          if (status === 'done') {
            stats.completed += 1;
            stats.completedBusinessPoints += businessPoints;
            stats.completedDevPoints += devPoints;

            const start = this._parseDateValue(task.startDate);
            const end = this._parseDateValue(task.endDate);
            if (start && end && end >= start) {
              const diffDays = (end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24);
              stats.totalCycleDays += diffDays;
              stats.cycleSamples += 1;
            }
          }

          if (this._isTaskBlocked(task)) {
            stats.blocked += 1;
          }
        });
      });

      const rows = Array.from(metricsByKey.values()).map(stats => {
        const avgCycle = stats.cycleSamples > 0 ? (stats.totalCycleDays / stats.cycleSamples) : null;
        return {
          developerKey: stats.developerKey,
          developer: stats.developerName,
          developerEmail: stats.developerEmail,
          projectId: stats.projectId,
          projectName: stats.projectName,
          sprintKey: stats.sprintKey,
          sprintId: stats.sprintId,
          sprintTitle: stats.sprintTitle,
          sprintStart: stats.sprintStart,
          sprintEnd: stats.sprintEnd,
          totalAssigned: stats.totalAssigned,
          completed: stats.completed,
          inProgress: stats.inProgress,
          blocked: stats.blocked,
          completedDevPoints: stats.completedDevPoints,
          completedBusinessPoints: stats.completedBusinessPoints,
          avgCycle,
          cycleSamples: stats.cycleSamples
        };
      }).sort((a, b) => {
        const devCompare = a.developer.localeCompare(b.developer, 'es', { sensitivity: 'base' });
        if (devCompare !== 0) return devCompare;

        const dateA = a.sprintStart ? new Date(a.sprintStart).getTime() : Number.MAX_SAFE_INTEGER;
        const dateB = b.sprintStart ? new Date(b.sprintStart).getTime() : Number.MAX_SAFE_INTEGER;
        if (dateA !== dateB) return dateA - dateB;

        return a.sprintTitle.localeCompare(b.sprintTitle, 'es', { sensitivity: 'base' });
      });

      const totals = rows.reduce((acc, row) => {
        acc.totalAssigned += row.totalAssigned;
        acc.completed += row.completed;
        acc.inProgress += row.inProgress;
        acc.blocked += row.blocked;
        acc.completedDevPoints += row.completedDevPoints;
        acc.completedBusinessPoints += row.completedBusinessPoints;
        if (row.avgCycle !== null && row.cycleSamples > 0) {
          acc.totalCycleDays += row.avgCycle * row.cycleSamples;
          acc.cycleSamples += row.cycleSamples;
        }
        return acc;
      }, {
        totalAssigned: 0,
        completed: 0,
        inProgress: 0,
        blocked: 0,
        completedDevPoints: 0,
        completedBusinessPoints: 0,
        totalCycleDays: 0,
        cycleSamples: 0
      });

      totals.avgCycle = totals.cycleSamples > 0
        ? totals.totalCycleDays / totals.cycleSamples
        : null;

      return {
        rows,
        totals,
        developers: Array.from(developerMap.values()).sort((a, b) => a.label.localeCompare(b.label, 'es', { sensitivity: 'base' })),
        sprints: Array.from(sprintOptionMap.values()).sort((a, b) => a.label.localeCompare(b.label, 'es', { sensitivity: 'base' }))
      };
    }

    _renderDeveloperMetrics(summaryMetrics, sprintMetrics) {
