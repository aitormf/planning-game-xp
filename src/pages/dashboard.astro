---
import Layout from '../layouts/Layout.astro';
import { appShellRoutes, resolveAppShellPartial } from '../lib/app-shell-routes.js';

const shellRoute = Astro.url.pathname;
const shellPartial = resolveAppShellPartial(shellRoute);
---

<Layout
  title="Project Analytics Dashboard"
  shellRoute={shellRoute}
  shellPartial={shellPartial}
  shellRoutes={appShellRoutes}
>
  <noscript>
    <div style="padding: 1.5rem;">
      Esta pagina necesita JavaScript para cargar el contenido.
    </div>
  </noscript>
</Layout>
