      `;
    }

    _renderDeveloperSummaryTable(metrics) {
      const { rows, totals } = metrics;

      if (!rows || rows.length === 0) {
        return '<div class="no-data-message">No developer data available for the selected projects</div>';
      }

      const tableRows = rows.map(row => {
        const projectsLabel = row.projects.length === 1
          ? row.projects[0]
          : `${row.projects.length} projects`;
        const projectsTitle = row.projects.join(', ');

        return `
          <tr>
            <td>${row.developer}</td>
            <td title="${projectsTitle}">${projectsLabel}</td>
            <td>${this._formatMetric(row.totalAssigned)}</td>
            <td>${this._formatMetric(row.completed)}</td>
            <td>${this._formatMetric(row.inProgress)}</td>
            <td>${this._formatMetric(row.blocked)}</td>
            <td>${this._formatMetric(row.completedDevPoints)}</td>
            <td>${this._formatMetric(row.completedBusinessPoints)}</td>
            <td>${this._formatMetric(row.avgCycle, 1, '—')}</td>
          </tr>
        `;
      }).join('');

      const totalsRow = `
        <tr class="developer-metrics-total">
          <td>Total</td>
          <td>—</td>
          <td>${this._formatMetric(totals.totalAssigned)}</td>
          <td>${this._formatMetric(totals.completed)}</td>
          <td>${this._formatMetric(totals.inProgress)}</td>
          <td>${this._formatMetric(totals.blocked)}</td>
          <td>${this._formatMetric(totals.completedDevPoints)}</td>
          <td>${this._formatMetric(totals.completedBusinessPoints)}</td>
          <td>${this._formatMetric(totals.avgCycle, 1, '—')}</td>
        </tr>
      `;

      return `
        <div class="developer-metrics-summary">
          Métricas de ${this.selectedYear} para ${this.selectedProjects.length} proyecto(s).
        </div>
        <table class="developer-metrics-table">
          <thead>
            <tr>
              <th>Developer</th>
              <th>Projects</th>
              <th>Total Tasks</th>
              <th>Completed</th>
              <th>In Progress</th>
              <th>Blocked</th>
              <th>Dev Points (Done)</th>
              <th>Business Points (Done)</th>
              <th>Avg Cycle (days)</th>
            </tr>
          </thead>
          <tbody>
            ${tableRows}
          </tbody>
          <tfoot>
            ${totalsRow}
          </tfoot>
        </table>
      `;
    }

    _renderDeveloperSprintView(metrics) {
      if (!metrics || !metrics.rows || metrics.rows.length === 0) {
        return '<div class="no-data-message">No developer data available for the selected projects</div>';
      }

      const mode = this.developerSprintChartMode === 'pending' ? 'pending' : 'completed';
      const completedActive = mode === 'completed' ? 'active' : '';
      const pendingActive = mode === 'pending' ? 'active' : '';

      return `
        <div class="developer-sprint-chart-controls">
          <span class="developer-sprint-mode-label">Vista del sprint</span>
          <div class="metrics-view-toggle" role="tablist">
            <button id="developerSprintModeCompleted" data-mode="completed" class="metrics-view-button ${completedActive}" type="button">Completadas</button>
            <button id="developerSprintModePending" data-mode="pending" class="metrics-view-button ${pendingActive}" type="button">Pendientes</button>
          </div>
        </div>
        <div class="developer-sprint-chart-wrapper">
          <canvas id="developerSprintChartCanvas" aria-label="Gráfico de tareas y puntos de desarrollo por sprint" role="img"></canvas>
        </div>
        <div id="developerSprintChartEmpty" class="no-data-message developer-sprint-empty hidden">
          No hay datos para los filtros seleccionados
        </div>
        <div id="developerSprintChartSummary" class="developer-sprint-summary hidden"></div>
        <div id="developerSprintNoSprintContainer" class="developer-sprint-nosprint hidden"></div>
      `;
    }

    _filterDeveloperSprintRows(rows, filter = { developer: 'all', sprint: 'all' }) {
      return rows.filter(row => {
        const developerMatch = !filter.developer || filter.developer === 'all' || row.developerKey === filter.developer;
        const sprintMatch = !filter.sprint || filter.sprint === 'all' || row.sprintKey === filter.sprint;
        return developerMatch && sprintMatch;
      });
    }

    _buildDeveloperSprintChartData(metrics, filter = { developer: 'all', sprint: 'all' }, mode = 'completed') {
      const rows = metrics?.rows || [];
      const developerLookup = new Map((metrics?.developers || []).map(option => [option.value, option.label]));
      const filteredRows = this._filterDeveloperSprintRows(rows, filter);
      const developerLabel = filter?.developer === 'all'
        ? 'todos los developers'
        : (developerLookup.get(filter?.developer) || 'Sin developer');
      const normalizedMode = mode === 'pending' ? 'pending' : 'completed';
      const showDevelopers = filter?.developer === 'all';

      if (filteredRows.length === 0) {
        return {
          labels: [],
          primaryValues: [],
          secondaryValues: [],
          details: [],
          summaryText: '',
          developerLabel,
          reason: `No hay datos para ${developerLabel} en los proyectos seleccionados`,
          showDevelopers,
          mode: normalizedMode,
          primaryDatasetLabel: normalizedMode === 'pending' ? 'Tareas pendientes' : 'Tareas completadas',
          secondaryDatasetLabel: normalizedMode === 'pending' ? 'Pts. desarrollo pendientes' : 'Pts. desarrollo completados',
          palette: normalizedMode === 'pending'
            ? {
                barBackground: 'rgba(251, 191, 36, 0.7)',
                barBorder: 'rgba(217, 119, 6, 0.9)',
                lineBorder: '#d97706',
                lineBackground: 'rgba(234, 179, 8, 0.25)'
              }
            : {
                barBackground: 'rgba(59, 130, 246, 0.65)',
                barBorder: 'rgba(37, 99, 235, 0.9)',
                lineBorder: '#ef4444',
                lineBackground: 'rgba(239, 68, 68, 0.25)'
              }
        };
      }

      const aggregated = new Map();

      filteredRows.forEach(row => {
        const sprintKey = row.sprintKey || `${row.projectId || 'project'}__${row.sprintId || '__none'}`;
        const sprintTitle = row.sprintTitle || 'Sin sprint';
        const label = `${row.projectName} — ${sprintTitle}`;
        const parsedStart = this._parseDateValue(row.sprintStart);
        const parsedEnd = this._parseDateValue(row.sprintEnd);
        const startTime = parsedStart ? parsedStart.getTime() : Number.POSITIVE_INFINITY;
        const endTime = parsedEnd ? parsedEnd.getTime() : Number.POSITIVE_INFINITY;
        const totalDevPoints = Number(row.totalDevPoints) || 0;
        const completedDevPoints = Number(row.completedDevPoints) || 0;

        let entry = aggregated.get(sprintKey);
        if (!entry) {
          entry = {
            key: sprintKey,
            label,
            projectName: row.projectName,
            sprintId: row.sprintId || '',
            sprintTitle,
            startDate: row.sprintStart || '',
            endDate: row.sprintEnd || '',
            startTime,
            endTime,
            tasks: 0,
            completed: 0,
            inProgress: 0,
            blocked: 0,
            devPoints: 0,
            totalDevPoints: 0,
            developers: new Set()
          };
          aggregated.set(sprintKey, entry);
        } else {
          if (startTime < entry.startTime) {
            entry.startTime = startTime;
            if (row.sprintStart) {
              entry.startDate = row.sprintStart;
            }
          }
          if (endTime < entry.endTime) {
            entry.endTime = endTime;
            if (row.sprintEnd) {
              entry.endDate = row.sprintEnd;
            }
          }
        }

        entry.tasks += row.totalAssigned;
        entry.completed += row.completed;
        entry.inProgress += row.inProgress;
        entry.blocked += row.blocked;
        entry.devPoints += completedDevPoints;
        entry.totalDevPoints += totalDevPoints;
        entry.developers.add(row.developer);
      });

      aggregated.forEach(entry => {
        entry.pending = Math.max(entry.tasks - entry.completed, 0);
        entry.pendingDevPoints = Math.max(entry.totalDevPoints - entry.devPoints, 0);
      });

      const allEntries = Array.from(aggregated.values());
      const sprintEntries = allEntries.filter(entry => entry.sprintId && entry.sprintId !== '__none');
      const noSprintEntries = allEntries.filter(entry => !entry.sprintId || entry.sprintId === '__none');

      const sorted = sprintEntries.sort((a, b) => {
        if (a.startTime !== b.startTime) {
          return a.startTime - b.startTime;
        }
        return a.label.localeCompare(b.label, 'es', { sensitivity: 'base' });
      });

      const totals = sorted.reduce((acc, entry) => {
        acc.tasks += entry.tasks;
        acc.completed += entry.completed;
        acc.inProgress += entry.inProgress;
        acc.blocked += entry.blocked;
        acc.devPoints += entry.devPoints;
        acc.totalDevPoints += entry.totalDevPoints;
        return acc;
      }, {
        tasks: 0,
        completed: 0,
        inProgress: 0,
        blocked: 0,
        devPoints: 0,
        totalDevPoints: 0
      });

      const totalsPendingTasks = Math.max(totals.tasks - totals.completed, 0);
      const totalsPendingDevPoints = Math.max(totals.totalDevPoints - totals.devPoints, 0);

      const summaryText = normalizedMode === 'pending'
        ? `Resumen para ${developerLabel}: ${this._formatMetric(totalsPendingTasks)} tareas pendientes de ${this._formatMetric(totals.tasks)} asignadas | ${this._formatMetric(totalsPendingDevPoints)} pts de desarrollo pendientes`
        : `Resumen para ${developerLabel}: ${this._formatMetric(totals.completed)} tareas completadas de ${this._formatMetric(totals.tasks)} asignadas | ${this._formatMetric(totals.devPoints)} pts de desarrollo completados`;

      const labels = sorted.map(entry => entry.label);
      const primaryValues = sorted.map(entry => normalizedMode === 'pending' ? entry.pending : entry.completed);
      const secondaryValues = sorted.map(entry => normalizedMode === 'pending' ? entry.pendingDevPoints : entry.devPoints);
      const primaryDatasetLabel = normalizedMode === 'pending' ? 'Tareas pendientes' : 'Tareas completadas';
      const secondaryDatasetLabel = normalizedMode === 'pending' ? 'Pts. desarrollo pendientes' : 'Pts. desarrollo completados';
      const palette = normalizedMode === 'pending'
        ? {
            barBackground: 'rgba(251, 191, 36, 0.7)',
            barBorder: 'rgba(217, 119, 6, 0.9)',
            lineBorder: '#d97706',
            lineBackground: 'rgba(234, 179, 8, 0.25)'
          }
        : {
            barBackground: 'rgba(59, 130, 246, 0.65)',
            barBorder: 'rgba(37, 99, 235, 0.9)',
            lineBorder: '#ef4444',
            lineBackground: 'rgba(239, 68, 68, 0.25)'
          };

      const details = sorted.map(entry => ({
        label: entry.label,
        projectName: entry.projectName,
        sprintTitle: entry.sprintTitle,
        schedule: this._formatSprintSchedule(entry.startDate, entry.endDate),
        totalTasks: entry.tasks,
        completed: entry.completed,
        pending: entry.pending,
        inProgress: entry.inProgress,
        blocked: entry.blocked,
        devPointsCompleted: entry.devPoints,
        devPointsPending: entry.pendingDevPoints,
        developers: Array.from(entry.developers).sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }))
      }));

      const noSprintTotals = noSprintEntries.reduce((acc, entry) => {
        acc.tasks += entry.tasks;
        acc.completed += entry.completed;
        acc.pending += entry.pending;
        acc.inProgress += entry.inProgress;
        acc.blocked += entry.blocked;
        acc.devPointsCompleted += entry.devPoints;
        acc.devPointsPending += entry.pendingDevPoints;
        entry.developers.forEach(dev => acc.developers.add(dev));
        acc.projects.add(entry.projectName);
        return acc;
      }, {
        tasks: 0,
        completed: 0,
        pending: 0,
        inProgress: 0,
        blocked: 0,
        devPointsCompleted: 0,
        devPointsPending: 0,
        developers: new Set(),
        projects: new Set()
      });

      const noSprintDetails = noSprintEntries.map(entry => ({
        projectName: entry.projectName,
        totalTasks: entry.tasks,
        completed: entry.completed,
        pending: entry.pending,
        inProgress: entry.inProgress,
        blocked: entry.blocked,
        devPointsCompleted: entry.devPoints,
        devPointsPending: entry.pendingDevPoints,
        developers: Array.from(entry.developers).sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }))
      })).sort((a, b) => a.projectName.localeCompare(b.projectName, 'es', { sensitivity: 'base' }));

      const noSprintSummaryText = noSprintEntries.length === 0
        ? ''
        : `Tareas sin sprint: ${this._formatMetric(noSprintTotals.tasks)} asignadas (${this._formatMetric(noSprintTotals.completed)} completadas, ${this._formatMetric(noSprintTotals.pending)} pendientes).`;

      return {
        labels,
        primaryValues,
        secondaryValues,
        primaryDatasetLabel,
        secondaryDatasetLabel,
        details,
        summaryText,
        developerLabel,
        reason: labels.length ? '' : (noSprintEntries.length
          ? 'No hay sprints con datos; todas las tareas para este filtro están sin sprint.'
          : ''),
        showDevelopers,
        mode: normalizedMode,
        palette,
        noSprintDetails,
        noSprintSummaryText,
        noSprintTotals: {
          tasks: noSprintTotals.tasks,
          completed: noSprintTotals.completed,
          pending: noSprintTotals.pending,
          inProgress: noSprintTotals.inProgress,
          blocked: noSprintTotals.blocked,
          devPointsCompleted: noSprintTotals.devPointsCompleted,
          devPointsPending: noSprintTotals.devPointsPending,
          developers: Array.from(noSprintTotals.developers).sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' })),
          projects: Array.from(noSprintTotals.projects).sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }))
        }
      };
    }

    async _ensureChartJsModule() {
      if (this._chartJsModule) {
        return this._chartJsModule;
      }
      try {
        const module = await import('https://cdn.jsdelivr.net/npm/chart.js@4.4.3/+esm');
        if (module?.registerables) {
          module.Chart.register(...module.registerables);
        }
        this._chartJsModule = module;
        return module;
      } catch (error) {
throw error;
      }
    }

    async _renderDeveloperSprintChart(canvas, chartData) {
      try {
        const { Chart } = await this._ensureChartJsModule();
        if (!Chart) {
return;
        }

        this._destroyDeveloperSprintChart();

        const context = canvas.getContext('2d');
        if (!context) {
return;
        }

        const details = chartData.details;
        const showDevelopers = chartData.showDevelopers;
        const formatMetric = (value, digits = 0) => this._formatMetric(value, digits);
        const isPendingMode = chartData.mode === 'pending';
        const palette = chartData.palette || {
          barBackground: 'rgba(59, 130, 246, 0.65)',
          barBorder: 'rgba(37, 99, 235, 0.9)',
          lineBorder: '#ef4444',
          lineBackground: 'rgba(239, 68, 68, 0.25)'
        };
        const primaryDatasetLabel = chartData.primaryDatasetLabel || (isPendingMode ? 'Tareas pendientes' : 'Tareas completadas');
        const secondaryDatasetLabel = chartData.secondaryDatasetLabel || (isPendingMode ? 'Pts. desarrollo pendientes' : 'Pts. desarrollo completados');

        this._developerSprintChart = new Chart(context, {
          type: 'bar',
          data: {
            labels: chartData.labels,
            datasets: [
              {
                type: 'bar',
                label: primaryDatasetLabel,
                data: chartData.primaryValues,
                backgroundColor: palette.barBackground,
                borderColor: palette.barBorder,
                borderWidth: 1,
                borderRadius: 6,
                maxBarThickness: 42,
                yAxisID: 'yTasks'
              },
              {
                type: 'line',
                label: secondaryDatasetLabel,
                data: chartData.secondaryValues,
                borderColor: palette.lineBorder,
                backgroundColor: palette.lineBackground,
                borderWidth: 3,
                pointRadius: 4,
                pointHoverRadius: 6,
                tension: 0.35,
                fill: false,
                yAxisID: 'yPoints'
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
              mode: 'index',
              intersect: false
            },
            scales: {
              x: {
                ticks: {
                  maxRotation: 45,
                  minRotation: 0,
                  autoSkip: false
                }
              },
              yTasks: {
                type: 'linear',
                position: 'left',
                beginAtZero: true,
                ticks: {
                  precision: 0
                },
                title: {
                  display: true,
                  text: primaryDatasetLabel
                }
              },
              yPoints: {
                type: 'linear',
                position: 'right',
                beginAtZero: true,
                grid: {
                  drawOnChartArea: false
                },
                title: {
                  display: true,
                  text: secondaryDatasetLabel
                }
              }
            },
            plugins: {
              legend: {
                position: 'top'
              },
              tooltip: {
                callbacks: {
                  title: (tooltipItems) => {
                    const index = tooltipItems?.[0]?.dataIndex ?? 0;
                    return details[index]?.label || '';
                  },
                  label: (context) => {
                    const value = formatMetric(context.parsed.y || 0);
                    const labelText = context.dataset?.label || '';
                    return labelText ? `${labelText}: ${value}` : value;
                  },
                  afterBody: (tooltipItems) => {
                    if (!tooltipItems?.length) {
                      return [];
                    }
                    const index = tooltipItems[0].dataIndex;
                    const detail = details[index];
                    if (!detail) {
                      return [];
                    }
                    const lines = [
                      `Asignadas: ${formatMetric(detail.totalTasks)}`
                    ];
                    if (detail.completed > 0) {
                      lines.push(`Completadas: ${formatMetric(detail.completed)}`);
                    }
                    if (detail.pending > 0) {
                      lines.push(`Pendientes: ${formatMetric(detail.pending)}`);
                    }
                    if (detail.inProgress > 0) {
                      lines.push(`En progreso: ${formatMetric(detail.inProgress)}`);
                    }
                    if (detail.blocked > 0) {
                      lines.push(`Bloqueadas: ${formatMetric(detail.blocked)}`);
                    }
                    if (!isPendingMode && detail.devPointsCompleted > 0) {
                      lines.push(`Pts dev completados: ${formatMetric(detail.devPointsCompleted)}`);
                    }
                    if (isPendingMode && detail.devPointsPending > 0) {
                      lines.push(`Pts dev pendientes: ${formatMetric(detail.devPointsPending)}`);
                    }
                    if (detail.schedule && detail.schedule !== '—') {
                      lines.push(`Período: ${detail.schedule}`);
                    }
                    if (showDevelopers && detail.developers.length) {
                      lines.push(`Developers: ${detail.developers.join(', ')}`);
                    }
                    return lines;
                  }
                }
              }
            }
          }
        });

        this._developerSprintChartMeta = {
          details,
          showDevelopers,
          developerLabel: chartData.developerLabel
        };
      } catch (error) {
const emptyMessage = document.getElementById('developerSprintChartEmpty');
        if (emptyMessage) {
          emptyMessage.textContent = 'No se pudo cargar el gráfico de métricas';
          emptyMessage.classList.remove('hidden');
        }
      }
    }

    _destroyDeveloperSprintChart() {
      if (this._developerSprintChart) {
        this._developerSprintChart.destroy();
        this._developerSprintChart = null;
        this._developerSprintChartMeta = null;
      }
    }

    _attachDeveloperMetricsEvents() {
      const summaryButton = document.getElementById('developerViewSummary');
      const sprintButton = document.getElementById('developerViewSprint');
      const developerFilter = document.getElementById('developerSprintFilterDeveloper');
      const sprintModeCompleted = document.getElementById('developerSprintModeCompleted');
      const sprintModePending = document.getElementById('developerSprintModePending');

      if (summaryButton) {
        summaryButton.addEventListener('click', () => {
          this.developerMetricsView = 'summary';
          this._applyDeveloperMetricsView();
          this._refreshDeveloperSprintChart();
        });
      }

      if (sprintButton) {
        sprintButton.addEventListener('click', () => {
          this.developerMetricsView = 'sprint';
          this._applyDeveloperMetricsView();
          this._refreshDeveloperSprintChart();
        });
      }

      if (developerFilter) {
        developerFilter.addEventListener('change', (event) => {
          this.developerSprintFilter = {
            developer: event.target.value,
            sprint: 'all'
          };
          this._refreshDeveloperSprintChart();
        });
      }

      if (sprintModeCompleted) {
        sprintModeCompleted.addEventListener('click', () => {
          this.developerSprintChartMode = 'completed';
          this._applyDeveloperSprintMode();
          this._refreshDeveloperSprintChart();
        });
      }

      if (sprintModePending) {
        sprintModePending.addEventListener('click', () => {
          this.developerSprintChartMode = 'pending';
          this._applyDeveloperSprintMode();
          this._refreshDeveloperSprintChart();
        });
      }

      this._applyDeveloperSprintMode();
    }

    _applyDeveloperMetricsView() {
      const summaryView = document.getElementById('developerSummaryView');
      const sprintView = document.getElementById('developerSprintView');
      const summaryButton = document.getElementById('developerViewSummary');
      const sprintButton = document.getElementById('developerViewSprint');
      const filterWrapper = document.querySelector('.developer-sprint-filters');

      if (!summaryView || !sprintView || !summaryButton || !sprintButton) {
        return;
      }

      if (this.developerMetricsView === 'sprint') {
        summaryView.classList.add('hidden');
        sprintView.classList.remove('hidden');
        summaryButton.classList.remove('active');
        sprintButton.classList.add('active');
        filterWrapper?.classList.remove('hidden');
        this._applyDeveloperSprintMode();
      } else {
        this.developerMetricsView = 'summary';
        sprintView.classList.add('hidden');
        summaryView.classList.remove('hidden');
        sprintButton.classList.remove('active');
        summaryButton.classList.add('active');
        filterWrapper?.classList.add('hidden');
      }
    }

    _applyDeveloperSprintMode() {
      const mode = this.developerSprintChartMode === 'pending' ? 'pending' : 'completed';
      const completedButton = document.getElementById('developerSprintModeCompleted');
      const pendingButton = document.getElementById('developerSprintModePending');

      if (completedButton) {
        completedButton.classList.toggle('active', mode === 'completed');
      }

      if (pendingButton) {
        pendingButton.classList.toggle('active', mode === 'pending');
      }
    }

    async _refreshDeveloperSprintChart() {
      if (!this.developerSprintMetrics) {
        return;
      }

      this._applyDeveloperSprintMode();

      const developerFilter = document.getElementById('developerSprintFilterDeveloper');
      if (developerFilter && this.developerSprintFilter?.developer) {
        developerFilter.value = this.developerSprintFilter.developer;
      }

      const canvas = document.getElementById('developerSprintChartCanvas');
      const emptyMessage = document.getElementById('developerSprintChartEmpty');
      const summaryElement = document.getElementById('developerSprintChartSummary');
      const noSprintContainer = document.getElementById('developerSprintNoSprintContainer');

      if (!canvas) {
        this._destroyDeveloperSprintChart();
        if (noSprintContainer) {
          noSprintContainer.classList.add('hidden');
          noSprintContainer.innerHTML = '';
        }
        return;
      }

      const chartData = this._buildDeveloperSprintChartData(
        this.developerSprintMetrics,
        this.developerSprintFilter,
        this.developerSprintChartMode
      );

      if (!chartData.labels.length) {
        this._destroyDeveloperSprintChart();
        if (emptyMessage) {
          emptyMessage.textContent = chartData.reason || 'No hay datos para los filtros seleccionados';
          emptyMessage.classList.remove('hidden');
        }
        if (summaryElement) {
          summaryElement.classList.add('hidden');
          summaryElement.textContent = '';
        }
        this._renderNoSprintSummary(noSprintContainer, chartData);
        return;
      }

      emptyMessage?.classList.add('hidden');

      await this._renderDeveloperSprintChart(canvas, chartData);

      if (summaryElement) {
        summaryElement.textContent = chartData.summaryText;
        summaryElement.classList.remove('hidden');
      }

      this._renderNoSprintSummary(noSprintContainer, chartData);
    }

    _renderNoSprintSummary(container, chartData) {
      if (!container) {
        return;
      }

      const details = chartData?.noSprintDetails || [];
      const summaryText = chartData?.noSprintSummaryText || '';

      if (!details.length) {
        container.classList.add('hidden');
        container.innerHTML = '';
        return;
      }

      const listItems = details.map(detail => {
        const developerList = detail.developers.length
          ? detail.developers.join(', ')
          : 'Sin asignar';
        const metrics = [
          `Asignadas: ${this._formatMetric(detail.totalTasks)}`,
          `Completadas: ${this._formatMetric(detail.completed)}`,
          `Pendientes: ${this._formatMetric(detail.pending)}`
        ];
        if (detail.devPointsCompleted > 0) {
          metrics.push(`Pts dev completados: ${this._formatMetric(detail.devPointsCompleted)}`);
        }
        if (detail.devPointsPending > 0) {
          metrics.push(`Pts dev pendientes: ${this._formatMetric(detail.devPointsPending)}`);
        }
        return `<li><strong>${detail.projectName}</strong> — ${metrics.join(' · ')} · Developers: ${developerList}</li>`;
      }).join('');

      container.innerHTML = `
        <h4>Tareas sin sprint</h4>
        <p>${summaryText}</p>
        <ul>
          ${listItems}
        </ul>
      `;
      container.classList.remove('hidden');
    }

    _formatSprintSchedule(start, end) {
      const hasStart = Boolean(start);
      const hasEnd = Boolean(end);

      if (!hasStart && !hasEnd) {
        return '—';
      }

      const formattedStart = hasStart ? this._formatDateForLabel(start) : 'Sin fecha';
      const formattedEnd = hasEnd ? this._formatDateForLabel(end) : 'Sin fecha';

      if (hasStart && hasEnd) {
        return `${formattedStart} → ${formattedEnd}`;
      }

      if (hasStart) {
        return `Desde ${formattedStart}`;
      }

      return `Hasta ${formattedEnd}`;
    }

    _formatDateForLabel(value) {
      const parsed = this._parseDateValue(value);
      if (!parsed) {
        return '—';
      }

      return parsed.toLocaleDateString('es-ES', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      });
    }

    _formatMetric(value, digits = 0, fallback = '0') {
      if (value === null || value === undefined || Number.isNaN(value)) {
        return fallback;
      }
      return Number(value).toLocaleString('es-ES', {
        minimumFractionDigits: digits,
        maximumFractionDigits: digits
      });
    }

    _formatNameFromEmail(email) {
      if (!email || typeof email !== 'string') {
        return email || '';
      }
      const localPart = email.split('@')[0] || email;
      let cleaned = localPart.replace(/#ext#/gi, '');
      cleaned = cleaned.replace(/[._-]+/g, ' ');
      cleaned = cleaned.replace(/\s+/g, ' ').trim();
      if (!cleaned) {
        return email;
      }
      return cleaned.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
    }

    _parseDateValue(value) {
      if (!value) {
        return null;
      }

      if (value instanceof Date) {
        return Number.isNaN(value.getTime()) ? null : value;
      }

      const raw = String(value).trim();
      if (!raw) {
        return null;
      }

      let parsed = new Date(raw);
      if (!Number.isNaN(parsed.getTime())) {
        return parsed;
      }

      if (raw.includes('/')) {
        const [day, month, year] = raw.split('/');
        if (day && month && year) {
          const normalizedYear = year.length === 2 ? `20${year}` : year;
          const iso = `${normalizedYear.padStart(4, '0')}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
          parsed = new Date(iso);
          if (!Number.isNaN(parsed.getTime())) {
            return parsed;
          }
        }
      }

      return null;
    }

    _isTaskBlocked(task) {
      if (!task) {
        return false;
      }
      const status = (task.status || '').toLowerCase();
      return status.includes('block') || Boolean(task.blockedByBusiness) || Boolean(task.blockedByDevelopment);
    }

  }

  // Initialize dashboard when DOM is ready
  document.addEventListener('astro:page-load', async () => {
    
    // Initialize dashboard controller immediately
    // The MultiProjectSelector will handle auth state internally
    new DashboardController();
  });
</script>

