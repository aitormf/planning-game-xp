---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <div class="landing-container">
    <div class="hero-section">
      <img src="/images/icono_PGame.png" alt="Planning Game" class="hero-logo" />
      <h1 class="hero-title">Planning Game<span class="xp">XP</span></h1>
      <p class="hero-subtitle">Gestión ágil de proyectos con prácticas eXtreme Programming</p>

      <div class="cta-buttons">
        <a href="/projects" class="cta-primary" data-astro-reload>Ver Proyectos</a>
        <a href="/doc/" class="cta-secondary" data-astro-reload>Documentación</a>
      </div>

      <div class="features">
        <div class="feature">
          <div class="feature-icon">📋</div>
          <h3>Gestión de Tareas</h3>
          <p>Organiza user stories, bugs y epics con tableros Kanban</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🚀</div>
          <h3>Sprints</h3>
          <p>Planifica y gestiona sprints con puntos de desarrollo y negocio</p>
        </div>
        <div class="feature">
          <div class="feature-icon">👥</div>
          <h3>Colaboración</h3>
          <p>Trabajo en equipo en tiempo real con notificaciones push</p>
        </div>
        <div class="feature">
          <div class="feature-icon">📊</div>
          <h3>Métricas</h3>
          <p>Dashboards y gráficos de progreso para seguimiento de proyectos</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .landing-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200px);
    padding: 2rem;
  }

  .hero-section {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-logo {
    width: 100px;
    height: auto;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    color: var(--brand-primary, #6366f1);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .hero-title .xp {
    font-weight: 700;
    color: var(--brand-secondary, #10b981);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-muted, #64748b);
    margin: 0 0 2.5rem;
    font-weight: 400;
  }

  .cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 3.5rem;
  }

  .cta-primary,
  .cta-secondary {
    padding: 0.75rem 1.75rem;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .cta-primary {
    background: var(--brand-primary, #6366f1);
    color: white;
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.25);
  }

  .cta-primary:hover {
    background: var(--brand-primary-hover, #4f46e5);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35);
  }

  .cta-secondary {
    background: var(--bg-primary, white);
    color: var(--brand-primary, #6366f1);
    border: 1px solid var(--brand-primary, #6366f1);
  }

  .cta-secondary:hover {
    background: rgba(99, 102, 241, 0.06);
  }

  .features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .feature {
    background: var(--bg-primary, white);
    padding: 1.25rem;
    border-radius: 12px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    border: 1px solid var(--border-subtle, #e2e8f0);
    flex: 0 1 200px;
    min-width: 180px;
  }

  .feature:hover {
    border-color: var(--brand-primary, #6366f1);
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.1);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .feature h3 {
    font-size: 0.9rem;
    color: var(--text-primary, #0f172a);
    margin: 0 0 0.35rem;
    font-weight: 600;
  }

  .feature p {
    font-size: 0.8rem;
    color: var(--text-muted, #64748b);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .cta-primary,
    .cta-secondary {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }

    .feature {
      flex: 1 1 100%;
    }
  }
</style>
