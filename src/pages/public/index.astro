---
// Public read-only view — real-time via Firebase RTDB listeners
// projectId and token are read from URL query params via client JS
const fbConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  databaseURL: import.meta.env.PUBLIC_FIREBASE_DATABASE_URL,
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <script is:inline>
    // FOUC prevention: apply saved theme before first paint
    (function(){var t=localStorage.getItem('pg-public-theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Board</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/png" href="/images/icono_PGame.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --font: 'DM Sans', system-ui, sans-serif;
      --mono: 'JetBrains Mono', monospace;
      --green: #22c55e;
      --amber: #eab308;
      --blue: #3b82f6;
      --rose: #ef4444;
      --violet: #8b5cf6;
      --accent: #6366f1;
    }

    /* Dark theme (default) */
    :root, [data-theme="dark"] {
      --bg: #06080f;
      --bg-raised: #0c1019;
      --bg-row-hover: #101525;
      --border: #151c2e;
      --border-active: #252e48;
      --text: #c8ceda;
      --text-secondary: #6b7590;
      --text-dim: #3d4560;
      --accent-muted: rgba(99, 102, 241, 0.12);
      --status-todo-bg: #1e2538; --status-todo-fg: #94a3b8; --status-todo-bd: #2a3450;
      --status-ip-bg: #0c1a3a; --status-ip-fg: #60a5fa; --status-ip-bd: #1e3a6e;
      --status-tv-bg: #1a1800; --status-tv-fg: #fbbf24; --status-tv-bd: #3d3500;
      --status-done-bg: #042f1a; --status-done-fg: #4ade80; --status-done-bd: #0a5c30;
      --status-blocked-bg: #2a0a0a; --status-blocked-fg: #f87171; --status-blocked-bd: #5c1a1a;
      --status-reopen-bg: #1a0a3a; --status-reopen-fg: #a78bfa; --status-reopen-bd: #2e1a5c;
    }

    /* Light theme */
    [data-theme="light"] {
      --bg: #f8f9fb;
      --bg-raised: #ffffff;
      --bg-row-hover: #f0f2f5;
      --border: #e2e5ea;
      --border-active: #c8cdd5;
      --text: #1a1d24;
      --text-secondary: #5c6370;
      --text-dim: #8b919e;
      --accent-muted: rgba(99, 102, 241, 0.08);
      --status-todo-bg: #eef1f5; --status-todo-fg: #475569; --status-todo-bd: #d8dde6;
      --status-ip-bg: #e8f0fe; --status-ip-fg: #1d4ed8; --status-ip-bd: #bfdbfe;
      --status-tv-bg: #fef9e7; --status-tv-fg: #a16207; --status-tv-bd: #fde68a;
      --status-done-bg: #e8f8ef; --status-done-fg: #15803d; --status-done-bd: #bbf7d0;
      --status-blocked-bg: #fef2f2; --status-blocked-fg: #dc2626; --status-blocked-bd: #fecaca;
      --status-reopen-bg: #f3f0ff; --status-reopen-fg: #7c3aed; --status-reopen-bd: #ddd6fe;
    }

    /* Auto: respect system preference when no explicit choice */
    @media (prefers-color-scheme: light) {
      :root:not([data-theme]) {
        --bg: #f8f9fb;
        --bg-raised: #ffffff;
        --bg-row-hover: #f0f2f5;
        --border: #e2e5ea;
        --border-active: #c8cdd5;
        --text: #1a1d24;
        --text-secondary: #5c6370;
        --text-dim: #8b919e;
        --accent-muted: rgba(99, 102, 241, 0.08);
        --status-todo-bg: #eef1f5; --status-todo-fg: #475569; --status-todo-bd: #d8dde6;
        --status-ip-bg: #e8f0fe; --status-ip-fg: #1d4ed8; --status-ip-bd: #bfdbfe;
        --status-tv-bg: #fef9e7; --status-tv-fg: #a16207; --status-tv-bd: #fde68a;
        --status-done-bg: #e8f8ef; --status-done-fg: #15803d; --status-done-bd: #bbf7d0;
        --status-blocked-bg: #fef2f2; --status-blocked-fg: #dc2626; --status-blocked-bd: #fecaca;
        --status-reopen-bg: #f3f0ff; --status-reopen-fg: #7c3aed; --status-reopen-bd: #ddd6fe;
      }
    }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.45;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    .shell {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.5rem 2rem;
    }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 0.65rem;
    }

    .topbar-logo {
      width: 24px;
      height: 24px;
      opacity: 0.7;
    }

    .topbar-title {
      font-size: 0.88rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .topbar-sep {
      color: var(--text-dim);
      font-weight: 300;
      margin: 0 0.15rem;
    }

    .topbar-subtitle {
      font-size: 0.88rem;
      font-weight: 400;
      color: var(--text-secondary);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .pill {
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 500;
      padding: 0.2rem 0.55rem;
      border-radius: 3px;
      letter-spacing: 0.02em;
    }

    .pill-live {
      color: var(--green);
      background: rgba(34, 197, 94, 0.1);
    }

    .pill-offline {
      color: var(--amber);
      background: rgba(234, 179, 8, 0.1);
    }

    .pill-error {
      color: var(--rose);
      background: rgba(239, 68, 68, 0.1);
    }

    .pill-count {
      color: var(--text-secondary);
      background: var(--bg-raised);
      border: 1px solid var(--border);
    }

    .btn-icon {
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 5px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-dim);
      cursor: pointer;
      font-size: 0.85rem;
      transition: border-color 0.12s, color 0.12s;
    }
    .btn-icon:hover { border-color: var(--border-active); color: var(--text-secondary); }
    .btn-icon:disabled { opacity: 0.35; cursor: default; }

    /* ── TOOLBAR ── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.65rem 0;
      border-bottom: 1px solid var(--border);
    }

    .tab-group {
      display: flex;
      gap: 0;
    }

    .tab {
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 500;
      padding: 0.4rem 0.85rem;
      border: none;
      background: none;
      color: var(--text-dim);
      cursor: pointer;
      position: relative;
      transition: color 0.12s;
    }
    .tab:hover { color: var(--text-secondary); }
    .tab.active { color: var(--text); }
    .tab.active::after {
      content: '';
      position: absolute;
      bottom: -0.65rem;
      left: 0.85rem;
      right: 0.85rem;
      height: 1.5px;
      background: var(--accent);
      border-radius: 1px;
    }

    .tab-count {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--text-dim);
      margin-left: 0.25rem;
      vertical-align: 1px;
    }

    .toolbar-meta {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--text-dim);
    }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    /* Column widths via nth-child since colgroup doesn't get scoped attrs */
    th:nth-child(1), td:nth-child(1) { white-space: nowrap; }
    th:nth-child(3), td:nth-child(3) { white-space: nowrap; }
    th:nth-child(4), td:nth-child(4) { white-space: nowrap; text-align: center; }
    th:nth-child(5), td:nth-child(5) { white-space: nowrap; text-align: center; }
    th:nth-child(6), td:nth-child(6) { white-space: nowrap; text-align: center; }
    th:nth-child(7), td:nth-child(7) { white-space: nowrap; text-align: right; }
    th:nth-child(8), td:nth-child(8) { white-space: nowrap; text-align: right; }

    thead { position: sticky; top: 0; z-index: 1; }

    th {
      font-family: var(--mono);
      font-size: 0.65rem;
      font-weight: 500;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      text-align: left;
      padding: 0.5rem 0.6rem;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: color 0.1s;
    }
    th:hover { color: var(--text-secondary); }
    th.sorted { color: var(--accent); }
    th .arr { font-size: 0.55rem; margin-left: 0.15rem; opacity: 0.7; }
    th.r { text-align: right; }

    td {
      padding: 0.45rem 0.6rem;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    tbody tr { transition: background 0.08s; }
    tbody tr:hover { background: var(--bg-row-hover); }

    .cell-id {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      white-space: nowrap;
    }

    .cell-title {
      font-size: 0.82rem;
      font-weight: 400;
      color: var(--text);
    }

    .cell-status {
      font-size: 0.72rem;
      font-weight: 600;
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      display: inline-block;
      line-height: 1.4;
      white-space: nowrap;
    }

    .s-todo { background: var(--status-todo-bg); color: var(--status-todo-fg); border: 1px solid var(--status-todo-bd); }
    .s-inprogress { background: var(--status-ip-bg); color: var(--status-ip-fg); border: 1px solid var(--status-ip-bd); }
    .s-tovalidate { background: var(--status-tv-bg); color: var(--status-tv-fg); border: 1px solid var(--status-tv-bd); }
    .s-done { background: var(--status-done-bg); color: var(--status-done-fg); border: 1px solid var(--status-done-bd); }
    .s-blocked { background: var(--status-blocked-bg); color: var(--status-blocked-fg); border: 1px solid var(--status-blocked-bd); }
    .s-reopened { background: var(--status-reopen-bg); color: var(--status-reopen-fg); border: 1px solid var(--status-reopen-bd); }

    .cell-num {
      font-family: var(--mono);
      font-size: 0.72rem;
      text-align: center;
      color: var(--text-secondary);
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .cell-date {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--text-dim);
      text-align: right;
    }

    /* ── STATES ── */
    .state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem 2rem;
      gap: 0.75rem;
    }

    .state-text { color: var(--text-dim); font-size: 0.85rem; }
    .state-error { color: var(--rose); font-size: 0.85rem; }

    .spinner {
      width: 20px;
      height: 20px;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── PAGER ── */
    .pager {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 0.75rem 0;
      border-top: 1px solid var(--border);
      margin-top: 0;
    }

    .pager-btn {
      font-family: var(--font);
      font-size: 0.78rem;
      padding: 0.35rem 0.75rem;
      border-radius: 5px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-secondary);
      cursor: pointer;
      transition: all 0.12s;
    }
    .pager-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--text); }
    .pager-btn:disabled { opacity: 0.3; cursor: default; }

    .pager-info {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--text-dim);
    }

    /* ── FOOTER ── */
    .footer {
      margin-top: 2rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-brand {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.7rem;
      color: var(--text-dim);
      text-decoration: none;
    }
    .footer-brand:hover { color: var(--text-secondary); }
    .footer-brand img { width: 14px; height: 14px; opacity: 0.5; }

    .footer-update {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--text-dim);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 700px) {
      .shell { padding: 1rem; }
      .topbar { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
      .hide-sm { display: none; }
      th:nth-child(1), td:nth-child(1) { width: 110px; min-width: 110px; }
      th:nth-child(3), td:nth-child(3) { width: 110px; min-width: 110px; }
    }

    /* ── ENTRY ANIMATION ── */
    .fade-up {
      opacity: 0;
      transform: translateY(6px);
      animation: fadeUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="topbar-left">
        <img src="/images/icono_PGame.png" alt="" class="topbar-logo" width="24" height="24">
        <span class="topbar-title" id="pTitle">Loading</span>
        <span class="topbar-sep">/</span>
        <span class="topbar-subtitle" id="pSub">Board</span>
      </div>
      <div class="topbar-right">
        <span class="pill pill-live" id="livePill">&#9679; live</span>
        <span class="pill pill-count" id="countPill">0</span>
        <button class="btn-icon" id="themeBtn" title="Toggle light/dark mode">&#9788;</button>
        <button class="btn-icon" id="refreshBtn" title="Refresh">&#8635;</button>
      </div>
    </header>

    <div class="toolbar">
      <div class="tab-group" id="tabs">
        <button class="tab active" data-type="task">Tasks <span class="tab-count" id="ct-task">0</span></button>
        <button class="tab" data-type="bug">Bugs <span class="tab-count" id="ct-bug">0</span></button>
        <button class="tab" data-type="epic">Epics <span class="tab-count" id="ct-epic">0</span></button>
      </div>
      <span class="toolbar-meta" id="lastUpdate"></span>
    </div>

    <div id="content">
      <div class="state"><div class="spinner"></div><span class="state-text">Loading project data...</span></div>
    </div>

    <footer class="footer">
      <a href="https://pgamexp.com" class="footer-brand" target="_blank" rel="noopener">
        <img src="/images/icono_PGame.png" alt="" width="14" height="14">
        Planning Game XP
      </a>
      <span class="footer-update" id="nextUpdate"></span>
    </footer>
  </div>

  <script define:vars={{ fbConfig }}>
    window.__fbConfig = fbConfig;
  </script>
  <script type="module">
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js';
    import { getDatabase, ref, onValue, off } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js';
    import { getAuth, signInWithCustomToken, signInAnonymously } from 'https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js';

    const P = new URLSearchParams(location.search);
    const PID = P.get('project') || '';
    const TOK = P.get('token') || '';

    const $ = (id) => document.getElementById(id);
    const content = $('content'), refreshBtn = $('refreshBtn'), tabs = $('tabs');
    const livePill = $('livePill');

    if (!PID) {
      content.innerHTML = '<div class="state"><span class="state-error">Missing ?project= parameter</span></div>';
    }

    // Firebase setup
    const app = initializeApp(window.__fbConfig);
    const db = getDatabase(app);
    const auth = getAuth(app);

    // State
    const data = { tasks: {}, bugs: {}, epics: {} };
    let type = 'task', sortBy = 'priority', sortAsc = true, page = 0;
    const PAGE_SIZE = 50;
    const listeners = [];

    function setStatus(mode, label) {
      livePill.className = 'pill ' + (mode === 'live' ? 'pill-live' : mode === 'offline' ? 'pill-offline' : 'pill-error');
      livePill.innerHTML = mode === 'live' ? '&#9679; live' : mode === 'offline' ? '&#9679; reconnecting' : '&#9679; error';
      $('lastUpdate').textContent = label || '';
    }

    function updateCounts() {
      const cards = allCards();
      $('countPill').textContent = cards.length;
      const typeMap = { tasks: 'task', bugs: 'bug', epics: 'epic' };
      for (const [section, t] of Object.entries(typeMap)) {
        const el = $(`ct-${t}`);
        if (el) el.textContent = Object.keys(data[section]).length;
      }
    }

    function allCards() {
      const cards = [];
      for (const [section, items] of Object.entries(data)) {
        const t = section === 'tasks' ? 'task' : section === 'bugs' ? 'bug' : 'epic';
        for (const card of Object.values(items)) {
          cards.push({ ...card, type: t });
        }
      }
      return cards;
    }

    function sc(s) {
      if (!s) return '';
      const n = s.toLowerCase().replace(/[^a-z]/g, '');
      if (n.includes('todo') || n.includes('created') || n.includes('assigned')) return 's-todo';
      if (n.includes('inprogress')) return 's-inprogress';
      if (n.includes('tovalidate')) return 's-tovalidate';
      if (n.includes('donevalidated') || n === 'done' || n.includes('fixed') || n.includes('closed') || n.includes('verified')) return 's-done';
      if (n.includes('blocked')) return 's-blocked';
      if (n.includes('reopened')) return 's-reopened';
      return '';
    }

    function fd(d) {
      if (!d) return '\u2014';
      const p = d.split('T')[0].split('-');
      return p.length === 3 ? `${p[2]}/${p[1]}` : d;
    }

    function sort(arr) {
      return [...arr].sort((a, b) => {
        let x = a[sortBy], y = b[sortBy];
        if (x == null && y == null) return 0;
        if (x == null) return 1;
        if (y == null) return -1;
        if (typeof x === 'string') x = x.toLowerCase();
        if (typeof y === 'string') y = y.toLowerCase();
        return x < y ? (sortAsc ? -1 : 1) : x > y ? (sortAsc ? 1 : -1) : 0;
      });
    }

    function render() {
      const cards = allCards();
      const all = sort(cards.filter(c => c.type === type));
      if (!all.length) {
        content.innerHTML = `<div class="state"><span class="state-text">No ${type}s in this project</span></div>`;
        return;
      }

      const totalPages = Math.ceil(all.length / PAGE_SIZE);
      if (page >= totalPages) page = totalPages - 1;
      if (page < 0) page = 0;
      const f = all.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE);
      const showing = `${page * PAGE_SIZE + 1}\u2013${Math.min((page + 1) * PAGE_SIZE, all.length)} of ${all.length}`;

      const a = (fld) => sortBy === fld ? `<span class="arr">${sortAsc ? '\u25B2' : '\u25BC'}</span>` : '';
      const s = (fld) => sortBy === fld ? 'sorted' : '';

      content.innerHTML = `
        <div class="table-wrap fade-up">
          <table>
            <thead><tr>
              <th class="${s('cardId')}" data-s="cardId">id${a('cardId')}</th>
              <th class="${s('title')}" data-s="title">title${a('title')}</th>
              <th class="${s('status')}" data-s="status">status${a('status')}</th>
              <th class="${s('priority')}" data-s="priority">pri${a('priority')}</th>
              <th class="${s('devPoints')}" data-s="devPoints">dev${a('devPoints')}</th>
              <th class="${s('businessPoints')}" data-s="businessPoints">biz${a('businessPoints')}</th>
              <th class="${s('startDate')} hide-sm" data-s="startDate">start${a('startDate')}</th>
              <th class="${s('endDate')} hide-sm" data-s="endDate">end${a('endDate')}</th>
            </tr></thead>
            <tbody>${f.map(c => `<tr>
              <td class="cell-id">${c.cardId || ''}</td>
              <td class="cell-title">${c.title || ''}</td>
              <td><span class="cell-status ${sc(c.status)}">${c.status || ''}</span></td>
              <td class="cell-num">${c.priority != null ? c.priority : '\u2014'}</td>
              <td class="cell-num">${c.devPoints != null ? c.devPoints : '\u2014'}</td>
              <td class="cell-num">${c.businessPoints != null ? c.businessPoints : '\u2014'}</td>
              <td class="cell-date hide-sm">${fd(c.startDate)}</td>
              <td class="cell-date hide-sm">${fd(c.endDate)}</td>
            </tr>`).join('')}</tbody>
          </table>
        </div>
        ${totalPages > 1 ? `<div class="pager">
          <button class="pager-btn" id="prevPage" ${page === 0 ? 'disabled' : ''}>&#8592; Prev</button>
          <span class="pager-info">${showing}</span>
          <button class="pager-btn" id="nextPage" ${page >= totalPages - 1 ? 'disabled' : ''}>Next &#8594;</button>
        </div>` : ''}`;

      const prevBtn = content.querySelector('#prevPage');
      const nextBtn = content.querySelector('#nextPage');
      if (prevBtn) prevBtn.addEventListener('click', () => { page--; render(); });
      if (nextBtn) nextBtn.addEventListener('click', () => { page++; render(); });

      content.querySelectorAll('th[data-s]').forEach(th => {
        th.addEventListener('click', () => {
          const f = th.getAttribute('data-s');
          if (sortBy === f) sortAsc = !sortAsc; else { sortBy = f; sortAsc = true; }
          page = 0;
          render();
        });
      });
    }

    tabs.addEventListener('click', e => {
      const t = e.target.closest('.tab');
      if (!t) return;
      tabs.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      t.classList.add('active');
      type = t.dataset.type;
      page = 0;
      render();
    });

    function subscribe(section) {
      const r = ref(db, `/publicViews/${PID}/${section}`);
      const unsub = onValue(r, (snap) => {
        data[section] = snap.val() || {};
        const now = new Date();
        setStatus('live', `Updated ${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`);
        $('nextUpdate').textContent = 'Real-time';
        updateCounts();
        render();
      }, (err) => {
        setStatus('error', err.message);
      });
      listeners.push({ ref: r, section });
    }

    // Connection state monitoring
    const connRef = ref(db, '.info/connected');
    onValue(connRef, (snap) => {
      if (snap.val() === true) {
        setStatus('live', 'Connected');
      } else {
        setStatus('offline', 'Reconnecting...');
      }
    });

    // Load project name via Cloud Function (one-time), then subscribe to RTDB
    async function init() {
      if (!PID) return;

      try {
        // For token-protected projects, authenticate first
        if (TOK) {
          const r = await fetch('/api/public/validate-token', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ projectId: PID, token: TOK })
          });
          const d = await r.json();
          if (!r.ok) throw new Error(d.error || 'Token validation failed');

          if (d.customToken) {
            await signInWithCustomToken(auth, d.customToken);
          }
          // If d.public === true, no auth needed
        }

        // Get project name from the existing API (lightweight, one-time)
        const nameUrl = `/api/public/${encodeURIComponent(PID)}/cards?type=epic` + (TOK ? `&token=${encodeURIComponent(TOK)}` : '');
        fetch(nameUrl).then(r => r.json()).then(d => {
          if (d.projectName) $('pTitle').textContent = d.projectName;
        }).catch(() => {
          $('pTitle').textContent = PID;
        });

        // Subscribe to real-time data
        subscribe('tasks');
        subscribe('bugs');
        subscribe('epics');
      } catch (e) {
        content.innerHTML = `<div class="state"><span class="state-error">${e.message}</span></div>`;
        setStatus('error', e.message);
      }
    }

    // Manual refresh just re-renders (data is already live)
    refreshBtn.addEventListener('click', () => { render(); });

    // Theme toggle (auto by default, persists to localStorage)
    const themeBtn = $('themeBtn');
    const THEME_KEY = 'pg-public-theme';
    function applyTheme(theme) {
      if (theme) {
        document.documentElement.setAttribute('data-theme', theme);
        themeBtn.textContent = theme === 'light' ? '\u263E' : '\u2606';
        themeBtn.title = theme === 'light' ? 'Switch to dark mode' : 'Switch to light mode';
      } else {
        document.documentElement.removeAttribute('data-theme');
        const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        themeBtn.textContent = isDark ? '\u2606' : '\u263E';
        themeBtn.title = 'Toggle light/dark mode';
      }
    }
    const savedTheme = localStorage.getItem(THEME_KEY);
    applyTheme(savedTheme);

    themeBtn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const isDark = current === 'dark' || (!current && window.matchMedia('(prefers-color-scheme: dark)').matches);
      const next = isDark ? 'light' : 'dark';
      localStorage.setItem(THEME_KEY, next);
      applyTheme(next);
    });

    init();
  </script>
</body>
</html>
