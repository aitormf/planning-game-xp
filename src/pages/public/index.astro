---
// Public read-only view — no auth, no Firebase SDK, no service workers
// projectId and token are read from URL query params via client JS
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Board</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/png" href="/images/icono_PGame.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #06080f;
      --bg-raised: #0c1019;
      --bg-row-hover: #101525;
      --border: #151c2e;
      --border-active: #252e48;
      --text: #c8ceda;
      --text-secondary: #6b7590;
      --text-dim: #3d4560;
      --accent: #6366f1;
      --accent-muted: rgba(99, 102, 241, 0.12);
      --green: #22c55e;
      --amber: #eab308;
      --blue: #3b82f6;
      --rose: #ef4444;
      --violet: #8b5cf6;
      --font: 'DM Sans', system-ui, sans-serif;
      --mono: 'JetBrains Mono', monospace;
    }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.45;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    .shell {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.5rem 2rem;
    }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 0.65rem;
    }

    .topbar-logo {
      width: 24px;
      height: 24px;
      opacity: 0.7;
    }

    .topbar-title {
      font-size: 0.88rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .topbar-sep {
      color: var(--text-dim);
      font-weight: 300;
      margin: 0 0.15rem;
    }

    .topbar-subtitle {
      font-size: 0.88rem;
      font-weight: 400;
      color: var(--text-secondary);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .pill {
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 500;
      padding: 0.2rem 0.55rem;
      border-radius: 3px;
      letter-spacing: 0.02em;
    }

    .pill-live {
      color: var(--green);
      background: rgba(34, 197, 94, 0.1);
    }

    .pill-count {
      color: var(--text-secondary);
      background: var(--bg-raised);
      border: 1px solid var(--border);
    }

    .btn-icon {
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 5px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-dim);
      cursor: pointer;
      font-size: 0.85rem;
      transition: border-color 0.12s, color 0.12s;
    }
    .btn-icon:hover { border-color: var(--border-active); color: var(--text-secondary); }
    .btn-icon:disabled { opacity: 0.35; cursor: default; }

    /* ── TOOLBAR ── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.65rem 0;
      border-bottom: 1px solid var(--border);
    }

    .tab-group {
      display: flex;
      gap: 0;
    }

    .tab {
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 500;
      padding: 0.4rem 0.85rem;
      border: none;
      background: none;
      color: var(--text-dim);
      cursor: pointer;
      position: relative;
      transition: color 0.12s;
    }
    .tab:hover { color: var(--text-secondary); }
    .tab.active { color: var(--text); }
    .tab.active::after {
      content: '';
      position: absolute;
      bottom: -0.65rem;
      left: 0.85rem;
      right: 0.85rem;
      height: 1.5px;
      background: var(--accent);
      border-radius: 1px;
    }

    .tab-count {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--text-dim);
      margin-left: 0.25rem;
      vertical-align: 1px;
    }

    .toolbar-meta {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--text-dim);
    }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    /* Column widths via nth-child since colgroup doesn't get scoped attrs */
    th:nth-child(1), td:nth-child(1) { width: 145px; min-width: 145px; }
    th:nth-child(3), td:nth-child(3) { width: 140px; min-width: 140px; }
    th:nth-child(4), td:nth-child(4) { width: 55px; }
    th:nth-child(5), td:nth-child(5) { width: 50px; }
    th:nth-child(6), td:nth-child(6) { width: 50px; }
    th:nth-child(7), td:nth-child(7) { width: 75px; }
    th:nth-child(8), td:nth-child(8) { width: 75px; }

    thead { position: sticky; top: 0; z-index: 1; }

    th {
      font-family: var(--mono);
      font-size: 0.65rem;
      font-weight: 500;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      text-align: left;
      padding: 0.5rem 0.6rem;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: color 0.1s;
    }
    th:hover { color: var(--text-secondary); }
    th.sorted { color: var(--accent); }
    th .arr { font-size: 0.55rem; margin-left: 0.15rem; opacity: 0.7; }
    th.r { text-align: right; }

    td {
      padding: 0.45rem 0.6rem;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    tbody tr { transition: background 0.08s; }
    tbody tr:hover { background: var(--bg-row-hover); }

    .cell-id {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      white-space: nowrap;
    }

    .cell-title {
      font-size: 0.82rem;
      font-weight: 400;
      color: var(--text);
    }

    .cell-status {
      font-size: 0.72rem;
      font-weight: 600;
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      display: inline-block;
      line-height: 1.4;
      white-space: nowrap;
    }

    .s-todo { background: #1e2538; color: #94a3b8; border: 1px solid #2a3450; }
    .s-inprogress { background: #0c1a3a; color: #60a5fa; border: 1px solid #1e3a6e; }
    .s-tovalidate { background: #1a1800; color: #fbbf24; border: 1px solid #3d3500; }
    .s-done { background: #042f1a; color: #4ade80; border: 1px solid #0a5c30; }
    .s-blocked { background: #2a0a0a; color: #f87171; border: 1px solid #5c1a1a; }
    .s-reopened { background: #1a0a3a; color: #a78bfa; border: 1px solid #2e1a5c; }

    .cell-num {
      font-family: var(--mono);
      font-size: 0.72rem;
      text-align: center;
      color: var(--text-secondary);
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .cell-date {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--text-dim);
      text-align: right;
    }

    /* ── STATES ── */
    .state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem 2rem;
      gap: 0.75rem;
    }

    .state-text { color: var(--text-dim); font-size: 0.85rem; }
    .state-error { color: var(--rose); font-size: 0.85rem; }

    .spinner {
      width: 20px;
      height: 20px;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── FOOTER ── */
    .footer {
      margin-top: 2rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-brand {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.7rem;
      color: var(--text-dim);
      text-decoration: none;
    }
    .footer-brand:hover { color: var(--text-secondary); }
    .footer-brand img { width: 14px; height: 14px; opacity: 0.5; }

    .footer-update {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--text-dim);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 700px) {
      .shell { padding: 1rem; }
      .topbar { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
      .hide-sm { display: none; }
      th:nth-child(1), td:nth-child(1) { width: 110px; min-width: 110px; }
      th:nth-child(3), td:nth-child(3) { width: 110px; min-width: 110px; }
    }

    /* ── ENTRY ANIMATION ── */
    .fade-up {
      opacity: 0;
      transform: translateY(6px);
      animation: fadeUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="topbar-left">
        <img src="/images/icono_PGame.png" alt="" class="topbar-logo" width="24" height="24">
        <span class="topbar-title" id="pTitle">Loading</span>
        <span class="topbar-sep">/</span>
        <span class="topbar-subtitle" id="pSub">Board</span>
      </div>
      <div class="topbar-right">
        <span class="pill pill-live" id="livePill">&#9679; live</span>
        <span class="pill pill-count" id="countPill">0</span>
        <button class="btn-icon" id="refreshBtn" title="Refresh">&#8635;</button>
      </div>
    </header>

    <div class="toolbar">
      <div class="tab-group" id="tabs">
        <button class="tab active" data-type="task">Tasks <span class="tab-count" id="ct-task">0</span></button>
        <button class="tab" data-type="bug">Bugs <span class="tab-count" id="ct-bug">0</span></button>
        <button class="tab" data-type="epic">Epics <span class="tab-count" id="ct-epic">0</span></button>
      </div>
      <span class="toolbar-meta" id="lastUpdate"></span>
    </div>

    <div id="content">
      <div class="state"><div class="spinner"></div><span class="state-text">Loading project data...</span></div>
    </div>

    <footer class="footer">
      <a href="https://pgamexp.com" class="footer-brand" target="_blank" rel="noopener">
        <img src="/images/icono_PGame.png" alt="" width="14" height="14">
        Planning Game XP
      </a>
      <span class="footer-update" id="nextUpdate"></span>
    </footer>
  </div>

  <script>
    const P = new URLSearchParams(location.search);
    const PID = P.get('project') || '';
    const TOK = P.get('token') || '';

    if (!PID) {
      document.getElementById('content').innerHTML =
        '<div class="state"><span class="state-error">Missing ?project= parameter</span></div>';
    }

    function apiUrl() {
      const t = TOK ? `?token=${encodeURIComponent(TOK)}` : '';
      const base = (location.hostname.includes('planning-game') || location.hostname.includes('pgamexp'))
        ? `/api/public/${encodeURIComponent(PID)}/cards${t}`
        : `https://europe-west1-planning-gamexp.cloudfunctions.net/publicProjectCards/${encodeURIComponent(PID)}/cards${t}`;
      return base;
    }

    let cards = [], type = 'task', sortBy = 'priority', sortAsc = true, timer = null;
    const $ = (id) => document.getElementById(id);
    const content = $('content'), refreshBtn = $('refreshBtn'), tabs = $('tabs');

    async function load() {
      try {
        refreshBtn.disabled = true;
        refreshBtn.textContent = '...';
        const r = await fetch(apiUrl());
        if (!r.ok) { const e = await r.json().catch(() => ({})); throw new Error(e.error || r.statusText); }
        const d = await r.json();
        cards = d.cards || [];

        $('pTitle').textContent = d.projectName || PID;
        $('countPill').textContent = cards.length;
        ['task','bug','epic'].forEach(t => {
          const el = $(`ct-${t}`);
          if (el) el.textContent = cards.filter(c => c.type === t).length;
        });

        const now = new Date();
        $('lastUpdate').textContent = `Updated ${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
        $('nextUpdate').textContent = `Auto-refresh in 60s`;

        render();
      } catch (e) {
        content.innerHTML = `<div class="state"><span class="state-error">${e.message}</span></div>`;
      } finally {
        refreshBtn.disabled = false;
        refreshBtn.textContent = '\u21BB';
      }
    }

    function sc(s) {
      if (!s) return '';
      const n = s.toLowerCase().replace(/[^a-z]/g, '');
      if (n.includes('todo') || n.includes('created') || n.includes('assigned')) return 's-todo';
      if (n.includes('inprogress')) return 's-inprogress';
      if (n.includes('tovalidate')) return 's-tovalidate';
      if (n.includes('donevalidated') || n === 'done' || n.includes('fixed') || n.includes('closed') || n.includes('verified')) return 's-done';
      if (n.includes('blocked')) return 's-blocked';
      if (n.includes('reopened')) return 's-reopened';
      return '';
    }

    function fd(d) {
      if (!d) return '\u2014';
      const p = d.split('T')[0].split('-');
      return p.length === 3 ? `${p[2]}/${p[1]}` : d;
    }

    function sort(arr) {
      return [...arr].sort((a, b) => {
        let x = a[sortBy], y = b[sortBy];
        if (x == null) x = sortAsc ? Infinity : -Infinity;
        if (y == null) y = sortAsc ? Infinity : -Infinity;
        if (typeof x === 'string') x = x.toLowerCase();
        if (typeof y === 'string') y = y.toLowerCase();
        return x < y ? (sortAsc ? -1 : 1) : x > y ? (sortAsc ? 1 : -1) : 0;
      });
    }

    function render() {
      const f = sort(cards.filter(c => c.type === type));
      if (!f.length) {
        content.innerHTML = `<div class="state"><span class="state-text">No ${type}s in this project</span></div>`;
        return;
      }

      const a = (fld) => sortBy === fld ? `<span class="arr">${sortAsc ? '\u25B2' : '\u25BC'}</span>` : '';
      const s = (fld) => sortBy === fld ? 'sorted' : '';

      content.innerHTML = `
        <div class="table-wrap fade-up">
          <table>
            <colgroup>
              <col class="col-id"><col class="col-title"><col class="col-status">
              <col class="col-pri"><col class="col-pts"><col class="col-pts">
              <col class="col-date"><col class="col-date">
            </colgroup>
            <thead><tr>
              <th class="${s('cardId')}" data-s="cardId">id${a('cardId')}</th>
              <th class="${s('title')}" data-s="title">title${a('title')}</th>
              <th class="${s('status')}" data-s="status">status${a('status')}</th>
              <th class="${s('priority')} r" data-s="priority">pri${a('priority')}</th>
              <th class="${s('devPoints')} r" data-s="devPoints">dev${a('devPoints')}</th>
              <th class="${s('businessPoints')} r" data-s="businessPoints">biz${a('businessPoints')}</th>
              <th class="${s('startDate')} r hide-sm" data-s="startDate">start${a('startDate')}</th>
              <th class="${s('endDate')} r hide-sm" data-s="endDate">end${a('endDate')}</th>
            </tr></thead>
            <tbody>${f.map(c => `<tr>
              <td class="cell-id">${c.cardId || ''}</td>
              <td class="cell-title">${c.title || ''}</td>
              <td><span class="cell-status ${sc(c.status)}">${c.status || ''}</span></td>
              <td class="cell-num">${c.priority != null ? c.priority : '\u2014'}</td>
              <td class="cell-num">${c.devPoints != null ? c.devPoints : '\u2014'}</td>
              <td class="cell-num">${c.businessPoints != null ? c.businessPoints : '\u2014'}</td>
              <td class="cell-date hide-sm">${fd(c.startDate)}</td>
              <td class="cell-date hide-sm">${fd(c.endDate)}</td>
            </tr>`).join('')}</tbody>
          </table>
        </div>`;

      content.querySelectorAll('th[data-s]').forEach(th => {
        th.addEventListener('click', () => {
          const f = th.getAttribute('data-s');
          if (sortBy === f) sortAsc = !sortAsc; else { sortBy = f; sortAsc = true; }
          render();
        });
      });
    }

    tabs.addEventListener('click', e => {
      const t = e.target.closest('.tab');
      if (!t) return;
      tabs.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      t.classList.add('active');
      type = t.dataset.type;
      render();
    });

    refreshBtn.addEventListener('click', load);
    load();
    timer = setInterval(load, 60000);
  </script>
</body>
</html>
