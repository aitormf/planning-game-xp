<script>
  // CRÍTICO: Establecer projectId ANTES de cualquier otra cosa
  // Este script es síncrono y se ejecuta inmediatamente
  (function() {
    const urlParams = new URLSearchParams(window.location.search);
    const projectId = urlParams.get('projectId') || '';

    // Establecer en todas las ubicaciones posibles
    window.currentProjectId = projectId;
    window.initialProjectId = projectId;
    document.body.dataset.projectId = projectId;

    // Add class to body for CSS-based hiding when no project
    if (!projectId) {
      document.body.classList.add('no-project-selected');
    }
  })();
</script>

<script>
  // Show "select project" message when DOM is ready
  document.addEventListener('astro:page-load', () => {
    if (!window.currentProjectId) {
      const noProjectMsg = document.getElementById('noProjectMessage');
      if (noProjectMsg) {
        noProjectMsg.style.display = 'flex';
      }
    }
  });

  // Navigate to selected project when changed from the selector
  document.addEventListener('project-changed', (e) => {
    const projectId = e.detail?.projectId;
    if (projectId) {
      const url = new URL(window.location);
      url.searchParams.set('projectId', projectId);
      if (window.appShellRouter?.navigate) {
        window.appShellRouter.navigate(url.toString());
      } else {
        window.location.href = url.toString();
      }
    }
  });
</script>

<script>
  // Variables globales para permisos
  let isResponsable = false;
  let currentUserRole = { isResponsable: false };
  let isYearReadOnly = false; // Para años anteriores en modo solo lectura

  // All tabs visible for authenticated users. Users/trash only for SuperAdmin, app only if projectHasApps.
  const ALL_TABS = ['sprints', 'epics', 'tasks', 'bugs', 'proposals', 'qa', 'adrs', 'devPlans'];
  const ADMIN_ONLY_TABS = ['users', 'trash'];
  let projectHasApps = false; // Controls App tab visibility

  // Show/hide tabs based on user role
  window.updateTabVisibility = function() {
    const allTabButtons = document.querySelectorAll('.tablinks');
    allTabButtons.forEach(tab => {
      const section = tab.dataset.section;
      // tasksGenerator visibility is managed by app-controller.js - don't override
      if (section === 'tasksGenerator') return;
      // Users and trash: SuperAdmin only (managed by app-controller.js)
      if (section === 'users' || section === 'trash') return;
      // App tab only visible if project has allowExecutables
      if (section === 'app') {
        tab.style.display = projectHasApps ? '' : 'none';
      } else {
        tab.style.display = ALL_TABS.includes(section) ? '' : 'none';
      }
    });

    // Controlar visibilidad de botones de creación/edición
    toggleEditButtons();

    // Notificar a todos los componentes sobre el cambio de permisos
    window.notifyPermissionsUpdate();
  };

  // Show/hide edit buttons based on user role and year
  function toggleEditButtons() {
    if (isYearReadOnly) {
      // Year is read-only: hide all edit buttons
      const editButtons = document.querySelectorAll('.add-button, .add-plan-button, .edit-button, .delete-button');
      editButtons.forEach(btn => { btn.style.display = 'none'; });
      return;
    }

    const editButtons = document.querySelectorAll('.add-button, .add-plan-button, .edit-button, .delete-button');
    editButtons.forEach(btn => {
      // Proposals and QA: always visible for all authenticated users
      if (btn.id === 'addProposalCard' || btn.id === 'addQACard') {
        btn.style.display = '';
      // Tasks and Bugs: visible for all authenticated users (developers can create)
      } else if (btn.id === 'addTaskCard' || btn.id === 'addBugCard') {
        btn.style.display = '';
      // Epics, Sprints, delete buttons: admin only
      } else if (btn.id === 'addEpicCard' || btn.id === 'addSprintCard') {
        btn.style.display = isResponsable ? '' : 'none';
      } else {
        // Other edit/delete buttons: admin only
        btn.style.display = isResponsable ? '' : 'none';
      }
    });
  }

  // Set user role and update UI accordingly
  window.setUserRole = function(userRole) {
    isResponsable = userRole.isResponsable || false;
    currentUserRole = userRole;
    window.currentUserRole = userRole;

    // Update tab visibility and buttons based on new role
    window.updateTabVisibility();
  };

  // Notify all components about permission changes
  window.notifyPermissionsUpdate = function() {
    const permissionsEvent = new CustomEvent('permissions-updated', {
      detail: {
        canEdit: true, // All authenticated users can edit (specific permissions checked per card type)
        userRole: currentUserRole,
        isResponsable
      },
      bubbles: true
    });

    document.dispatchEvent(permissionsEvent);
  };

  // Handler for component permission requests
  document.addEventListener('request-user-permissions', function(e) {
    const { requestId, cardType, cardId } = e.detail;

    const responseEvent = new CustomEvent('user-permissions-response', {
      detail: {
        requestId,
        canEdit: true, // All authenticated users can edit (card-level permissions checked separately)
        userRole: currentUserRole,
        isResponsable
      },
      bubbles: true
    });

    setTimeout(() => document.dispatchEvent(responseEvent), 0);
  });

  // Handler for TaskCard permissions
  document.addEventListener('request-task-permissions', function(e) {
    const { cardId, cardType, userEmail, createdBy, callback } = e.detail;

    // All authenticated users can edit tasks; admins can also delete
    const canEdit = !isYearReadOnly;
    const canDelete = isResponsable && !isYearReadOnly;

    const permissions = {
      canEdit,
      canSave: canEdit,
      canDelete,
      userRole: currentUserRole,
      isResponsable,
      isYearReadOnly
    };

    if (callback && typeof callback === 'function') {
      callback(permissions);
    }
  });

  // Handler for BugCard permissions
  document.addEventListener('request-bug-permissions', function(e) {
    const { cardId, cardType, userEmail, createdBy, callback } = e.detail;

    // All authenticated users can edit bugs; admins can delete any, owners can delete own
    const currentUserEmail = document.body.dataset.userEmail;
    const isOwner = createdBy && currentUserEmail && createdBy === currentUserEmail;
    const canEdit = !isYearReadOnly;
    const canDelete = (isResponsable || isOwner) && !isYearReadOnly;

    const permissions = {
      canEdit,
      canSave: canEdit,
      canDelete,
      userRole: currentUserRole,
      isResponsable,
      isYearReadOnly
    };

    if (callback && typeof callback === 'function') {
      callback(permissions);
    }
  });

  // Handler for cards with ownership logic (ProposalCard and QACard)
  document.addEventListener('request-ownership-permissions', function(e) {
    const { cardId, cardType, userEmail, createdBy, callback } = e.detail;

    const currentUserEmail = document.body.dataset.userEmail;
    const isOwner = createdBy && currentUserEmail && createdBy === currentUserEmail;

    // All authenticated users can edit their own proposals/QA; admins can edit all
    const canEdit = isResponsable || isOwner;

    const permissions = {
      canEdit,
      canSave: canEdit,
      canDelete: isResponsable || isOwner, // Owners can delete their own, admins can delete any
      canConvertToTask: canEdit,
      userRole: currentUserRole,
      isOwner,
      isAdmin: isResponsable
    };

    if (callback && typeof callback === 'function') {
      callback(permissions);
    }
  });

  // Handler for other card types (Sprint, Epic) - admin only
  document.addEventListener('request-card-permissions', function(e) {
    const { cardId, cardType, userEmail, createdBy, callback } = e.detail;

    // Epics and Sprints: only admins can edit
    const canEdit = isResponsable && !isYearReadOnly;

    const permissions = {
      canEdit,
      canSave: canEdit,
      canDelete: canEdit,
      userRole: currentUserRole,
      isResponsable,
      isYearReadOnly
    };

    if (callback && typeof callback === 'function') {
      callback(permissions);
    }
  });

  // Sistema de gestión de modales a nivel de aplicación
  class ModalStateManager {
    constructor() {
      this.expandedCards = new Map(); // elementId -> modalId
      this.modalStack = []; // Stack LIFO para modales anidados: [{ modalId, elementId, parentModalId? }]
      this.setupEventListeners();
    }

    // Añadir modal al stack LIFO
    pushModal(modalId, elementId, parentModalId = null) {
      const modalInfo = { modalId, elementId, parentModalId };
      this.modalStack.push(modalInfo);
}

    // Obtener el modal más reciente (top of stack)
    getTopModal() {
      return this.modalStack.length > 0 ? this.modalStack[this.modalStack.length - 1] : null;
    }

    // Remover modal del stack
    popModal() {
      if (this.modalStack.length > 0) {
        const removedModal = this.modalStack.pop();
return removedModal;
      }
      return null;
    }

    // Encontrar modal en stack por modalId
    findModalInStack(modalId) {
      return this.modalStack.find(modal => modal.modalId === modalId);
    }

    setupEventListeners() {
      // Escuchar solicitud de mostrar tareas de épica
      document.addEventListener('show-epic-tasks-requested', (e) => {
        const { epicId, epicTitle, projectId } = e.detail;
        this.handleShowEpicTasks(epicId, epicTitle, projectId);
      });

      // Escuchar cuando una card se expande
      document.addEventListener('card-expanded', (e) => {
        const { tagName, elementId } = e.detail;
// Si es una task-card que se expande, buscar su modal
        if (tagName === 'task-card') {
          setTimeout(() => {
            const modals = Array.from(document.querySelectorAll('app-modal'));
            const taskModal = modals.find(modal => 
              modal.querySelector(`task-card[id="${elementId}"]`)
            );
            
            if (taskModal) {
              const modalId = taskModal.getAttribute('modal-id');
              this.expandedCards.set(elementId, modalId);
}
          }, 50);
        }
      });

      // Escuchar cuando una card se guarda
      document.addEventListener('card-saved-successfully', (e) => {
        const { tagName, elementId } = e.detail;
// Si es una task-card que se guardó, cerrar SOLO el modal más reciente (LIFO)
        if (tagName === 'task-card') {
          const topModal = this.getTopModal();
if (topModal && topModal.elementId === elementId) {
            
            // Verificar que el modal existe en el DOM antes de cerrar
            const modalElement = document.querySelector(`app-modal[modal-id="${topModal.modalId}"]`);
document.dispatchEvent(new CustomEvent('close-modal', {
              bubbles: true,
              composed: true,
              detail: { modalId: topModal.modalId }
            }));
            
            // Remover del stack y limpiar registro
            this.popModal();
            this.expandedCards.delete(elementId);
          } else {
}
        }
      });
    }

    async handleShowEpicTasks(epicId, epicTitle, projectId) {
      window.handleShowEpicTasks(epicId, epicTitle, projectId);
    }
  }

  // Función global para manejar mostrar tareas de épica (a nivel de app)
  window.handleShowEpicTasks = async function(epicId, epicTitle, projectId) {
    try {
      // Verificar que AppController esté inicializado
      if (!window.appController) {
        // Esperar a que AppController se inicialice (máximo 5 segundos)
        let attempts = 0;
        while (!window.appController && attempts < 50) {
          await new Promise(resolve => setTimeout(resolve, 100));
          attempts++;
        }
        if (!window.appController) {
          console.error('[AdminProject] AppController not available after timeout');
          return;
        }
      }

      // Solicitar las tareas del proyecto
      document.dispatchEvent(new CustomEvent('request-project-tasks', {
        detail: {
          projectId: projectId,
          fullData: true,
          callback: (tasks) => {
            window.displayEpicTasksModal(tasks, epicId, epicTitle);
          }
        },
        bubbles: true,
        composed: true
      }));
    } catch (error) {
const notification = document.createElement('slide-notification');
      notification.message = 'Error al cargar las tareas de la épica';
      notification.type = 'error';
      document.body.appendChild(notification);
    }
  };

  // Función global para mostrar el modal con tabla de tareas épica
  window.displayEpicTasksModal = function(allTasks, epicId, epicTitle) {
    if (!allTasks || !Array.isArray(allTasks)) {
      return;
    }

    // Filtrar las tareas que pertenecen a esta épica
    const epicTasks = allTasks.filter(task => task.epic === epicId);

    if (epicTasks.length === 0) {
      document.dispatchEvent(new CustomEvent('show-modal', {
        detail: {
          options: {
            title: `Tareas de la épica: ${epicTitle}`,
            message: `<p>No hay tareas asignadas a esta épica.</p>`,
            button1Text: 'Cerrar',
            button1css: 'background-color: green; color: var(--text-on-primary, white);',
            button1Action: () => { },
            maxWidth: '80vw',
            maxHeight: '80vh',
            showHeader: true,
            showFooter: true
          }
        }
      }));
      return;
    }

    // Crear tabla HTML con las tareas
    const tableHtml = window.createTasksTableHtml(epicTasks);

    // Crear el modal manualmente con ID específico
    const modal = document.createElement('app-modal');
    const epicModalId = `epic-modal-${epicId}-${Date.now()}`;

    // IMPORTANTE: Activar modo programático para que el modal se muestre al añadirse al DOM
    modal._programmaticMode = true;

    // Asignar modalId ANTES de añadir al DOM para evitar ID auto-generado
    modal.modalId = epicModalId;
    modal.setAttribute('modal-id', epicModalId);
    modal.title = `Tareas de la épica: ${epicTitle} (${epicTasks.length} tareas)`;
    modal.maxWidth = '80vw';
    modal.maxHeight = '80vh';

    let handleModalCloseRequested = null;

    const cleanupEpicModalListeners = () => {
      if (handleModalCloseRequested) {
        document.removeEventListener('modal-closed-requested', handleModalCloseRequested);
        handleModalCloseRequested = null;
      }
      document.removeEventListener('modal-close-confirmed', handleEpicModalCloseConfirmed);

      if (window.modalStateManager) {
        const topModal = window.modalStateManager.getTopModal?.();
        if (topModal && topModal.modalId === epicModalId) {
          window.modalStateManager.popModal();
        } else if (Array.isArray(window.modalStateManager.modalStack)) {
          window.modalStateManager.modalStack = window.modalStateManager.modalStack.filter(
            (modalInfo) => modalInfo.modalId !== epicModalId
          );
        }
      }
    };

    const handleEpicModalCloseConfirmed = (e) => {
      const { modalId, componentType } = e.detail || {};
      const matchesModal = modalId === epicModalId || (!modalId && componentType === 'epic-tasks');
      if (!matchesModal) return;

      cleanupEpicModalListeners();
      modal.close();
    };

    document.addEventListener('modal-close-confirmed', handleEpicModalCloseConfirmed);

    // Añadir modal al DOM
    document.body.appendChild(modal);

    // Crear contenido del modal
    const tempContainer = document.createElement('div');
    tempContainer.id = `epic-tasks-${epicId}`;
    tempContainer.innerHTML = tableHtml;

    // Esperar a que el modal esté conectado antes de setContent
    modal.updateComplete.then(() => {
      modal.setContent(tempContainer);
      modal.contentElementId = tempContainer.id;
      modal.contentElementType = 'epic-tasks';

      handleModalCloseRequested = (event) => {
        const { contentElementId, modalId } = event.detail || {};
        if (modalId && modalId !== epicModalId) return;
        if (contentElementId && contentElementId !== tempContainer.id) return;

        document.dispatchEvent(new CustomEvent('modal-close-confirmed', {
          detail: {
            modalId: epicModalId,
            componentType: 'epic-tasks',
            contentElementId: tempContainer.id
          }
        }));
      };

      document.addEventListener('modal-closed-requested', handleModalCloseRequested);

      // Configurar event listeners para botones "Ver tarea"
      window.setupTaskViewButtons(tempContainer, epicTasks);
    });
    
    // Registrar modal de épica en el stack
    if (window.modalStateManager) {
      window.modalStateManager.pushModal(epicModalId, `epic-${epicId}`);
    }
};

