  // Convert Git SSH URL to HTTPS URL for browser navigation
  function convertGitUrlToHttps(url) {
    if (!url) return null;
    // Already HTTPS
    if (url.startsWith('https://')) return url;
    // SSH format: git@github.com:Org/Repo.git
    const sshMatch = url.match(/^git@([^:]+):(.+?)(?:\.git)?$/);
    if (sshMatch) {
      return `https://${sshMatch[1]}/${sshMatch[2]}`;
    }
    // HTTP format
    if (url.startsWith('http://')) return url;
    return url;
  }

  // Normalize repoUrl to array format (handles string, array, or Firebase object)
  function normalizeRepoUrls(repoUrl) {
    if (!repoUrl) return [];
    if (typeof repoUrl === 'string') {
      return repoUrl.trim() ? [{ url: repoUrl.trim(), label: 'Repositorio' }] : [];
    }
    if (Array.isArray(repoUrl)) {
      return repoUrl.filter(r => r && r.url);
    }
    // Firebase object format: {0: {url, label}, 1: {url, label}}
    if (typeof repoUrl === 'object') {
      return Object.values(repoUrl).filter(r => r && r.url);
    }
    return [];
  }

  // Function to update doc buttons visibility based on project data
  window.updateDocButtons = function(projectData) {
    const repoBtn = document.getElementById('repoLinkBtn');
    const descBtn = document.getElementById('projectDescBtn');

    if (!repoBtn || !descBtn) return;

    // Show repo button if repoUrl exists
    const repos = normalizeRepoUrls(projectData?.repoUrl);
    if (repos.length > 0) {
      repoBtn.style.display = 'inline-flex';
      repoBtn.onclick = () => {
        if (repos.length === 1) {
          const url = convertGitUrlToHttps(repos[0].url);
          if (url) window.open(url, '_blank');
        } else {
          // Multiple repos: show selection modal
          const repoLinks = repos.map(r => {
            const url = convertGitUrlToHttps(r.url);
            return `<a href="${url}" target="_blank" style="display: block; padding: 0.5rem 1rem; margin: 0.25rem 0; background: var(--bg-secondary); border-radius: 4px; text-decoration: none; color: var(--text-primary); border: 1px solid var(--border-subtle);">
              <strong>${r.label || 'Repositorio'}</strong><br>
              <small style="color: var(--text-muted);">${url}</small>
            </a>`;
          }).join('');
          document.dispatchEvent(new CustomEvent('show-modal', {
            detail: {
              options: {
                title: 'Seleccionar repositorio',
                message: `<div style="padding: 0.5rem;">${repoLinks}</div>`,
                button1Text: 'Cerrar',
                button1css: 'background-color: var(--brand-primary, #6366f1); color: var(--text-on-primary, white);',
                button1Action: () => {},
                maxWidth: '500px',
                showHeader: true
              }
            }
          }));
        }
      };
    } else {
      repoBtn.style.display = 'none';
      repoBtn.onclick = null;
    }

    // Show description button if description exists
    if (projectData && projectData.description) {
      descBtn.style.display = 'inline-flex';
      descBtn.onclick = () => {
        // Escape HTML to prevent XSS but preserve markdown
        const escapedDescription = projectData.description
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');

        document.dispatchEvent(new CustomEvent('show-modal', {
          detail: {
            options: {
              title: `Documentación: ${projectData.name || 'Proyecto'}`,
              message: `<md-renderer style="display: block; text-align: left; padding: 1rem;">${escapedDescription}</md-renderer>`,
              button1Text: 'Cerrar',
              button1css: 'background-color: var(--brand-primary, #6366f1); color: var(--text-on-primary, white);',
              button1Action: () => {},
              maxWidth: '700px',
              maxHeight: '80vh',
              showHeader: true
            }
          }
        }));
      };
    } else {
      descBtn.style.display = 'none';
      descBtn.onclick = null;
    }
  };

  // Inicializar cuando el DOM esté listo
  document.addEventListener('astro:page-load', function() {
// Inicializar gestor de modales
    window.modalStateManager = new ModalStateManager();

    // Listen for project changes to update doc buttons, ADR list, and tab visibility
    document.addEventListener('project-changed', function(e) {
      const projectId = e.detail?.projectId;
      if (projectId && window.projects && window.projects[projectId]) {
        const projectData = window.projects[projectId];
        window.updateDocButtons(projectData);
        // Update App tab visibility based on project config
        projectHasApps = Boolean(projectData.allowExecutables);
        window.updateTabVisibility();
      }
      // Update ADR list with new projectId
      const adrList = document.getElementById('adrList');
      if (adrList && projectId) {
        adrList.projectId = projectId;
      }
      // Update Dev Plans section with new projectId
      const devPlansSection = document.getElementById('devPlansSection');
      if (devPlansSection && projectId) {
        devPlansSection.projectId = projectId;
      }
    });

    // Update doc buttons, ADR list, and tab visibility on initial load
    const checkAndUpdateDocButtons = () => {
      const projectId = window.currentProjectId || document.body.dataset.projectId;
      if (projectId && window.projects && window.projects[projectId]) {
        const projectData = window.projects[projectId];
        window.updateDocButtons(projectData);
        // Update App tab visibility
        projectHasApps = Boolean(projectData.allowExecutables);
        window.updateTabVisibility();
        // Initialize ADR list with projectId
        const adrList = document.getElementById('adrList');
        if (adrList) {
          adrList.projectId = projectId;
        }
        // Initialize Dev Plans section with projectId
        const devPlansSection = document.getElementById('devPlansSection');
        if (devPlansSection) {
          devPlansSection.projectId = projectId;
        }
      } else {
        // Retry after a short delay if projects not loaded yet
        setTimeout(checkAndUpdateDocButtons, 500);
      }
    };
    setTimeout(checkAndUpdateDocButtons, 100);

    // Initial tab visibility and permissions
    window.updateTabVisibility();

    // Listener for year-based permission changes
    document.addEventListener('year-permissions-updated', function(e) {
      const { year, isPastYear, isYearReadOnly: yearReadOnly } = e.detail;
      isYearReadOnly = yearReadOnly;

      // Update button visibility based on new year state
      toggleEditButtons();

      // Notify components about permission changes
      window.notifyPermissionsUpdate();
    });
  });
</script>

