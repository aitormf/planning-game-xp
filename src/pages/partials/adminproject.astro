<script type="module">
  import { modalService } from '/js/services/modal-service.js';
  import { URLStateManager } from '/js/utils/url-utils.js';

  window.modalService = modalService;

  // Restore section from URL hash on page load
  document.addEventListener('astro:page-load', () => {
    const urlState = URLStateManager.getState();

    // Restore section (tab) from hash
    if (urlState.section) {
      const sectionTab = document.querySelector(`[data-section="${urlState.section}"]`);
      if (sectionTab) {
        // Wait a bit for the tab system to initialize
        setTimeout(() => {
          sectionTab.click();
        }, 100);
      }
    }
  });

  // Listen for browser back/forward navigation
  URLStateManager.onPopState((state) => {
    if (state.section) {
      const sectionTab = document.querySelector(`[data-section="${state.section}"]`);
      if (sectionTab) {
        sectionTab.click();
      }
    }
  });
</script>

<script type="module">
// Edit Project functionality
import { showModal } from '@manufosela/app-modal';
import 'https://esm.sh/@manufosela/md-renderer';
import { database, ref, get, set, update, auth, superAdminEmail } from '/firebase-config.js';
import { FirebaseService } from '/js/services/firebase-service.js';
import { encodeEmailForFirebase } from '/js/utils/email-sanitizer.js';
import '/js/wc/ProjectForm.js';
import '/js/wc/CardSearch.js';

let currentProjectName = '';

// Initialize edit button visibility
function initEditProjectButton() {
  const editBtn = document.getElementById('editProjectBtn');
  if (!editBtn) return;

  // Check if user is superAdmin
  const checkSuperAdmin = () => {
    const user = auth.currentUser;
    if (user && user.email === superAdminEmail) {
      editBtn.style.display = '';
    } else {
      editBtn.style.display = 'none';
    }
  };

  // Check on auth state change
  auth.onAuthStateChanged(() => {
    checkSuperAdmin();
  });

  // Initial check
  checkSuperAdmin();

  // Handle click
  editBtn.addEventListener('click', () => {
    const projectSelector = document.getElementById('projectSelector');
    const projectName = projectSelector?.selectedProject || window.currentProjectId;
    if (projectName) {
      showEditProjectModal(projectName);
    }
  });
}

// Listen for project changes
document.addEventListener('project-changed', (e) => {
  currentProjectName = e.detail?.projectId || e.detail?.projectName || '';
});

async function showEditProjectModal(projectName) {
  try {
    // Load project data
    const projectRef = ref(database, `/projects/${projectName}`);
    const snapshot = await get(projectRef);
    const projectData = snapshot.val();

    if (!projectData) {
      document.dispatchEvent(new CustomEvent('show-slide-notification', {
        detail: { options: { message: 'No se encontraron datos del proyecto', type: 'error' } }
      }));
      return;
    }

    // Check if project has existing cards (locks name and abbreviation)
    const cardsRef = ref(database, `/cards/${projectName}`);
    const cardsSnapshot = await get(cardsRef);
    const hasCards = cardsSnapshot.exists();

    const projectForm = document.createElement('project-form');

    // Store project data to apply after component is ready
    const applyProjectData = () => {
      projectForm.editMode = true;
      projectForm.hasCards = hasCards;
      projectForm.originalProjectName = projectName;
      projectForm.projectName = projectData.name || projectName;
      projectForm.abbreviation = projectData.abbreviation || '';
      projectForm.scoringSystem = projectData.scoringSystem || '1-5';
      projectForm.stakeholders = projectData.stakeholders || [];
      projectForm.developers = projectData.developers || [];
      projectForm.allowExecutables = projectData.allowExecutables || false;
      projectForm.description = projectData.description || '';
      projectForm.repoUrl = projectData.repoUrl ?? projectData.repositoryUrl ?? '';
      projectForm.languagesText = Array.isArray(projectData.languages) ? projectData.languages.join(', ') : '';
      projectForm.frameworksText = Array.isArray(projectData.frameworks) ? projectData.frameworks.join(', ') : '';
      projectForm.businessContext = projectData.businessContext || '';
      // Migration: if no businessContext but agentsGuidelines exists, migrate
      if (!projectData.businessContext && projectData.agentsGuidelines) {
        projectForm.businessContext = projectData.agentsGuidelines;
        document.dispatchEvent(new CustomEvent('show-slide-notification', {
          detail: { options: {
            message: 'Se han migrado las directrices de agents al campo "Contexto de Negocio". Revisa y guarda.',
            type: 'info'
          }}
        }));
      }
      projectForm.useIa = Boolean(projectData.iaEnabled);
      projectForm.iaAvailable = projectData.iaEnabled || projectForm.iaAvailable;
      projectForm.archived = Boolean(projectData.archived);
      projectForm.requestUpdate();
    };

    // Apply initial data
    applyProjectData();

    showModal({
      title: 'Editar Proyecto',
      maxWidth: '50dvw',
      maxHeight: '80dvh',
      showFooter: true,
      button1Text: 'Guardar Cambios',
      button2Text: 'Cancelar',
      button1Action: async () => {
        const validation = projectForm.validateWithFeedback();
        if (!validation.valid) {
          const errorMsg = validation.errors.map(e => e.message).join('. ');
          document.dispatchEvent(new CustomEvent('show-slide-notification', {
            detail: { options: { message: errorMsg, type: 'error' } }
          }));
          return false;
        }
        await updateProject(projectForm, projectName, projectData);
      },
      button2Action: () => {}
    });

    // Add form to modal and wait for component to be ready
    setTimeout(() => {
      const modal = document.querySelector('app-modal');
      if (modal) {
        modal.setContent(projectForm);

        // Wait for component to finish loading, then re-apply data
        const waitForReady = () => {
          if (!projectForm.isLoading) {
            applyProjectData();
          } else {
            // Check again after a short delay
            setTimeout(waitForReady, 50);
          }
        };
        waitForReady();

        projectForm.addEventListener('delete-project', (e) => {
          deleteProject(e.detail.projectName);
        });

        projectForm.addEventListener('archive-project', (e) => {
          archiveProject(e.detail.projectName, e.detail.archived);
        });
      }
    }, 100);

  } catch (error) {
    console.error('Error loading project:', error);
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: 'Error al cargar los datos del proyecto', type: 'error' } }
    }));
  }
}

/**
 * Sync project team assignments to /users/{email}/projects/{projectId}
 * so entityDirectoryService sees them (single source of truth).
 * Only updates users that already exist in /users/.
 */
async function syncProjectTeamToUsers(projectName, developers, stakeholders) {
  const devEmails = new Set();
  const stkEmails = new Set();

  for (const dev of developers) {
    if (dev.email) devEmails.add(dev.email.toLowerCase().trim());
  }
  for (const stk of stakeholders) {
    if (stk.email) stkEmails.add(stk.email.toLowerCase().trim());
  }

  const allEmails = new Set([...devEmails, ...stkEmails]);
  const updates = {};

  for (const email of allEmails) {
    const encodedEmail = encodeEmailForFirebase(email);
    if (!encodedEmail) continue;

    // Only sync if user exists in /users/
    const userSnap = await get(ref(database, `/users/${encodedEmail}`));
    if (!userSnap.exists()) continue;

    const isDev = devEmails.has(email);
    const isStk = stkEmails.has(email);
    updates[`/users/${encodedEmail}/projects/${projectName}/developer`] = isDev;
    updates[`/users/${encodedEmail}/projects/${projectName}/stakeholder`] = isStk;
  }

  if (Object.keys(updates).length > 0) {
    await update(ref(database), updates);
  }
}

async function updateProject(projectForm, originalProjectName, originalData) {
  const formData = projectForm.getFormData();

  try {
    // Build project data, excluding undefined values (Firebase doesn't accept undefined)
    const projectData = {
      name: formData.projectName,
      abbreviation: formData.abbreviation,
      scoringSystem: formData.scoringSystem,
      stakeholders: formData.stakeholders,
      developers: formData.developers,
      allowExecutables: formData.allowExecutables || false,
      description: formData.description || '',
      repoUrl: formData.repoUrl || '',
      languages: formData.languages || [],
      frameworks: formData.frameworks || [],
      businessContext: formData.businessContext || '',
      iaEnabled: formData.useIa || false,
      updatedAt: new Date().toISOString(),
      updatedBy: auth.currentUser?.email || 'unknown',
      archived: originalData?.archived || false
    };

    // Only include optional fields if they exist in originalData
    if (originalData?.order !== undefined) {
      projectData.order = originalData.order;
    }
    if (originalData?.createdAt !== undefined) {
      projectData.createdAt = originalData.createdAt;
    }
    if (originalData?.createdBy !== undefined) {
      projectData.createdBy = originalData.createdBy;
    }

    if (formData.projectName !== originalProjectName) {
      await set(ref(database, `/projects/${formData.projectName}`), projectData);
      await set(ref(database, `/projects/${originalProjectName}`), null);
    } else {
      await set(ref(database, `/projects/${originalProjectName}`), projectData);
    }

    // Sync team assignments to /users/ for entityDirectoryService consistency
    const targetProjectName = formData.projectName || originalProjectName;
    await syncProjectTeamToUsers(targetProjectName, formData.developers || [], formData.stakeholders || []);

    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: 'Proyecto actualizado exitosamente!' } }
    }));

    // Reload page if name changed
    if (formData.projectName !== originalProjectName) {
      window.location.href = `/adminproject?projectId=${encodeURIComponent(formData.projectName)}`;
    }

  } catch (error) {
    console.error('Error updating project:', error);
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: 'Error al actualizar el proyecto', type: 'error' } }
    }));
  }
}

async function archiveProject(projectName, archived) {
  try {
    await set(ref(database, `/projects/${projectName}/archived`), archived);
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: archived ? 'Proyecto archivado' : 'Proyecto desarchivado' } }
    }));
  } catch (error) {
    console.error('Error archiving project:', error);
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: 'Error al archivar el proyecto', type: 'error' } }
    }));
  }
}

async function deleteProject(projectName) {
  try {
    await set(ref(database, `/projects/${projectName}`), null);
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: 'Proyecto eliminado' } }
    }));
    window.location.href = '/';
  } catch (error) {
    console.error('Error deleting project:', error);
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: 'Error al eliminar el proyecto', type: 'error' } }
    }));
  }
}

// === Trash Tab ===

let trashLoaded = false;

async function loadTrashCards(projectName) {
  if (trashLoaded) return;

  const container = document.getElementById('trashCardsList');
  if (!container) return;

  container.innerHTML = '<p class="loading-message">Cargando papelera...</p>';

  try {
    const trashRef = ref(database, `/trash/cards/${projectName}`);
    const snapshot = await get(trashRef);
    const trashData = snapshot.val();

    if (!trashData) {
      container.innerHTML = '<p class="empty-message">La papelera está vacía.</p>';
      trashLoaded = true;
      return;
    }

    const items = [];
    for (const [cardType, cards] of Object.entries(trashData)) {
      for (const [firebaseId, card] of Object.entries(cards)) {
        items.push({ ...card, _firebaseId: firebaseId, _cardType: cardType });
      }
    }

    items.sort((a, b) => (b.deletedAt || '').localeCompare(a.deletedAt || ''));

    if (items.length === 0) {
      container.innerHTML = '<p class="empty-message">La papelera está vacía.</p>';
      trashLoaded = true;
      return;
    }

    const table = document.createElement('table');
    table.className = 'trash-table';
    table.innerHTML = `
      <thead>
        <tr>
          <th>Card ID</th>
          <th>Tipo</th>
          <th>Título</th>
          <th>Estado</th>
          <th>Eliminado por</th>
          <th>Fecha eliminación</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        ${items.map(item => {
          const type = (item._cardType || '').replace(`_${projectName}`, '');
          const deletedDate = item.deletedAt
            ? new Date(item.deletedAt).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' })
            : '-';
          const reason = item.deleteReason === 'moved_to_project'
            ? `Movido a ${item.movedTo?.projectId || '?'}`
            : '';
          return `<tr>
            <td>${item.cardId || '-'}</td>
            <td>${type}</td>
            <td>${item.title || '-'}</td>
            <td>${item.status || '-'} ${reason ? `<span class="moved-badge">${reason}</span>` : ''}</td>
            <td>${item.deletedBy || '-'}</td>
            <td>${deletedDate}</td>
            <td><button class="btn-restore" data-action="restore" data-firebase-id="${item._firebaseId}" data-card-type="${item._cardType}">Restaurar</button></td>
          </tr>`;
        }).join('')}
      </tbody>
    `;
    container.innerHTML = '';
    container.append(table);

    // Attach restore button handlers
    table.querySelectorAll('[data-action="restore"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const fbId = btn.dataset.firebaseId;
        const cardType = btn.dataset.cardType;
        btn.disabled = true;
        btn.textContent = 'Restaurando...';
        try {
          await FirebaseService.restoreCard(projectName, cardType, fbId);
          trashLoaded = false;
          loadTrashCards(projectName);
        } catch {
          btn.disabled = false;
          btn.textContent = 'Restaurar';
        }
      });
    });

    trashLoaded = true;
  } catch (error) {
    console.error('Error loading trash:', error);
    container.innerHTML = '<p class="error-message">Error al cargar la papelera.</p>';
  }
}

document.addEventListener('tab-changed', (e) => {
  const section = e.detail?.section;
  if (section === 'trash') {
    const projectName = new URLSearchParams(window.location.search).get('projectId');
    if (projectName) loadTrashCards(projectName);
  }
});

// Invalidate trash cache when a card is deleted or restored so it reloads on next visit
document.addEventListener('card-deleted', () => {
  trashLoaded = false;
});
document.addEventListener('card-restored', () => {
  trashLoaded = false;
});

// Initialize on page load
document.addEventListener('astro:page-load', () => {
  initEditProjectButton();
});
</script>

<script type="module">
// Task Guide Modal
  const taskGuideStyles = `
    <style>
      /* Override modal centering for this content */
