<div data-main>
  <div class="page-header">
    <h1>Global Configuration</h1>
    <p class="subtitle">Manage global agents, prompts, and instructions that can be assigned to projects</p>
  </div>

  <global-config-list id="globalConfigList"></global-config-list>


<script type="module">
  import '/js/wc/GlobalConfigList.js';

  // Handle events
  document.getElementById('globalConfigList')?.addEventListener('config-saved', (e) => {
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: `${e.detail.name} saved successfully`, type: 'success' } }
    }));
  });

  document.getElementById('globalConfigList')?.addEventListener('config-deleted', (e) => {
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: `${e.detail.name} deleted`, type: 'info' } }
    }));
  });

  document.getElementById('globalConfigList')?.addEventListener('config-created', (e) => {
    document.dispatchEvent(new CustomEvent('show-slide-notification', {
      detail: { options: { message: `New config created`, type: 'success' } }
    }));
  });
</script>

<style>
  .page-header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 1rem 0.5rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-primary, #333);
    margin: 0 0 0.5rem 0;
  }

  .page-header .subtitle {
    color: var(--text-secondary, #666);
    margin: 0;
    font-size: 0.95rem;
  }
</style>

</div>
