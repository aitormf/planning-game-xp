---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Documentación">
  <div class="doc-page-wrapper">
    <aside class="doc-page-sidebar">
      <nav class="doc-sidebar-nav" id="doc-sidebar">
        <div class="doc-sidebar-header">
          <span class="doc-sidebar-icon">📘</span>
          <span class="doc-sidebar-title">Engineering Playbook</span>
          <button class="doc-add-btn" id="add-doc-btn" title="Añadir documento" style="display: none;">+</button>
        </div>
        <div id="sidebar-content">
          <div class="doc-loading">Cargando...</div>
        </div>
      </nav>
    </aside>

    <div class="doc-page-content">
      <div class="doc-toolbar" id="doc-toolbar" style="display: none;">
        <button class="doc-toolbar-btn" id="edit-doc-btn" title="Editar documento">
          <span>Editar</span>
        </button>
        <button class="doc-toolbar-btn doc-toolbar-btn-danger" id="delete-doc-btn" title="Eliminar documento">
          <span>Eliminar</span>
        </button>
        <button class="doc-toolbar-btn" id="history-doc-btn" title="Ver historial">
          <span>Historial</span>
        </button>
      </div>
      <nav class="doc-breadcrumbs" id="breadcrumbs"></nav>
      <article class="doc-page-article" id="doc-content">
        <div class="doc-loading">Cargando documentación...</div>
      </article>
    </div>
  </div>

  <!-- Editor Modal -->
  <div class="doc-modal-overlay" id="editor-modal" style="display: none;">
    <div class="doc-modal">
      <div class="doc-modal-header">
        <h2 id="editor-title">Editar Documento</h2>
        <button class="doc-modal-close" id="editor-close">&times;</button>
      </div>
      <div class="doc-modal-body">
        <div class="doc-form-group">
          <label for="doc-title-input">Título (para sidebar)</label>
          <input type="text" id="doc-title-input" placeholder="Título del documento">
        </div>
        <div class="doc-form-row">
          <div class="doc-form-group doc-form-group-section">
            <label for="doc-section-input">Sección</label>
            <div class="doc-section-row">
              <select id="doc-section-input">
                <!-- Populated dynamically -->
              </select>
              <button type="button" class="doc-btn-icon" id="add-section-btn" title="Nueva sección">+</button>
            </div>
          </div>
          <div class="doc-form-group doc-form-group-path">
            <label for="doc-path-input">Ruta</label>
            <div class="doc-path-row">
              <span class="doc-path-prefix" id="doc-path-prefix">/</span>
              <input type="text" id="doc-path-input" placeholder="mi-pagina">
            </div>
          </div>
          <div class="doc-form-group doc-form-group-order">
            <label for="doc-order-input">Orden</label>
            <input type="number" id="doc-order-input" value="0" min="0" readonly>
          </div>
        </div>
        <div class="doc-form-group doc-form-group-full">
          <label>Contenido (Markdown)</label>
          <div class="doc-editor-container">
            <textarea id="doc-content-input" placeholder="# Título&#10;&#10;Contenido en Markdown..."></textarea>
            <div class="doc-preview" id="doc-preview">
              <div class="doc-preview-label">Vista previa</div>
              <div class="doc-preview-content" id="doc-preview-content"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="doc-modal-footer">
        <button class="doc-btn doc-btn-secondary" id="editor-cancel">Cancelar</button>
        <button class="doc-btn doc-btn-primary" id="editor-save">Guardar</button>
      </div>
    </div>
  </div>

  <!-- History Modal -->
  <div class="doc-modal-overlay" id="history-modal" style="display: none;">
    <div class="doc-modal doc-modal-wide">
      <div class="doc-modal-header">
        <h2>Historial de cambios</h2>
        <button class="doc-modal-close" id="history-close">&times;</button>
      </div>
      <div class="doc-modal-body">
        <div id="history-content">
          <div class="doc-loading">Cargando historial...</div>
        </div>
      </div>
      <div class="doc-modal-footer">
        <button class="doc-btn doc-btn-secondary" id="history-cancel">Cerrar</button>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="doc-modal-overlay" id="delete-modal" style="display: none;">
    <div class="doc-modal doc-modal-small">
      <div class="doc-modal-header">
        <h2>Confirmar eliminación</h2>
        <button class="doc-modal-close" id="delete-close">&times;</button>
      </div>
      <div class="doc-modal-body">
        <p>¿Estás seguro de que quieres eliminar este documento?</p>
        <p class="doc-warning">Esta acción se puede deshacer desde el historial.</p>
      </div>
      <div class="doc-modal-footer">
        <button class="doc-btn doc-btn-secondary" id="delete-cancel">Cancelar</button>
        <button class="doc-btn doc-btn-danger" id="delete-confirm">Eliminar</button>
      </div>
    </div>
  </div>

  <!-- New Section Modal -->
  <div class="doc-modal-overlay" id="section-modal" style="display: none;">
    <div class="doc-modal doc-modal-small">
      <div class="doc-modal-header">
        <h2>Nueva Sección</h2>
        <button class="doc-modal-close" id="section-close">&times;</button>
      </div>
      <div class="doc-modal-body">
        <div class="doc-form-group">
          <label for="section-name-input">Nombre</label>
          <input type="text" id="section-name-input" placeholder="Nombre de la sección">
        </div>
        <div class="doc-form-group">
          <label for="section-slug-input">Slug (para URL)</label>
          <input type="text" id="section-slug-input" placeholder="nombre-seccion">
        </div>
      </div>
      <div class="doc-modal-footer">
        <button class="doc-btn doc-btn-secondary" id="section-cancel">Cancelar</button>
        <button class="doc-btn doc-btn-primary" id="section-save">Crear</button>
      </div>
    </div>
  </div>
</Layout>

<!-- Marked library for Markdown parsing (UMD build exposes global 'marked') -->
<script src="https://cdn.jsdelivr.net/npm/marked@9.1.6/marked.min.js"></script>

<script type="module">
  import { docsService } from '/js/services/docs-service.js';
  import { modalService } from '/js/services/modal-service.js';
  import { entityDirectoryService } from '/js/services/entity-directory-service.js';

  /**
   * Show a message modal (replacement for alert)
   */
  async function showMessage(title, message) {
    return modalService.createConfirmationModal({
      title,
      message,
      confirmText: 'Aceptar',
      cancelText: null,
      confirmButtonClass: 'confirm',
      cancelButtonClass: 'cancel'
    });
  }

  /**
   * Show a confirmation modal (replacement for confirm)
   */
  async function showConfirm(title, message) {
    return modalService.createConfirmationModal({
      title,
      message,
      confirmText: 'Aceptar',
      cancelText: 'Cancelar',
      confirmButtonClass: 'confirm',
      cancelButtonClass: 'cancel'
    });
  }

  // State
  let docs = [];
  let sections = [];
  let currentDoc = null;
  let isAdmin = false;
  let isDeveloper = false;
  let canDelete = false;  // Only admins can delete
  let editingDocId = null;

  // DOM Elements
  const contentEl = document.getElementById('doc-content');
  const breadcrumbsEl = document.getElementById('breadcrumbs');
  const sidebarContent = document.getElementById('sidebar-content');
  const toolbar = document.getElementById('doc-toolbar');
  const addDocBtn = document.getElementById('add-doc-btn');
  const editDocBtn = document.getElementById('edit-doc-btn');
  const deleteDocBtn = document.getElementById('delete-doc-btn');
  const historyDocBtn = document.getElementById('history-doc-btn');

  // Editor Modal Elements
  const editorModal = document.getElementById('editor-modal');
  const editorTitle = document.getElementById('editor-title');
  const titleInput = document.getElementById('doc-title-input');
  const sectionInput = document.getElementById('doc-section-input');
  const pathPrefix = document.getElementById('doc-path-prefix');
  const pathInput = document.getElementById('doc-path-input');
  const orderInput = document.getElementById('doc-order-input');
  const contentInput = document.getElementById('doc-content-input');
  const previewContent = document.getElementById('doc-preview-content');
  const addSectionBtn = document.getElementById('add-section-btn');

  // History Modal Elements
  const historyModal = document.getElementById('history-modal');
  const historyContent = document.getElementById('history-content');

  // Delete Modal Elements
  const deleteModal = document.getElementById('delete-modal');

  // Section Modal Elements
  const sectionModal = document.getElementById('section-modal');
  const sectionNameInput = document.getElementById('section-name-input');
  const sectionSlugInput = document.getElementById('section-slug-input');

  /**
   * Get section name by slug
   */
  function getSectionName(slug) {
    const section = sections.find(s => s.slug === slug);
    return section?.name || slug;
  }

  /**
   * Check if user is admin, super admin, or developer
   * - Admins: can create, edit, and delete docs
   * - Developers: can create and edit docs (no delete)
   */
  async function checkAdminStatus() {
    // Check project admin
    const isProjectAdmin = window.currentUserRole?.isResponsable || false;

    // Check super admin (from .env via firebase-config.js)
    let isSuperAdmin = false;
    const userEmail = (document.body.dataset.userEmail || '').toLowerCase().trim();

    try {
      if (userEmail) {
        const { superAdminEmail } = await import(
          /* @vite-ignore */ `${window.location.origin}/firebase-config.js`
        );
        const configSuperAdmin = (superAdminEmail || '').toLowerCase().trim();
        isSuperAdmin = userEmail === configSuperAdmin;
      }
    } catch (error) {
      // Silently fail - user won't have super admin access
    }

    // Check if user is a developer (from global developers list)
    isDeveloper = false;
    try {
      if (userEmail) {
        await entityDirectoryService.init();
        const developerId = entityDirectoryService.resolveDeveloperId(userEmail);
        isDeveloper = !!developerId;
      }
    } catch (error) {
      // Silently fail - user won't have developer access
    }

    isAdmin = isProjectAdmin || isSuperAdmin;
    canDelete = isAdmin;  // Only admins can delete
    const canEdit = isAdmin || isDeveloper;  // Admins and developers can create/edit

    // Show/hide controls based on permissions
    if (canEdit) {
      addDocBtn.style.display = 'flex';
      toolbar.style.display = 'flex';
      editDocBtn.style.display = '';
      historyDocBtn.style.display = '';
      // Delete button only for admins
      deleteDocBtn.style.display = canDelete ? '' : 'none';
    } else {
      addDocBtn.style.display = 'none';
      toolbar.style.display = 'none';
    }
  }

  /**
   * Load sections from Firebase
   */
  async function loadSections() {
    try {
      sections = await docsService.getAllSections();
    } catch (error) {
      console.error('Error loading sections:', error);
      sections = [];
    }
  }

  /**
   * Load documents from Firebase
   */
  async function loadDocs() {
    try {
      await loadSections();
      docs = await docsService.getAllDocs();
      buildSidebar();
      handleNavigation();
    } catch (error) {
      console.error('Error loading docs:', error);
      sidebarContent.innerHTML = '<div class="doc-error">Error cargando documentos</div>';
      contentEl.innerHTML = '<h1>Error</h1><p>No se pudieron cargar los documentos.</p>';
    }
  }

  /**
   * Build sidebar from documents
   */
  function buildSidebar() {
    // Show migrate button if no docs or no sections
    if (docs.length === 0 || sections.length === 0) {
      sidebarContent.innerHTML = `
        <div class="doc-sidebar-section">
          <a href="#/" class="doc-sidebar-link doc-sidebar-home" data-route="/">Inicio</a>
        </div>
        <p class="doc-sidebar-empty">No hay documentos aún.</p>
        ${isAdmin ? '<button class="doc-migrate-btn" id="migrate-docs-btn">Importar documentación inicial</button>' : ''}
      `;

      const migrateBtn = document.getElementById('migrate-docs-btn');
      if (migrateBtn) {
        migrateBtn.addEventListener('click', migrateInitialDocs);
      }
      return;
    }

    // Group docs by section (only sections from Firebase, no 'general')
    const docsBySection = {};
    docs.forEach(doc => {
      const sectionSlug = doc.section;
      if (sectionSlug && sectionSlug !== 'general') {
        if (!docsBySection[sectionSlug]) {
          docsBySection[sectionSlug] = [];
        }
        docsBySection[sectionSlug].push(doc);
      }
    });

    // Start with home link
    let html = `
      <div class="doc-sidebar-section">
        <a href="#/" class="doc-sidebar-link doc-sidebar-home" data-route="/">Inicio</a>
      </div>
    `;

    // Build sections in order (from Firebase sections)
    sections.forEach(section => {
      const sectionDocs = docsBySection[section.slug] || [];
      if (sectionDocs.length > 0) {
        html += `
          <div class="doc-sidebar-section">
            <span class="doc-sidebar-label">${section.name}</span>
            ${sectionDocs.map(doc => `
              <a href="#${doc.path}" class="doc-sidebar-link" data-route="${doc.path}" data-doc-id="${doc.id}">${doc.title}</a>
            `).join('')}
          </div>
        `;
      }
    });

    sidebarContent.innerHTML = html;

    // Add click listeners
    sidebarContent.querySelectorAll('.doc-sidebar-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const route = link.dataset.route;
        window.location.hash = route;
      });
    });
  }

  /**
   * Get current route from hash
   */
  function getRoute() {
    return window.location.hash.slice(1) || '/';
  }

  /**
   * Update breadcrumbs
   */
  function updateBreadcrumbs(doc) {
    if (!doc || doc.path === '/') {
      breadcrumbsEl.innerHTML = '';
      return;
    }

    const parts = doc.path.split('/').filter(Boolean);
    let html = '<a href="#/">Docs</a>';

    parts.forEach((part, i) => {
      const isLast = i === parts.length - 1;
      const isSection = i === 0;

      // For section (first part), use section name from Firebase
      // For document (last part), use document title
      let label;
      if (isSection) {
        label = getSectionName(part);
      } else if (isLast) {
        label = doc.title;
      } else {
        label = part;
      }

      if (isLast) {
        html += ` <span class="separator">/</span> <span class="current">${label}</span>`;
      } else {
        // For section, link to first doc in that section
        const sectionFirstDoc = docs.find(d => d.section === part);
        const href = sectionFirstDoc ? `#${sectionFirstDoc.path}` : '#/';
        html += ` <span class="separator">/</span> <a href="${href}">${label}</a>`;
      }
    });

    breadcrumbsEl.innerHTML = html;
  }

  /**
   * Update active link in sidebar
   */
  function updateActiveLink(route) {
    sidebarContent.querySelectorAll('.doc-sidebar-link').forEach(link => {
      link.classList.toggle('active', link.dataset.route === route);
    });
  }

  /**
   * Render Markdown to HTML
   */
  function renderMarkdown(markdown) {
    const text = markdown || '';

    // Try marked library (handle different API versions)
    if (typeof marked !== 'undefined') {
      try {
        // marked v4+ uses marked.parse()
        if (typeof marked.parse === 'function') {
          return marked.parse(text);
        }
        // older versions: marked is the function itself
        if (typeof marked === 'function') {
          return marked(text);
        }
      } catch (e) {
        console.error('Error parsing markdown:', e);
      }
    }

    // Fallback: basic conversion
    return text
      .replace(/^### (.*$)/gim, '<h3>$1</h3>')
      .replace(/^## (.*$)/gim, '<h2>$1</h2>')
      .replace(/^# (.*$)/gim, '<h1>$1</h1>')
      .replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
      .replace(/\*(.*)\*/gim, '<em>$1</em>')
      .replace(/`([^`]+)`/gim, '<code>$1</code>')
      .replace(/\n/gim, '<br>');
  }

  /**
   * Build the home/welcome page content
   */
  function buildHomePage() {
    let sectionsHtml = '';

    sections.forEach(section => {
      const sectionDocs = docs.filter(d => d.section === section.slug);
      if (sectionDocs.length > 0) {
        const firstDoc = sectionDocs[0];
        sectionsHtml += `
          <div class="doc-home-section">
            <h3><a href="#${firstDoc.path}">${section.name}</a></h3>
            <ul>
              ${sectionDocs.map(doc => `<li><a href="#${doc.path}">${doc.title}</a></li>`).join('')}
            </ul>
          </div>
        `;
      }
    });

    return `
      <h1>Engineering Playbook</h1>
      <p class="doc-home-intro">
        Bienvenido a la documentación del equipo de ingeniería. Aquí encontrarás guías sobre
        nuestro flujo de trabajo, estándares de calidad, despliegues y más.
      </p>
      ${sectionsHtml ? `<div class="doc-home-sections">${sectionsHtml}</div>` : '<p>No hay documentos disponibles aún.</p>'}
      ${isAdmin && docs.length === 0 ? '<p>Usa el botón "+" en la barra lateral para crear el primer documento.</p>' : ''}
    `;
  }

  /**
   * Load content for route
   */
  function loadContent(route) {
    // Handle home page
    if (route === '/') {
      currentDoc = null;
      contentEl.style.opacity = '0';
      contentEl.style.transform = 'translateY(10px)';

      setTimeout(() => {
        contentEl.innerHTML = buildHomePage();
        breadcrumbsEl.innerHTML = '';
        updateActiveLink('/');

        requestAnimationFrame(() => {
          contentEl.style.opacity = '1';
          contentEl.style.transform = 'translateY(0)';
        });
      }, 150);
      return;
    }

    currentDoc = docs.find(doc => doc.path === route);

    if (!currentDoc) {
      contentEl.innerHTML = '<h1>Página no encontrada</h1><p>La ruta solicitada no existe.</p>';
      return;
    }

    // Fade out
    contentEl.style.opacity = '0';
    contentEl.style.transform = 'translateY(10px)';

    setTimeout(() => {
      const html = renderMarkdown(currentDoc.content);
      contentEl.innerHTML = html;
      updateBreadcrumbs(currentDoc);
      updateActiveLink(currentDoc.path);

      // Fade in
      requestAnimationFrame(() => {
        contentEl.style.opacity = '1';
        contentEl.style.transform = 'translateY(0)';
      });
    }, 150);
  }

  /**
   * Handle navigation
   */
  function handleNavigation() {
    const route = getRoute();
    loadContent(route);
  }

  /**
   * Populate section dropdown from Firebase
   */
  function populateSectionDropdown(selectedSlug = null) {
    sectionInput.innerHTML = '';

    if (sections.length === 0) {
      sectionInput.innerHTML = '<option value="">No hay secciones</option>';
      return;
    }

    sections.forEach(section => {
      const option = document.createElement('option');
      option.value = section.slug;
      option.textContent = section.name;
      if (section.slug === selectedSlug) {
        option.selected = true;
      }
      sectionInput.appendChild(option);
    });
  }

  /**
   * Update path prefix based on selected section
   */
  function updatePathPrefix() {
    const selectedSlug = sectionInput.value;
    pathPrefix.textContent = selectedSlug ? `/${selectedSlug}/` : '/';
  }

  /**
   * Update order based on selected section (for new docs)
   */
  async function updateOrderForSection() {
    if (editingDocId) return; // Don't auto-update for existing docs

    const selectedSlug = sectionInput.value;
    if (selectedSlug) {
      const nextOrder = await docsService.getNextOrderForSection(selectedSlug);
      orderInput.value = nextOrder;
    }
  }

  /**
   * Open editor modal
   */
  async function openEditor(doc = null) {
    editingDocId = doc?.id || null;
    editorTitle.textContent = doc ? 'Editar Documento' : 'Nuevo Documento';

    // Populate section dropdown
    const currentSection = doc?.section || (sections[0]?.slug || '');
    populateSectionDropdown(currentSection);

    titleInput.value = doc?.title || '';
    contentInput.value = doc?.content || '';

    // Handle path: for existing docs, extract slug from path
    if (doc?.path) {
      const pathParts = doc.path.split('/').filter(Boolean);
      // Last part is the slug
      pathInput.value = pathParts[pathParts.length - 1] || '';
    } else {
      pathInput.value = '';
    }

    // Update path prefix
    updatePathPrefix();

    // Set order
    if (doc) {
      orderInput.value = doc.order || 0;
    } else {
      await updateOrderForSection();
    }

    updatePreview();
    editorModal.style.display = 'flex';
  }

  /**
   * Close editor modal
   */
  function closeEditor() {
    editorModal.style.display = 'none';
    editingDocId = null;
  }

  /**
   * Update preview
   */
  function updatePreview() {
    const markdown = contentInput.value;
    previewContent.innerHTML = renderMarkdown(markdown);
  }

  /**
   * Save document (admins and developers)
   */
  async function saveDocument() {
    const canEdit = isAdmin || isDeveloper;
    if (!canEdit) {
      await showMessage('Sin permisos', 'No tienes permisos para editar documentos.');
      return;
    }

    const sectionSlug = sectionInput.value;
    const pathSlug = pathInput.value.trim().toLowerCase()
      .replace(/[^a-z0-9-]/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');

    if (!sectionSlug) {
      await showMessage('Campo requerido', 'Debes seleccionar una sección');
      return;
    }

    if (!pathSlug) {
      await showMessage('Campo requerido', 'La ruta es obligatoria');
      return;
    }

    const fullPath = `/${sectionSlug}/${pathSlug}`;

    const doc = {
      id: editingDocId,
      title: titleInput.value.trim(),
      section: sectionSlug,
      path: fullPath,
      order: parseInt(orderInput.value, 10) || 0,
      content: contentInput.value
    };

    if (!doc.title) {
      await showMessage('Campo requerido', 'El título es obligatorio');
      return;
    }

    try {
      const saved = await docsService.saveDoc(doc);
      closeEditor();
      await loadDocs();
      window.location.hash = saved.path;
    } catch (error) {
      console.error('Error saving document:', error);
      await showMessage('Error', 'Error al guardar el documento: ' + error.message);
    }
  }

  /**
   * Open history modal
   */
  async function openHistory() {
    if (!currentDoc) return;

    historyModal.style.display = 'flex';
    historyContent.innerHTML = '<div class="doc-loading">Cargando historial...</div>';

    try {
      const history = await docsService.getDocHistory(currentDoc.id);

      if (history.length === 0) {
        historyContent.innerHTML = '<p>No hay historial disponible.</p>';
        return;
      }

      let html = '<div class="doc-history-list">';
      history.forEach(entry => {
        const date = new Date(entry.timestamp);
        const actionLabels = {
          'create': 'Creado',
          'update': 'Actualizado',
          'delete': 'Eliminado'
        };
        html += `
          <div class="doc-history-item">
            <div class="doc-history-info">
              <span class="doc-history-action">${actionLabels[entry.action] || entry.action}</span>
              <span class="doc-history-date">${date.toLocaleString()}</span>
              <span class="doc-history-user">${entry.changedBy}</span>
            </div>
            <div class="doc-history-actions">
              <button class="doc-btn doc-btn-small" data-history-id="${entry.id}">Restaurar</button>
            </div>
          </div>
        `;
      });
      html += '</div>';

      historyContent.innerHTML = html;

      // Add restore listeners
      historyContent.querySelectorAll('[data-history-id]').forEach(btn => {
        btn.addEventListener('click', () => restoreVersion(btn.dataset.historyId));
      });
    } catch (error) {
      console.error('Error loading history:', error);
      historyContent.innerHTML = '<p class="doc-error">Error cargando historial.</p>';
    }
  }

  /**
   * Restore version from history
   */
  async function restoreVersion(historyId) {
    if (!currentDoc) return;
    const confirmed = await showConfirm('Restaurar versión', '¿Restaurar esta versión del documento?');
    if (!confirmed) return;

    try {
      await docsService.restoreFromHistory(currentDoc.id, historyId);
      closeHistory();
      await loadDocs();
      handleNavigation();
    } catch (error) {
      console.error('Error restoring version:', error);
      await showMessage('Error', 'Error al restaurar: ' + error.message);
    }
  }

  /**
   * Close history modal
   */
  function closeHistory() {
    historyModal.style.display = 'none';
  }

  /**
   * Open delete confirmation (admin only)
   */
  function openDeleteConfirm() {
    if (!currentDoc) return;
    if (!canDelete) {
      showMessage('Sin permisos', 'Solo los administradores pueden eliminar documentos.');
      return;
    }
    deleteModal.style.display = 'flex';
  }

  /**
   * Close delete modal
   */
  function closeDelete() {
    deleteModal.style.display = 'none';
  }

  /**
   * Delete document (admin only)
   */
  async function deleteDocument() {
    if (!currentDoc) return;
    if (!canDelete) {
      await showMessage('Sin permisos', 'Solo los administradores pueden eliminar documentos.');
      closeDelete();
      return;
    }

    try {
      await docsService.deleteDoc(currentDoc.id);
      closeDelete();
      await loadDocs();
      window.location.hash = '/';
    } catch (error) {
      console.error('Error deleting document:', error);
      await showMessage('Error', 'Error al eliminar: ' + error.message);
    }
  }

  /**
   * Open section modal
   */
  function openSectionModal() {
    sectionNameInput.value = '';
    sectionSlugInput.value = '';
    sectionModal.style.display = 'flex';
  }

  /**
   * Close section modal
   */
  function closeSectionModal() {
    sectionModal.style.display = 'none';
  }

  /**
   * Auto-generate slug from section name
   */
  function generateSlugFromName() {
    const name = sectionNameInput.value;
    const slug = name.toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
    sectionSlugInput.value = slug;
  }

  /**
   * Save new section
   */
  async function saveSection() {
    const name = sectionNameInput.value.trim();
    const slug = sectionSlugInput.value.trim().toLowerCase()
      .replace(/[^a-z0-9-]/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');

    if (!name) {
      await showMessage('Campo requerido', 'El nombre es obligatorio');
      return;
    }

    if (!slug) {
      await showMessage('Campo requerido', 'El slug es obligatorio');
      return;
    }

    // Check if slug already exists
    if (sections.some(s => s.slug === slug)) {
      await showMessage('Error', 'Ya existe una sección con ese slug');
      return;
    }

    try {
      const nextOrder = sections.length;
      await docsService.saveSection({ name, slug, order: nextOrder });
      closeSectionModal();
      await loadSections();
      // Update dropdown and select new section
      populateSectionDropdown(slug);
      updatePathPrefix();
      await updateOrderForSection();
    } catch (error) {
      console.error('Error saving section:', error);
      await showMessage('Error', 'Error al crear sección: ' + error.message);
    }
  }

  // Event Listeners
  window.addEventListener('hashchange', handleNavigation);

  // Admin controls
  addDocBtn.addEventListener('click', () => openEditor());
  editDocBtn.addEventListener('click', () => openEditor(currentDoc));
  deleteDocBtn.addEventListener('click', openDeleteConfirm);
  historyDocBtn.addEventListener('click', openHistory);

  // Editor modal
  document.getElementById('editor-close').addEventListener('click', closeEditor);
  document.getElementById('editor-cancel').addEventListener('click', closeEditor);
  document.getElementById('editor-save').addEventListener('click', saveDocument);
  contentInput.addEventListener('input', updatePreview);

  // Section dropdown change - update path prefix and order
  sectionInput.addEventListener('change', async () => {
    updatePathPrefix();
    await updateOrderForSection();
  });

  // Add section button
  addSectionBtn.addEventListener('click', openSectionModal);

  // Section modal
  document.getElementById('section-close').addEventListener('click', closeSectionModal);
  document.getElementById('section-cancel').addEventListener('click', closeSectionModal);
  document.getElementById('section-save').addEventListener('click', saveSection);
  sectionNameInput.addEventListener('input', generateSlugFromName);

  // History modal
  document.getElementById('history-close').addEventListener('click', closeHistory);
  document.getElementById('history-cancel').addEventListener('click', closeHistory);

  // Delete modal
  document.getElementById('delete-close').addEventListener('click', closeDelete);
  document.getElementById('delete-cancel').addEventListener('click', closeDelete);
  document.getElementById('delete-confirm').addEventListener('click', deleteDocument);

  // Close modals on overlay click
  [editorModal, historyModal, deleteModal, sectionModal].forEach(modal => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.style.display = 'none';
      }
    });
  });

  // Listen for auth changes
  document.addEventListener('user-authenticated', () => {
    setTimeout(() => checkAdminStatus(), 100);
  });

  /**
   * Migrate initial documentation to Firebase
   */
  async function migrateInitialDocs() {
    const confirmed = await showConfirm(
      'Importar documentación',
      '¿Importar la documentación inicial? Esto creará 4 secciones y 10 documentos.'
    );
    if (!confirmed) return;

    const migrateBtn = document.getElementById('migrate-docs-btn');
    if (migrateBtn) {
      migrateBtn.disabled = true;
      migrateBtn.textContent = 'Importando...';
    }

    try {
      // First migrate sections
      const sectionsCount = await docsService.migrateInitialSections();

      // Then migrate documents
      const docsCount = await docsService.migrateInitialDocs();

      await showMessage(
        'Importación completada',
        `Se importaron ${sectionsCount} secciones y ${docsCount} documentos correctamente.`
      );
      await loadDocs();
    } catch (error) {
      console.error('Error migrating docs:', error);
      await showMessage('Error', 'Error al importar: ' + error.message);
      if (migrateBtn) {
        migrateBtn.disabled = false;
        migrateBtn.textContent = 'Importar documentación inicial';
      }
    }
  }

  // Initialize
  async function init() {
    await checkAdminStatus();
    await loadDocs();
  }
  init();
</script>

