---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sprint View">
  <section class="sprintview-container">
    <h1>Sprint View</h1>
    <div class="sprintview-controls">
      <label for="projectSelector">Proyecto:</label>
      <select id="projectSelector">
        <option value="">Selecciona un proyecto</option>
      </select>
    </div>
    <div id="ganttContainer" class="gantt-wrapper"></div>
  </section>
</Layout>

<script type="module">
  import { database, ref, get } from '/firebase-config.js';
  import { isCurrentUserSuperAdmin, normalizeEmail as normalizeEmailSafe } from '/js/utils/super-admin-check.js';
  import { URLStateManager } from '/js/utils/url-utils.js';
  import '/js/wc/GanttChart.js';
  import '/js/core/app-initializer.js';

  const projectSelector = document.getElementById('projectSelector');
  const ganttContainer = document.getElementById('ganttContainer');
  let currentGanttChart = null;

  async function loadUserProjects() {
    const userEmail = document.body.dataset.userEmail || '';
    const projectsSnapshot = await get(ref(database, '/projects'));
    if (!projectsSnapshot.exists()) return [];

    const allProjects = Object.keys(projectsSnapshot.val());
    const isSuperAdmin = await isCurrentUserSuperAdmin(normalizeEmailSafe(userEmail));
    if (isSuperAdmin) return allProjects;

    const { encodeEmailForFirebase } = await import('/js/utils/email-sanitizer.js');
    const encodedEmail = encodeEmailForFirebase(userEmail);
    const userProjectsSnapshot = await get(ref(database, `/data/projectsByUser/${encodedEmail}`));

    if (!userProjectsSnapshot.exists()) return [];

    const userProjectsValue = userProjectsSnapshot.val();
    if (userProjectsValue === 'All') return allProjects;

    const userProjects = userProjectsValue.split(',').map(p => p.trim());
    return allProjects.filter(p => userProjects.includes(p));
  }

  function renderGanttChart(projectId) {
    ganttContainer.innerHTML = '';
    currentGanttChart = null;

    if (!projectId) return;

    const ganttChart = document.createElement('gantt-chart');
    ganttChart.project = projectId;
    ganttChart.year = new Date().getFullYear();
    ganttContainer.appendChild(ganttChart);
    currentGanttChart = ganttChart;
  }

  function selectProject(projectId, updateUrl = true) {
    projectSelector.value = projectId;
    renderGanttChart(projectId);
    if (updateUrl) {
      URLStateManager.updateState({ projectId });
    }
  }

  async function init() {
    const projects = await loadUserProjects();

    projects.sort((a, b) => a.localeCompare(b));
    projects.forEach(projectId => {
      const option = document.createElement('option');
      option.value = projectId;
      option.textContent = projectId;
      projectSelector.appendChild(option);
    });

    projectSelector.addEventListener('change', () => {
      selectProject(projectSelector.value);
    });

    URLStateManager.onPopState((state) => {
      if (state.projectId) {
        selectProject(state.projectId, false);
      }
    });

    // Restore project from URL or select first available
    const urlState = URLStateManager.getState();
    if (urlState.projectId && projects.includes(urlState.projectId)) {
      selectProject(urlState.projectId, false);
    } else if (projects.length > 0) {
      selectProject(projects[0], true);
    }
  }

  // Wait for auth if needed
  const userEmail = document.body.dataset.userEmail || '';
  if (userEmail) {
    init();
  } else {
    document.addEventListener('user-authenticated', () => init(), { once: true });
  }
</script>

<style is:global>
  body { background: var(--bg-secondary, #f5f7fb); }

  .sprintview-container {
    padding: 1.5rem 2rem;
  }

  .sprintview-container h1 {
    margin: 0 0 1rem;
    color: var(--text-primary, #111827);
  }

  .sprintview-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .sprintview-controls label {
    font-weight: 700;
    color: var(--text-secondary, #374151);
    font-size: 0.95rem;
  }

  .sprintview-controls select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-default, #d1d5db);
    border-radius: 8px;
    background: var(--bg-primary, #fff);
    color: var(--text-primary, #111827);
    font-size: 0.95rem;
    min-width: 200px;
    cursor: pointer;
  }

  .sprintview-controls select:focus {
    outline: none;
    border-color: var(--primary-color, #3b82f6);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .gantt-wrapper {
    background: var(--bg-primary, white);
    border-radius: 16px;
    border: 1px solid var(--border-subtle, #e2e8f0);
    box-shadow: var(--shadow-xl, 0 18px 36px rgba(15, 23, 42, 0.08));
    padding: 1.2rem;
    min-height: 400px;
  }

  @media (max-width: 820px) {
    .sprintview-container { padding: 1rem; }
  }
</style>
