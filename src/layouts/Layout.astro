---
import { ViewTransitions } from 'astro:transitions';
import MenuNav from '../components/MenuNav.astro';
import AppFooter from '../components/AppFooter.astro';

interface Props {
  title: string;
  shellRoute?: string;
  shellPartial?: string;
  shellRoutes?: Record<string, string | { partial?: string; partialUrl?: string; cache?: boolean }>;
}

const { title, shellRoute = '', shellPartial = '', shellRoutes } = Astro.props;
let user = null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="XP Planning Game" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ViewTransitions />
    <link rel="manifest" href="/manifest.json">
    <!-- Blocking: apply cached theme tokens before first paint to prevent FOUC -->
    <script is:inline>
      (function() {
        try {
          var raw = localStorage.getItem('pgxp-theme-config');
          if (!raw) return;
          var config = JSON.parse(raw);
          var tokens = config && config.tokens;
          if (!tokens) return;
          var root = document.documentElement;
          function kebab(s) { return s.replace(/([a-z])([A-Z])/g, '$1-$2').toLowerCase(); }
          function apply(obj, prefix) {
            for (var k in obj) {
              if (!obj.hasOwnProperty(k)) continue;
              var name = prefix ? '--' + prefix + '-' + kebab(k) : '--' + kebab(k);
              var v = obj[k];
              if (typeof v === 'object' && v !== null) {
                apply(v, prefix ? prefix + '-' + kebab(k) : kebab(k));
              } else {
                root.style.setProperty(name, v);
              }
            }
          }
          apply(tokens, '');
          // Apply text-on-primary alias for header/footer
          if (tokens.text && tokens.text.onPrimary) {
            root.style.setProperty('--text-on-primary', tokens.text.onPrimary);
            root.style.setProperty('--footer-text', tokens.text.onPrimary);
          }
          // Apply dark/light mode from cache
          var theme = localStorage.getItem('pgxp-theme');
          if (theme === 'dark') {
            root.classList.add('dark-theme');
            // Apply critical dark tokens before ThemeManagerService loads
            var dt = {
              '--bg-primary':'#0f172a','--bg-secondary':'#1e293b','--bg-tertiary':'#334155',
              '--text-primary':'#f8fafc','--text-secondary':'#e2e8f0','--text-muted':'#94a3b8',
              '--border-default':'#475569','--border-subtle':'#334155',
              '--card-bg':'#1e293b','--input-bg':'#1e293b','--input-border':'#475569',
              '--header-bg':'#0f172a','--modal-bg':'#0f172a',
              '--dropdown-bg':'#1e293b','--dropdown-border':'#334155',
              '--table-header-bg':'#1e293b','--table-row-bg':'#0f172a'
            };
            for (var p in dt) root.style.setProperty(p, dt[p]);
          }
        } catch(e) {}
      })();
    </script>
    <!-- Import Maps for npm packages -->
    <script type="importmap">
    {
      "imports": {
        "lit": "https://cdn.jsdelivr.net/npm/lit@3.2.1/+esm",
        "lit/": "https://cdn.jsdelivr.net/npm/lit@3.2.1/",
        "lit-html": "https://cdn.jsdelivr.net/npm/lit-html@3.2.1/+esm",
        "lit-html/": "https://cdn.jsdelivr.net/npm/lit-html@3.2.1/",
        "@lit/reactive-element": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/+esm",
        "@lit/reactive-element/": "https://cdn.jsdelivr.net/npm/@lit/reactive-element@2.0.4/",
        "@manufosela/slide-notification": "https://unpkg.com/@manufosela/slide-notification@2.1.0/src/slide-notification.js",
        "@manufosela/multi-select": "https://unpkg.com/@manufosela/multi-select@2.1.0/src/multi-select.js",
        "@manufosela/app-modal": "https://unpkg.com/@manufosela/app-modal@2.2.0/src/app-modal.js"
      }
    }
    </script>
    <!-- Precargar módulos críticos para evitar retrasos en el renderizado -->
    <link rel="modulepreload" href="https://cdn.jsdelivr.net/npm/lit@3.2.1/+esm" />
    <link rel="modulepreload" href="/firebase-config.js" />
    <!-- System Capabilities Lit Components - UMD Bundle para SSG -->
    <script src="https://cdn.jsdelivr.net/npm/@system-capabilities/lit@1.1.1/dist/system-capabilities-lit.umd.min.js"></script>
  </head>
  <body
    data-user-email={user || ''}
    data-authenticated="false"
    data-shell-route={shellRoute}
    data-shell-partial={shellPartial}
    data-shell-routes={shellRoutes ? JSON.stringify(shellRoutes) : undefined}
  >
    <header transition:animate="none">
      <a href="/" class="header-logos" data-astro-reload>
        <img src="/images/icono_PGame.png" alt="Planning Game" class="planning-game-icon" />
        <span id="orgBranding" class="org-branding hidden"></span>
      </a>
      <div class="header-title-container">
        <h1>Planning Game</h1>
        <system-status
          id="systemStatusIndicator"
          size="medium"
          autoCheck
          showTooltip
        ></system-status>
      </div>
      <div class="user-info">
        <theme-toggle></theme-toggle>
        <notification-bell id="notificationBell" class="hidden"></notification-bell>
        <span id="user-status">Cargando...</span>
        <div class="auth-actions">
          <button id="oauthLoginButton" class="login-button hidden">Sign in</button>
          <button id="emailLoginToggle" class="secondary-button hidden">Entrar con email</button>
          <form id="emailLoginForm" class="email-login-form hidden">
            <label class="sr-only" for="emailLoginInput">Correo electrónico</label>
            <input id="emailLoginInput" name="email" type="email" placeholder="Correo electrónico" autocomplete="username" required />
            <label class="sr-only" for="emailLoginPassword">Contraseña</label>
            <input id="emailLoginPassword" name="password" type="password" placeholder="Contraseña" autocomplete="current-password" required />
            <div class="email-login-actions">
              <button type="submit" class="login-button">Entrar</button>
              <button type="button" id="emailLoginCancel" class="secondary-button">Cancelar</button>
            </div>
            <p id="emailLoginError" class="error-message hidden"></p>
            <p class="form-helper-text">
              ¿No tienes cuenta?
              <button type="button" id="emailRegisterLink" class="link-button">Solicitar acceso</button>
            </p>
          </form>
          <form id="emailRegisterForm" class="email-register-form hidden">
            <h2>Solicitar acceso</h2>
            <p class="form-helper-text">Al enviar la solicitud, el equipo aprobará tu cuenta antes de que puedas acceder.</p>
            <label class="sr-only" for="emailRegisterName">Nombre completo</label>
            <input id="emailRegisterName" name="fullName" type="text" placeholder="Nombre completo" autocomplete="name" required />
            <label class="sr-only" for="emailRegisterEmail">Correo electrónico</label>
            <input id="emailRegisterEmail" name="email" type="email" placeholder="Correo electrónico corporativo" autocomplete="email" required />
            <label class="sr-only" for="emailRegisterPassword">Contraseña deseada</label>
            <input id="emailRegisterPassword" name="password" type="password" placeholder="Contraseña (mínimo 6 caracteres)" autocomplete="new-password" minlength="6" required />
            <div class="email-login-actions">
              <button type="submit" id="emailRegisterSubmit" class="login-button">Enviar solicitud</button>
              <button type="button" id="emailRegisterCancel" class="secondary-button">Cancelar</button>
            </div>
            <p id="emailRegisterError" class="error-message hidden"></p>
            <p id="emailRegisterSuccess" class="success-message hidden">Solicitud enviada. Revisaremos tus datos y te avisaremos por correo.</p>
            <p class="form-helper-text">
              ¿Ya tienes cuenta?
              <button type="button" id="emailRegisterToLogin" class="link-button">Volver a iniciar sesión</button>
            </p>
          </form>
          <button id="logoutButton" class="logout-button hidden">Logout</button>
        </div>
      </div>
    </header>

    <MenuNav currentPath={Astro.url.pathname} />

    <div id="subNavContainer"></div>

    <div id="welcomeMessage" class="welcome-container hidden">
      <div class="welcome-content">
        <img src="/images/icono_PGame.png" alt="Planning Game Logo" class="welcome-logo" />
        <h1 class="welcome-title"></h1>
        <p class="welcome-subtitle"></p>
      </div>
    </div>

    <main id="mainContainer" class="hidden">
      <div id="mainLoader" class="main-loader">
        <div class="spinner"></div>
      </div>
      <slot />
    </main>

    <AppFooter />

    <script>
      // Ocultar spinner cuando aparezca cualquier contenido visible en main
      (function() {
        const loader = document.getElementById('mainLoader');
        const main = document.getElementById('mainContainer');
        if (!loader || !main) return;

        const observer = new MutationObserver(function() {
          // Buscar cualquier elemento visible que no sea el loader
          const children = main.children;
          for (let i = 0; i < children.length; i++) {
            const child = children[i];
            if (child.id !== 'mainLoader' && child.offsetHeight > 0) {
              loader.classList.add('hidden');
              observer.disconnect();
              return;
            }
          }
        });

        observer.observe(main, { childList: true, subtree: true, attributes: true });
      })();
    </script>

    <script type="module">
      import { LazyLoader } from '/js/utils/lazy-loader.js';
      import { UserDisplayUtils } from '/js/utils/user-display-utils.js';
      import { APP_CONSTANTS } from '/js/constants/app-constants.js';
      import '/js/services/notification-service.js';
      import '/js/debug-notifications.js';
      import { database, ref, push, onValue, auth, authProvider, authProviderName, signOut, signInWithPopup, signInWithEmailAndPassword, functions, httpsCallable, app, get } from '/firebase-config.js';
      import { encodeEmailForFirebase } from '/js/utils/email-sanitizer.js';
      import { initAppShellRouterFromDataset } from '/js/core/app-shell-router.js';
      import { SYSTEM_REQUIREMENTS } from '/js/config/system-requirements-config.js';

      // Theme system - initialize on every page via Layout
      // Blocking script in <head> applies cached tokens before first paint
      import '/js/wc/ThemeToggle.js';
      import { ThemeLoaderService } from '/js/services/theme-loader-service.js';
      import { ThemeManagerService } from '/js/services/theme-manager-service.js';

      // Initialize theme services (design tokens + dark/light mode)
      // Non-blocking: init tokens synchronously, load config in background
      ThemeManagerService.init();
      ThemeLoaderService.loadAndApply().catch(() => {});

      // Version check - detect new deployments and notify users on all pages
      import '/js/wc/VersionUpdateModal.js';
      import { versionCheckService } from '/js/services/version-check-service.js';
      import { version as APP_VERSION } from '/js/version.js';
      versionCheckService.init(APP_VERSION);
      if (!document.querySelector('version-update-modal')) {
        document.body.appendChild(document.createElement('version-update-modal'));
      }

      let userStatusElement;
      let oauthLoginButton;
      let emailLoginToggle;
      let emailLoginForm;
      let emailLoginInput;
      let emailLoginPassword;
      let emailLoginError;
      let emailLoginCancel;
      let emailRegisterForm;
      let emailRegisterName;
      let emailRegisterEmail;
      let emailRegisterPassword;
      let emailRegisterError;
      let emailRegisterSuccess;
      let emailRegisterCancel;
      let emailRegisterSubmit;
      let emailRegisterLink;
      let emailRegisterToLogin;
      let logoutButton;
      let mainContainer;
      let welcomeMessage;
      let pagePath;
      let menuNav;
      let projectSelected = '';
      let theUser;
      let DOMisLoaded = false;
      let _layoutInitialized = false;
      let _authUnsubscribe = null;
      let requestAccessCallable = null;
      let _freshLoginType = null;

      // Make Firebase modules available globally for debugging
      window.database = database;
      window.ref = ref;
      window.get = get;
      window.auth = auth;

      function updatePageTitle(projectId) {
        const baseTitle = 'Planning GameXP';
        const pageTitle = document.querySelector('h1').textContent;
        document.title = projectId ? `${baseTitle} - ${projectId} - ${pageTitle}` : `${baseTitle} - ${pageTitle}`;
      }

      const EMAIL_AUTH_ERROR_MESSAGES = {
        'auth/invalid-email': 'El correo electrónico no es válido.',
        'auth/user-disabled': 'Este usuario está deshabilitado. Contacta con un administrador.',
        'auth/user-not-found': 'No existe ningún usuario con ese correo.',
        'auth/wrong-password': 'La contraseña es incorrecta.',
        'auth/invalid-credential': 'Credenciales no válidas. Revisa el correo y la contraseña.',
        'auth/too-many-requests': 'Has realizado demasiados intentos. Espera unos segundos y vuelve a intentarlo.',
        'auth/network-request-failed': 'No se puede contactar con el servidor. Revisa tu conexión a internet.'
      };

      const ACCOUNT_REQUEST_ERROR_MESSAGES = {
        'invalid-argument': 'Revisa los datos introducidos y vuelve a intentarlo.',
        'already-exists': 'Ya existe una solicitud activa o un usuario con este correo.',
        'failed-precondition': 'Este correo no pertenece a un dominio permitido.',
        'resource-exhausted': 'Has superado el número de intentos. Espera un momento antes de reintentarlo.',
        'internal': 'No se ha podido registrar la solicitud en el servidor. Inténtalo de nuevo más tarde.',
        default: 'No se ha podido enviar la solicitud. Inténtalo más tarde o contacta con soporte.'
      };

      // OAuth authentication function
      async function authenticateWithOAuth() {
        try {
          _freshLoginType = 'oauth';
          await signInWithPopup(auth, authProvider);
        } catch (error) {
          _freshLoginType = null;
          console.error('[Auth] Authentication error:', error.code, error.message);

          // Detect OAuth provider configuration errors (expired credentials, invalid config)
          const isProviderError =
            error.code === 'auth/invalid-credential' ||
            error.code === 'auth/operation-not-allowed' ||
            error.code === 'auth/internal-error' ||
            (error.message && error.message.includes('400'));

          if (isProviderError) {
            const notification = document.createElement('slide-notification');
            notification.message = 'Error de autenticación. Si el problema persiste, contacta al administrador (posibles credenciales expiradas).';
            notification.type = 'error';
            notification.timetohide = 8000;
            document.body.appendChild(notification);
          } else if (error.code === 'auth/popup-closed-by-user' || error.code === 'auth/cancelled-popup-request') {
            // User closed the popup or multiple popups, no need to show error
            return;
          } else {
            const notification = document.createElement('slide-notification');
            notification.message = 'Error de autenticación. Por favor, inténtalo de nuevo.';
            notification.type = 'error';
            document.body.appendChild(notification);
          }
        }
      }

      const normalizeEmail = (email) => (email || '').toString().trim().toLowerCase();
      const legacyEncodeEmail = (email) => normalizeEmail(email).replace(/[@.#$\[\]\/]/g, '_');

      window.isAppAdmin = false;

      async function updateAppAdminAccess(user) {
        if (!user?.email) {
          resetAppAdminAccess();
          return;
        }

        const normalizedEmail = normalizeEmail(user.email);
        const encodedEmail = encodeEmailForFirebase(normalizedEmail || user.email);
        const legacyEncodedEmail = legacyEncodeEmail(user.email);
        if (!encodedEmail) {
          resetAppAdminAccess();
          return;
        }

          try {
            let hasAccess = false;

            // First check: Super Admin from environment variable
            let superAdminEmail = '';
            try {
              const firebaseConfigModule = await import('/firebase-config.js');
              superAdminEmail = normalizeEmail(firebaseConfigModule.superAdminEmail || '');
            } catch (error) {
            }

            if (superAdminEmail && normalizedEmail === superAdminEmail) {
              hasAccess = true;
            }

            // Second check: appAdmins from Firebase (only if not already granted)
            if (!hasAccess) {
              const appAdminsRef = ref(database, '/data/appAdmins');
              const snapshot = await get(appAdminsRef);
              if (snapshot.exists()) {
                const value = snapshot.val();
                if (Array.isArray(value)) {
                  hasAccess = value.some(candidate => {
                    const normalizedCandidate = normalizeEmail(candidate);
                    return candidate === encodedEmail || normalizedCandidate === normalizedEmail;
                  });
                } else if (typeof value === 'object') {
                  const candidates = [
                    ...Object.keys(value),
                    ...Object.values(value)
                  ];
                  hasAccess = candidates.some(candidate => {
                    const normalizedCandidate = normalizeEmail(candidate);
                    return candidate === encodedEmail || normalizedCandidate === normalizedEmail;
                  });
                }
              }
            }

            // NOTE: /data/superAdminEmails is DEPRECATED and no longer used
            // SuperAdmin is only the ONE defined in .env (superAdminEmail)
            // AppAdmins are those in /data/appAdmins

            window.isAppAdmin = hasAccess;
        } catch (error) {
          window.isAppAdmin = false;
        }

        document.dispatchEvent(new CustomEvent('app-admin-status-changed', {
          detail: { isAppAdmin: window.isAppAdmin }
        }));
      }

      function resetAppAdminAccess() {
        window.isAppAdmin = false;
        document.dispatchEvent(new CustomEvent('app-admin-status-changed', {
          detail: { isAppAdmin: false }
        }));
      }

      function showEmailLoginForm() {
        if (!emailLoginForm || !emailLoginToggle) return;
        emailLoginForm.classList.remove('hidden');
        emailLoginToggle.classList.add('hidden');
        hideEmailLoginError();
        requestAnimationFrame(() => emailLoginInput?.focus());
      }

      function hideEmailLoginForm({ resetForm = false, showToggle = true } = {}) {
        if (!emailLoginForm || !emailLoginToggle) return;
        emailLoginForm.classList.add('hidden');
        if (showToggle) {
          emailLoginToggle.classList.remove('hidden');
        } else {
          emailLoginToggle.classList.add('hidden');
        }
        if (resetForm) {
          emailLoginForm.reset();
          hideEmailLoginError();
        }
      }

      function hideEmailLoginError() {
        if (!emailLoginError) return;
        emailLoginError.textContent = '';
        emailLoginError.classList.add('hidden');
      }

      function showEmailLoginError(message) {
        if (!emailLoginError) return;
        emailLoginError.textContent = message;
        emailLoginError.classList.remove('hidden');
      }

      function showEmailRegisterForm() {
        if (!emailRegisterForm) return;
        hideEmailLoginForm({ resetForm: false, showToggle: false });
        emailRegisterForm.classList.remove('hidden');
        hideEmailRegisterFeedback();
        requestAnimationFrame(() => emailRegisterName?.focus());
      }

      function hideEmailRegisterForm({ resetForm = false, showLoginToggle = true } = {}) {
        if (!emailRegisterForm) return;
        emailRegisterForm.classList.add('hidden');
        if (resetForm) {
          emailRegisterForm.reset();
        }
        hideEmailRegisterFeedback();
        setEmailRegisterSubmitting(false);
        if (showLoginToggle) {
          emailLoginToggle?.classList.remove('hidden');
        }
      }

      function hideEmailRegisterFeedback() {
        if (emailRegisterError) {
          emailRegisterError.textContent = '';
          emailRegisterError.classList.add('hidden');
        }
        if (emailRegisterSuccess) {
          emailRegisterSuccess.classList.add('hidden');
        }
      }

      function showEmailRegisterError(message) {
        if (!emailRegisterError) return;
        emailRegisterError.textContent = message;
        emailRegisterError.classList.remove('hidden');
        if (emailRegisterSuccess) {
          emailRegisterSuccess.classList.add('hidden');
        }
      }

      function showEmailRegisterSuccess(message) {
        if (!emailRegisterSuccess) return;
        emailRegisterSuccess.textContent = message;
        emailRegisterSuccess.classList.remove('hidden');
        if (emailRegisterError) {
          emailRegisterError.classList.add('hidden');
        }
      }

      function setEmailRegisterSubmitting(isSubmitting) {
        if (!emailRegisterSubmit) return;
        emailRegisterSubmit.disabled = isSubmitting;
        emailRegisterSubmit.textContent = isSubmitting ? 'Enviando...' : 'Enviar solicitud';
        if (emailRegisterForm) {
          const inputs = emailRegisterForm.querySelectorAll('input, select, textarea, button');
          inputs.forEach((input) => {
            if (input instanceof HTMLButtonElement && input.type === 'button') return;
            input.disabled = isSubmitting;
          });
        }
      }

      function getRequestAccessCallable() {
        if (!functions || !httpsCallable) return null;
        if (!requestAccessCallable) {
          try {
            requestAccessCallable = httpsCallable(functions, 'requestEmailAccess');
          } catch (error) {
            requestAccessCallable = null;
          }
        }
        return requestAccessCallable;
      }

      async function authenticateWithEmail(event) {
        event.preventDefault();
        if (!emailLoginInput || !emailLoginPassword) return;

        hideEmailLoginError();

        const email = emailLoginInput.value.trim();
        const password = emailLoginPassword.value;

        if (!email || !password) {
          showEmailLoginError('Introduce un correo y una contraseña.');
          return;
        }

        try {
          _freshLoginType = 'email';
          await signInWithEmailAndPassword(auth, email, password);
        } catch (error) {
          _freshLoginType = null;
          const message = EMAIL_AUTH_ERROR_MESSAGES[error.code] || 'Ha ocurrido un error al iniciar sesión. Inténtalo de nuevo.';
          showEmailLoginError(message);
        }
      }

      async function submitEmailRegistration(event) {
        event.preventDefault();
        if (!emailRegisterForm || !emailRegisterEmail || !emailRegisterPassword) return;

        hideEmailRegisterFeedback();

        const fullName = (emailRegisterName?.value || '').trim();
        const email = emailRegisterEmail.value.trim().toLowerCase();
        const password = emailRegisterPassword.value;

        if (!fullName || !email || !password) {
          showEmailRegisterError('Completa todos los campos obligatorios antes de enviar.');
          return;
        }

        if (password.length < 6) {
          showEmailRegisterError('La contraseña debe tener al menos 6 caracteres.');
          return;
        }

        const allowedDomains = Array.isArray(APP_CONSTANTS.AUTH_ALLOWED_EMAIL_DOMAINS)
          ? APP_CONSTANTS.AUTH_ALLOWED_EMAIL_DOMAINS
          : [];
        const emailDomain = email.split('@')[1];
        if (!emailDomain || !allowedDomains.includes(emailDomain)) {
          showEmailRegisterError('El correo debe pertenecer a un dominio autorizado por la compañía.');
          return;
        }

        const callable = getRequestAccessCallable();
        if (!callable) {
          showEmailRegisterError('Servicio no disponible temporalmente. Inténtalo más tarde.');
          return;
        }

        setEmailRegisterSubmitting(true);

        try {
          await callable({
            fullName,
            email,
            password
          });

          showEmailRegisterSuccess('Solicitud enviada. Revisaremos tus datos y activaremos la cuenta cuando sea aprobada.');
          if (emailRegisterForm) {
            emailRegisterForm.reset();
          }
        } catch (error) {
          const errorCode = error?.code?.replace('functions/', '');
          const message = ACCOUNT_REQUEST_ERROR_MESSAGES[errorCode] || ACCOUNT_REQUEST_ERROR_MESSAGES.default;
          showEmailRegisterError(message);
        } finally {
          setEmailRegisterSubmitting(false);
        }
      }

      function addProjectToLinks(projectId) {
        const links = [...document.querySelectorAll('.menu-nav .nav-link')].slice(1);
        links.forEach((link) => {
          try {
            const url = new URL(link.href, window.location.origin);
            url.searchParams.set('projectId', projectId);
            link.href = url.toString();
          } catch (e) {
            // Si algo falla, no romper la navegación
          }
        });
        updatePageTitle(projectId);
      }


      function notSignedIn() {
        getDomElements();
        theUser = null;
        window.currentUser = null; // Limpiar también window.currentUser
        resetAppAdminAccess();
        document.body.setAttribute('data-authenticated', 'false');

        // Redirect to home if on a protected page
        const protectedPages = ['/adminproject', '/dashboard', '/sprintview', '/development', '/wip', '/proposals'];
        const currentPath = window.location.pathname;
        if (protectedPages.some(page => currentPath.startsWith(page))) {
          window.location.href = '/';
          return;
        }

        userStatusElement.textContent = 'Not signed in';
        oauthLoginButton?.classList.remove('hidden');
        emailLoginToggle?.classList.remove('hidden');
        hideEmailLoginForm({ resetForm: true });
        hideEmailRegisterForm({ resetForm: true });
        logoutButton.classList.add('hidden');
        mainContainer.classList.add('hidden');
        if (welcomeMessage) {
          welcomeMessage.classList.remove('hidden');
        }
        const notificationBell = document.getElementById('notificationBell');
        if (notificationBell) {
          notificationBell.classList.add('hidden');
        }

        // Notify menu about user sign out
        document.dispatchEvent(new CustomEvent('user-signed-out'));
      }

      function _recordLoginEvent(user) {
        const sessionKey = `loginRecorded_${user.uid}`;
        if (sessionStorage.getItem(sessionKey)) return;
        const encodedEmail = encodeEmailForFirebase((user.email || '').toLowerCase());
        if (!encodedEmail) return;
        push(ref(database, `/loginHistory/${encodedEmail}`), {
          timestamp: new Date().toISOString(),
          email: user.email,
          displayName: user.displayName || '',
          provider: user.providerData?.[0]?.providerId || 'unknown',
          loginType: _freshLoginType || 'session-restore',
          userAgent: navigator.userAgent,
        }).then(() => sessionStorage.setItem(sessionKey, 'true'))
          .catch(e => console.error('[Auth] Login event failed:', e));
        _freshLoginType = null;
      }

      function signedIn(user) {
        getDomElements();
        theUser = user;
        window.currentUser = user; // Añadir para que lo use NotificationBell
        document.body.setAttribute('data-authenticated', 'true');
        const userName = user.displayName || user.email || 'Usuario sin nombre';
        userStatusElement.textContent = `Signed in as ${userName}`;
        oauthLoginButton?.classList.add('hidden');
        emailLoginToggle?.classList.add('hidden');
        hideEmailLoginForm({ resetForm: true, showToggle: false });
        hideEmailRegisterForm({ resetForm: true, showLoginToggle: false });
        logoutButton.classList.remove('hidden');
        mainContainer.classList.remove('hidden');
        if (welcomeMessage) {
          welcomeMessage.classList.add('hidden');
        }
        // Navigation allowed - MenuNav SSR handles this automatically
        if (pagePath !== '/') {
          addProjectToLinks(projectSelected);
        }
        document.body.dataset.userEmail = user.email || '';

        // Show notification bell
        const notificationBell = document.getElementById('notificationBell');
        if (notificationBell) {
          notificationBell.classList.remove('hidden');
        }

        // Notify notification bell about user authentication
        document.dispatchEvent(new CustomEvent('user-authenticated', {
          detail: { user: user }
        }));

        updateAppAdminAccess(user);

        // Record login event for history tracking
        _recordLoginEvent(user);

        // Initialize FCM for push notifications
        if (window.pushNotificationService) {
          window.pushNotificationService.reinitializeForUser(user.email).catch(error => {
          });
        }
      }


      function getDomElements() {
        userStatusElement = document.getElementById('user-status');
        oauthLoginButton = document.getElementById('oauthLoginButton');
        emailLoginToggle = document.getElementById('emailLoginToggle');
        emailLoginForm = document.getElementById('emailLoginForm');
        emailLoginInput = document.getElementById('emailLoginInput');
        emailLoginPassword = document.getElementById('emailLoginPassword');
        emailLoginError = document.getElementById('emailLoginError');
        emailLoginCancel = document.getElementById('emailLoginCancel');
        emailRegisterForm = document.getElementById('emailRegisterForm');
        emailRegisterName = document.getElementById('emailRegisterName');
        emailRegisterEmail = document.getElementById('emailRegisterEmail');
        emailRegisterPassword = document.getElementById('emailRegisterPassword');
        emailRegisterError = document.getElementById('emailRegisterError');
        emailRegisterSuccess = document.getElementById('emailRegisterSuccess');
        emailRegisterCancel = document.getElementById('emailRegisterCancel');
        emailRegisterSubmit = document.getElementById('emailRegisterSubmit');
        emailRegisterLink = document.getElementById('emailRegisterLink');
        emailRegisterToLogin = document.getElementById('emailRegisterToLogin');
        logoutButton = document.getElementById('logoutButton');
        mainContainer = document.getElementById('mainContainer');
        welcomeMessage = document.getElementById('welcomeMessage');
        menuNav = document.getElementById('menunav');
      }

      function applyOrganizationBranding() {
        const container = document.getElementById('orgBranding');
        if (!container) return;

        const orgName = APP_CONSTANTS.ORG_NAME;
        // If no org name configured, skip branding entirely
        if (!orgName) return;

        const imageExtensions = ['.png', '.jpg', '.jpeg', '.svg', '.webp'];
        const isImagePath = imageExtensions.some(ext => orgName.toLowerCase().endsWith(ext));

        // Try to load org logo image (symlinked from instance to /images/org-logo.*)
        // We try common extensions since the instance may have any format
        const extensionsToTry = isImagePath
          ? [orgName.substring(orgName.lastIndexOf('.'))]
          : [...imageExtensions];

        function tryLoadImage(exts, index = 0) {
          if (index >= exts.length) {
            // No image found — fall back to text h1 if orgName is plain text
            if (orgName && !isImagePath) {
              const heading = document.createElement('h1');
              heading.className = 'org-name-heading';
              heading.textContent = orgName;
              container.innerHTML = '';
              container.append(heading);
              container.classList.remove('hidden');
              container.setAttribute('aria-label', `Organización: ${orgName}`);
            }
            return;
          }
          const img = new Image();
          img.src = `/images/org-logo${exts[index]}`;
          img.onload = () => {
            img.alt = (isImagePath ? '' : orgName) || 'Organization logo';
            img.className = 'org-logo';
            container.innerHTML = '';
            container.append(img);
            container.classList.remove('hidden');
          };
          img.onerror = () => tryLoadImage(exts, index + 1);
        }

        tryLoadImage(extensionsToTry);
      }

      async function DOMContentLoadedActions() {
        getDomElements();
        applyOrganizationBranding();
        pagePath = window.location.pathname;

        if (!_layoutInitialized) {
          if (oauthLoginButton) {
            const providerLabels = { google: 'Google', microsoft: 'Microsoft', github: 'GitHub', gitlab: 'GitLab' };
            oauthLoginButton.textContent = `Sign in with ${providerLabels[authProviderName] || 'OAuth'}`;
            oauthLoginButton.addEventListener('click', authenticateWithOAuth);
          }
          if (emailLoginToggle) {
            emailLoginToggle.addEventListener('click', showEmailLoginForm);
          }
          if (emailLoginForm) {
            emailLoginForm.addEventListener('submit', authenticateWithEmail);
          }
          if (emailLoginCancel) {
            emailLoginCancel.addEventListener('click', () => hideEmailLoginForm({ resetForm: true }));
          }
          if (emailRegisterForm) {
            emailRegisterForm.addEventListener('submit', submitEmailRegistration);
          }
          if (emailRegisterCancel) {
            emailRegisterCancel.addEventListener('click', () => hideEmailRegisterForm({ resetForm: true }));
          }
          if (emailRegisterLink) {
            emailRegisterLink.addEventListener('click', showEmailRegisterForm);
          }
          if (emailRegisterToLogin) {
            emailRegisterToLogin.addEventListener('click', () => {
              hideEmailRegisterForm({ resetForm: false, showLoginToggle: false });
              showEmailLoginForm();
            });
          }
          if (logoutButton) {
            logoutButton.addEventListener('click', () => signOut(auth));
          }

          // Subscribe to auth state changes (only once)
          _authUnsubscribe = auth.onAuthStateChanged((user) => {
            if (user) {
              signedIn(user);
            } else {
              notSignedIn();
            }
          });

          _layoutInitialized = true;
        }

        if (auth.currentUser && document.body.dataset.authenticated !== 'true') {
          signedIn(auth.currentUser);
        }

        await getProjectIdFromURLparamProjectId();
        if (document.body.dataset.authenticated === 'true' && projectSelected) {
          addProjectToLinks(projectSelected);
        }

        // Set welcome messages from constants
        const welcomeTitle = document.querySelector('.welcome-title');
        const welcomeSubtitle = document.querySelector('.welcome-subtitle');
        if (welcomeTitle) welcomeTitle.textContent = APP_CONSTANTS.WELCOME_MESSAGES.TITLE;
        if (welcomeSubtitle) welcomeSubtitle.textContent = APP_CONSTANTS.WELCOME_MESSAGES.SUBTITLE;

        // Wait for MenuNav SSR to initialize
        if (window.menuNavSSR) {
          window.menuNavSSR.updateNavLinks();
          window.menuNavSSR.markActiveLinkByURL();
        } else {
          // Fallback if MenuNav SSR not ready yet
          setTimeout(() => {
            if (window.menuNavSSR) {
              window.menuNavSSR.updateNavLinks();
              window.menuNavSSR.markActiveLinkByURL();
            }
          }, 100);
        }

        // Load page-specific components with lazy loading
        const currentPage = pagePath.split('/')[1] || 'index';
        LazyLoader.loadPageComponents(currentPage);

        if (!window.appShellRouter) {
          const router = initAppShellRouterFromDataset();
          if (router) {
            window.appShellRouter = router;
          }
        }

        DOMisLoaded = true;
      }

      function getProjectIdFromURLparamProjectId() {
        const projectId = new URLSearchParams(window.location.search).get('projectId');
        if (projectId) {
          projectSelected = projectId;
          updatePageTitle(projectId);
        }
      }

      // Configurar requisitos del sistema usando el componente del paquete
      function initSystemRequirementsChecker() {
        try {

          // Obtener el componente system-status
          const statusIndicator = document.getElementById('systemStatusIndicator');

          if (statusIndicator) {
            // Configurar requisitos desde nuestra configuración
            statusIndicator.requirements = {
              features: SYSTEM_REQUIREMENTS.features.required.reduce((acc, feature) => {
                acc[feature] = true;
                return acc;
              }, {}),
              device: {
                minMemory: SYSTEM_REQUIREMENTS.memory.minimum / 1024, // Convertir MB a GB
                minCores: 2
              },
              screen: {
                minWidth: SYSTEM_REQUIREMENTS.screen.minWidth,
                minHeight: SYSTEM_REQUIREMENTS.screen.minHeight
              }
            };

            // Escuchar eventos del componente
            statusIndicator.addEventListener('status-change', (e) => {
              if (e.detail.failures && e.detail.failures.length > 0) {
              }
            });

            statusIndicator.addEventListener('click', (e) => {
            });

          } else {
          }
        } catch (error) {
        }
      }

      // Run on every page load (initial + View Transition navigations)
      document.addEventListener('astro:page-load', () => {
        DOMContentLoadedActions();
        setTimeout(initSystemRequirementsChecker, 100);
      });
    </script>

