---
const currentPath = Astro.url.pathname;

function isExactMatch(href: string): boolean {
  const cleanHref = href.replace(/\/$/, '') || '/doc';
  const cleanPath = currentPath.replace(/\/$/, '') || '/doc';
  return cleanPath === cleanHref;
}
---

