<style is:global>
  .backlog-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .backlog-card {
    border: 1px solid var(--border-default, #e5e7eb);
    border-radius: 12px;
    padding: 0.5rem 1rem 1rem;
    background: var(--bg-primary, #fff);
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,0.05));
    overflow: hidden;
  }

  .backlog-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
    width: 100%;
    margin: 0;
  }

  .backlog-card__header::-webkit-details-marker {
    display: none;
  }

  .backlog-card[open] {
    border-color: var(--border-strong, #d1d5db);
    box-shadow: var(--shadow-md, 0 2px 4px rgba(0,0,0,0.08));
  }

  .backlog-card[open] summary {
    border-bottom: 1px solid var(--border-default, #e5e7eb);
    margin-bottom: 0.5rem;
  }

  .summary-left {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    text-align: left;
  }

  .summary-name {
    font-weight: 800;
    color: var(--text-primary, #111827);
    font-size: 1.05rem;
  }

  .summary-email {
    color: var(--text-muted, #6b7280);
    font-size: 0.9rem;
  }

  .summary-right {
    display: flex;
    gap: 0.35rem;
    justify-content: flex-end;
    align-items: center;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .caret {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    color: var(--text-muted, #6b7280);
    margin-right: 0.35rem;
    transition: transform 0.2s ease;
    font-size: 0.9rem;
    min-width: 18px;
  }

  .caret::before {
    content: '▶';
    font-size: 0.9rem;
  }

  details[open] .caret {
    transform: rotate(90deg);
  }

  details[open] .caret::before {
    content: '▼';
  }

  .backlog-table-head,
  .backlog-row {
    display: grid;
    grid-template-columns: 40px 2fr 1fr 1fr 1fr 120px;
    align-items: center;
    gap: 0.35rem;
  }

  .backlog-table-head {
    font-size: 0.9rem;
    color: var(--text-secondary, #4b5563);
    font-weight: 700;
    border-bottom: 1px solid var(--border-default, #e5e7eb);
    padding: 0.35rem 0.25rem;
  }

  .backlog-row {
    border-bottom: 1px solid var(--border-default, #e5e7eb);
    padding: 0.4rem 0.25rem;
  }

  .backlog-row:hover {
    background: var(--bg-secondary, #f9fafb);
  }

  .cell-title a {
    color: var(--text-primary, #111827);
    font-weight: 700;
    text-decoration: none;
  }

  .cell-title a:hover {
    text-decoration: underline;
  }

  .cell-sub {
    color: var(--text-muted, #6b7280);
    font-size: 0.85rem;
  }

  .drag-cell {
    cursor: grab;
    color: var(--text-disabled, #9ca3af);
    font-size: 1.1rem;
    width: 32px;
    text-align: center;
  }

  .backlog-empty {
    color: var(--text-muted, #6b7280);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .backlog-card__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .backlog-table-head,
    .backlog-row {
      grid-template-columns: 32px 1fr;
      grid-template-rows: repeat(5, auto);
      grid-auto-flow: row;
    }
  }
</style>
