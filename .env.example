# Firebase Configuration
PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.europe-west1.firebasedatabase.app
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key
PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# Super Admin
PUBLIC_SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Application Branding
PUBLIC_APP_NAME=Planning Game XP
PUBLIC_APP_URL=https://your-app-url.web.app
PUBLIC_BRAND_COLOR=#01caca

# Auth
PUBLIC_ALLOWED_EMAIL_DOMAINS=yourdomain.com,otherdomain.com

# Default API email (used by Cloud Functions)
PUBLIC_DEFAULT_API_EMAIL=api@yourdomain.com

# Emulators (development only)
USE_FIREBASE_EMULATOR=false

# AI Configuration (optional)
PUBLIC_AI_PROVIDER=gemini
PUBLIC_AI_ENDPOINT=https://generativelanguage.googleapis.com
PUBLIC_AI_MODEL=gemini-2.0-flash
PUBLIC_AI_API_KEY=your-ai-api-key
